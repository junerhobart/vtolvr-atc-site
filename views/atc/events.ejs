<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="author" content="Aviation Realism Network">
    <meta name="description" content="Plan and manage ATC events for VTOL VR sessions">
    <meta name="keywords" content="ATC, Events, Planning, VTOL VR, Aviation">
    <title>ATC Events</title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <style>
        .main-content {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .page-wrap {
            flex: 1;
            max-width: 1100px;
            margin: 0 auto;
            padding: 48px 24px;
            width: 100%;
        }

        .hero {
            margin-bottom: 32px;
            text-align: center;
            padding-top: 20px;
        }

        .hero h1 {
            font-size: 2.5em;
            font-weight: 700;
            color: #e0e0e0;
            margin-bottom: 10px;
        }

        .hero p {
            color: #e0e0e0;
            font-size: 1.1em;
            opacity: 0.9;
        }

        .content-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            align-items: start;
        }

        /* Panels */
        .panel {
            padding: 24px 0;
        }

        .panel-title {
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: rgba(245,243,239,0.45);
            padding-bottom: 14px;
            margin-bottom: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }

        /* Form */
        .form-group {
            margin-bottom: 16px;
        }

        .form-group label {
            display: block;
            font-size: 0.8rem;
            font-weight: 500;
            color: rgba(245,243,239,0.5);
            margin-bottom: 6px;
        }

        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 10px 12px;
            background: #1e1e1e;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: #f5f3ef;
            font-family: "Inter", sans-serif;
            font-size: 0.875rem;
            transition: border-color 0.15s;
        }

        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            outline: none;
            border-color: rgba(255,255,255,0.25);
            background: #242424;
        }

        .form-group textarea { resize: vertical; min-height: 72px; }
        .form-group select option { background: #232323; }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 0;
        }

        .checkbox-group input[type="checkbox"] {
            width: 16px;
            height: 16px;
            cursor: pointer;
            accent-color: #888;
            flex-shrink: 0;
        }

        .checkbox-group label {
            font-size: 0.875rem;
            color: rgba(245,243,239,0.7);
            cursor: pointer;
            margin: 0;
        }

        .submit-btn {
            width: 100%;
            padding: 12px;
            background: #3a3a3a;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: #f5f3ef;
            font-family: "Inter", sans-serif;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.15s;
            margin-top: 8px;
        }

        .submit-btn:hover {
            background: #444;
            border-color: rgba(255,255,255,0.16);
        }

        /* Alerts */
        .alert {
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 0.875rem;
            margin-bottom: 16px;
            display: none;
        }

        .alert.show { display: block; }

        .alert-success {
            background: rgba(50,180,80,0.1);
            border: 1px solid rgba(50,180,80,0.25);
            color: #b6f3be;
        }

        .alert-error {
            background: rgba(220,50,50,0.12);
            border: 1px solid rgba(220,50,50,0.25);
            color: #ffb0b0;
        }

        /* Events list */
        .events-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .event-card {
            background: #1e1e1e;
            border: 1px solid rgba(255,255,255,0.07);
            border-left: 3px solid rgba(255,255,255,0.15);
            border-radius: 8px;
            padding: 16px;
            transition: border-color 0.15s;
        }

        .event-card:hover { border-color: rgba(255,255,255,0.14); }
        .event-card.active  { border-left-color: #73d87a; }
        .event-card.upcoming { border-left-color: rgba(100,160,255,0.7); }
        .event-card.completed { border-left-color: rgba(255,193,7,0.6); }

        .event-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
            gap: 8px;
        }

        .event-name {
            font-size: 0.95rem;
            font-weight: 600;
            color: #f5f3ef;
        }

        .event-badge {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 3px 10px;
            border-radius: 20px;
            white-space: nowrap;
        }

        .badge-active   { background: rgba(76,175,80,0.15);  color: #73d87a; }
        .badge-upcoming { background: rgba(33,150,243,0.12); color: #90caf9; }
        .badge-completed{ background: rgba(255,193,7,0.12);  color: #ffd75e; }

        .event-meta {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .meta-row {
            display: flex;
            gap: 8px;
            font-size: 0.8rem;
        }

        .meta-label {
            color: rgba(245,243,239,0.35);
            min-width: 90px;
            flex-shrink: 0;
        }

        .meta-value { color: rgba(245,243,239,0.7); }

        .empty-state {
            text-align: center;
            padding: 32px 20px;
            color: rgba(245,243,239,0.3);
            font-size: 0.9rem;
        }

        footer {
            text-align: center;
            padding: 24px 20px;
            font-size: 0.8rem;
            color: rgba(245,243,239,0.3);
        }

        @media (max-width: 900px) {
            .content-grid { grid-template-columns: 1fr; }
        }

        @media (max-width: 768px) {
            .page-wrap { padding: 32px 16px; }
            .hero h1 { font-size: 1.8em; }
            .form-row { grid-template-columns: 1fr; }
        }

        <%- include('../partials/fixed-sidebar-theme') %>
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { page: 'events' }) %>

    <div class="main-content">
        <div class="page-wrap">
            <div class="hero">
                <h1>ATC Events</h1>
                <p>Create and manage VTOL VR ATC sessions and events.</p>
            </div>

            <div class="content-grid">
                <!-- Create form -->
                <div class="panel">
                    <div class="panel-title">Create New Event</div>

                    <div class="alert alert-success" id="successMessage"></div>
                    <div class="alert alert-error" id="errorMessage"></div>

                    <form id="eventForm" onsubmit="handleSubmit(event)">
                        <div class="form-group">
                            <label for="eventName">Event Name</label>
                            <input type="text" id="eventName" placeholder="e.g., Flight Training Session" required>
                        </div>
                        <div class="form-group">
                            <label for="hostName">Host Name</label>
                            <input type="text" id="hostName" placeholder="Enter host name" required>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="airport">Airport / Location</label>
                                <input type="text" id="airport" placeholder="e.g., KJFK" required>
                            </div>
                            <div class="form-group">
                                <label for="map">Map</label>
                                <input type="text" id="map" placeholder="Map name">
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="timezone">Timezone</label>
                                <select id="timezone" required>
                                    <option value="">Select...</option>
                                    <option value="UTC">UTC</option>
                                    <option value="EST">Eastern (EST)</option>
                                    <option value="CST">Central (CST)</option>
                                    <option value="MST">Mountain (MST)</option>
                                    <option value="PST">Pacific (PST)</option>
                                    <option value="GMT">GMT</option>
                                    <option value="CET">Central European (CET)</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="duration">Duration (hours)</label>
                                <input type="number" id="duration" placeholder="e.g., 2" min="0.5" step="0.5" required>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label for="startTime">Start Date & Time</label>
                                <input type="datetime-local" id="startTime" required>
                            </div>
                            <div class="form-group">
                                <label for="endTime">End Date & Time</label>
                                <input type="datetime-local" id="endTime" required>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="pilots">Expected Pilots</label>
                            <input type="number" id="pilots" placeholder="Number of pilots" min="1" required>
                        </div>
                        <div class="form-group">
                            <label for="description">Description / Notes</label>
                            <textarea id="description" placeholder="Additional notes for pilots..."></textarea>
                        </div>
                        <div class="checkbox-group">
                            <input type="checkbox" id="alertServer">
                            <label for="alertServer">Alert server to this event</label>
                        </div>
                        <button type="submit" class="submit-btn">Create Event</button>
                    </form>
                </div>

                <!-- Events list -->
                <div class="panel">
                    <div class="panel-title">Upcoming Events</div>
                    <div class="events-list" id="eventsList">
                        <div class="empty-state">Loading events...</div>
                    </div>
                </div>
            </div>
        </div>

        <footer>
            <%#  <p>&copy; 2026 Aviation Realism Network. All rights reserved.</p> %>
            <p>Bringing realistic aviation simulation to VTOL VR</p>
        </footer>
    </div>

    <script>
        document.getElementById('startTime').addEventListener('change', calculateEndTime);
        document.getElementById('duration').addEventListener('change', calculateEndTime);

        function calculateEndTime() {
            const start = document.getElementById('startTime').value;
            const duration = parseFloat(document.getElementById('duration').value);
            if (!start || !duration) return;
            const end = new Date(new Date(start).getTime() + duration * 3600000);
            const pad = n => String(n).padStart(2, '0');
            document.getElementById('endTime').value =
                `${end.getFullYear()}-${pad(end.getMonth()+1)}-${pad(end.getDate())}T${pad(end.getHours())}:${pad(end.getMinutes())}`;
        }

        function handleSubmit(e) {
            e.preventDefault();
            const eventData = {
                name:        document.getElementById('eventName').value,
                hostName:    document.getElementById('hostName').value,
                airport:     document.getElementById('airport').value,
                map:         document.getElementById('map').value,
                timezone:    document.getElementById('timezone').value,
                duration:    parseFloat(document.getElementById('duration').value),
                startTime:   new Date(document.getElementById('startTime').value),
                endTime:     new Date(document.getElementById('endTime').value),
                pilots:      parseInt(document.getElementById('pilots').value),
                description: document.getElementById('description').value,
                alertServer: document.getElementById('alertServer').checked
            };

            if (eventData.startTime >= eventData.endTime) {
                showAlert('error', 'End time must be after start time.');
                return;
            }

            fetch('/api/events/create', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(eventData)
            })
            .then(r => { if (!r.ok) throw new Error('Failed to create event'); return r.json(); })
            .then(() => {
                showAlert('success', 'Event created successfully!');
                document.getElementById('eventForm').reset();
                setTimeout(loadEvents, 1500);
            })
            .catch(err => showAlert('error', 'Error creating event: ' + err.message));
        }

        function loadEvents() {
            fetch('/api/events')
                .then(r => { if (!r.ok) throw new Error('Failed to load events.'); return r.json(); })
                .then(payload => renderEvents(payload.data || []))
                .catch(error => {
                    document.getElementById('eventsList').innerHTML = '<div class="empty-state">' + error.message + '</div>';
                });
        }

        function renderEvents(events) {
            const container = document.getElementById('eventsList');
            if (!events.length) {
                container.innerHTML = '<div class="empty-state">No events scheduled yet.</div>';
                return;
            }
            container.innerHTML = events.map(ev => {
                const status = ev.status || 'upcoming';
                const badgeClass = `badge-${status}`;
                const start = new Date(ev.startTime).toLocaleString();
                const end   = new Date(ev.endTime).toLocaleString();
                return `
                    <div class="event-card ${status}">
                        <div class="event-header">
                            <span class="event-name">${ev.name}</span>
                            <span class="event-badge ${badgeClass}">${status}</span>
                        </div>
                        <div class="event-meta">
                            <div class="meta-row"><span class="meta-label">Host</span><span class="meta-value">${ev.hostName || 'N/A'}</span></div>
                            <div class="meta-row"><span class="meta-label">Location</span><span class="meta-value">${ev.airport}</span></div>
                            <div class="meta-row"><span class="meta-label">Timezone</span><span class="meta-value">${ev.timezone}</span></div>
                            <div class="meta-row"><span class="meta-label">Start</span><span class="meta-value">${start}</span></div>
                            <div class="meta-row"><span class="meta-label">End</span><span class="meta-value">${end}</span></div>
                            <div class="meta-row"><span class="meta-label">Pilots</span><span class="meta-value">${ev.pilots || 'N/A'}</span></div>
                            ${ev.description ? `<div class="meta-row"><span class="meta-label">Notes</span><span class="meta-value">${ev.description}</span></div>` : ''}
                        </div>
                    </div>
                `;
            }).join('');
        }

        function showAlert(type, message) {
            const el = document.getElementById(type === 'error' ? 'errorMessage' : 'successMessage');
            el.textContent = message;
            el.classList.add('show');
            setTimeout(() => el.classList.remove('show'), 4000);
        }

        loadEvents();
        setInterval(loadEvents, 30000);
    </script>
</body>
</html>
