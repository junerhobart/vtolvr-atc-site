<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="METAR Input - Air Traffic Control Weather Report">
    <title>METAR Report</title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #1a1a1a;
            color: #e0e0e0;
            min-height: 100vh;
            display: flex;
        }

        .main-content {
            margin-left: 280px;
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            padding: 40px 32px;
        }

        .page-wrap {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 24px;
            max-width: 680px;
            width: 100%;
            margin: 0 auto;
        }

        .page-header {
            text-align: center;
            padding-top: 20px;
            margin-bottom: 30px;
        }

        .page-title {
            font-size: 2.5em;
            font-weight: 700;
            color: #e0e0e0;
            margin-bottom: 10px;
        }

        .page-subtitle {
            font-size: 1.1em;
            color: #e0e0e0;
            opacity: 0.9;
        }

        .panel {
            padding: 24px 0;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .section-label {
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #888;
            padding-bottom: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .form-label {
            font-size: 0.85rem;
            font-weight: 600;
            color: #c0c0c0;
        }

        .form-label .required {
            color: #e05c5c;
            margin-left: 3px;
        }

        .input-row {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .form-input {
            flex: 1;
            padding: 10px 12px;
            background: #1a1a1a;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 6px;
            color: #e0e0e0;
            font-size: 0.92rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .form-input:focus {
            outline: none;
            border-color: rgba(255,255,255,0.25);
            box-shadow: 0 0 0 3px rgba(255,255,255,0.04);
        }

        .form-input::placeholder { color: #555; }

        .form-input[readonly] {
            color: #888;
            cursor: default;
        }

        textarea.form-input { resize: vertical; }

        .unit-label {
            font-size: 0.82rem;
            color: #666;
            white-space: nowrap;
            min-width: 44px;
        }

        .checkbox-row {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            background: #1a1a1a;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 6px;
            cursor: pointer;
            transition: border-color 0.2s;
        }

        .checkbox-row:hover { border-color: rgba(255,255,255,0.22); }

        .checkbox-row input[type="checkbox"] {
            width: 16px;
            height: 16px;
            cursor: pointer;
            accent-color: #e0e0e0;
            flex-shrink: 0;
        }

        .checkbox-row label {
            font-size: 0.9rem;
            color: #c0c0c0;
            cursor: pointer;
            margin: 0;
        }

        .hint {
            font-size: 0.78rem;
            color: #555;
        }

        .btn-group {
            display: flex;
            gap: 10px;
            padding-top: 4px;
        }

        .btn {
            flex: 1;
            padding: 11px 20px;
            border: none;
            border-radius: 6px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.2s, transform 0.1s;
        }

        .btn:hover { opacity: 0.88; }
        .btn:active { transform: scale(0.98); }

        .btn-primary {
            background: #e0e0e0;
            color: #1a1a1a;
        }

        .btn-ghost {
            background: transparent;
            color: #aaa;
            border: 1px solid rgba(255,255,255,0.12);
        }

        .btn-ghost:hover {
            border-color: rgba(255,255,255,0.25);
            color: #e0e0e0;
        }

        .alert {
            padding: 12px 16px;
            border-radius: 6px;
            font-size: 0.88rem;
            font-weight: 500;
            display: none;
        }

        .alert.show { display: block; }

        .alert-success {
            background: rgba(74, 175, 80, 0.15);
            border: 1px solid rgba(74, 175, 80, 0.35);
            color: #81c784;
        }

        .alert-error {
            background: rgba(224, 92, 92, 0.12);
            border: 1px solid rgba(224, 92, 92, 0.3);
            color: #ef9a9a;
        }

        footer {
            margin-top: auto;
            padding-top: 40px;
            text-align: center;
            font-size: 0.8rem;
            color: #555;
        }

        /* Virtual Keyboard */
        .vk-toggle-btn {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1001;
            background: #2e2e2e;
            color: #e0e0e0;
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 50%;
            width: 52px;
            height: 52px;
            font-size: 1.4em;
            cursor: pointer;
            box-shadow: 0 4px 16px rgba(0,0,0,0.4);
            transition: bottom 0.25s ease, background 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .vk-toggle-btn:hover { background: #383838; }

        .vk-toggle-btn.kb-open {
            bottom: calc(var(--kb-height, 240px) + 14px);
        }

        .virtual-keyboard {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background: rgba(18, 18, 18, 0.97);
            backdrop-filter: blur(12px);
            border-top: 1px solid rgba(255,255,255,0.08);
            padding: 10px 8px 16px;
            z-index: 1000;
            transform: translateY(100%);
            transition: transform 0.25s ease;
            display: flex;
            flex-direction: column;
            gap: 5px;
            align-items: center;
        }

        .virtual-keyboard.active { transform: translateY(0); }

        .vk-row {
            display: flex;
            gap: 4px;
            justify-content: center;
            width: 100%;
            max-width: 860px;
        }

        .vk-key {
            background: rgba(40, 40, 40, 0.9);
            color: #c0c0c0;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 6px;
            height: 38px;
            flex: 1;
            min-width: 0;
            font-size: 0.82em;
            cursor: pointer;
            transition: background 0.1s, transform 0.08s;
            text-align: center;
            user-select: none;
            -webkit-user-select: none;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 2px;
        }

        .vk-key:hover {
            background: rgba(60, 60, 60, 0.9);
            border-color: rgba(255,255,255,0.18);
            color: #fff;
        }

        .vk-key:active {
            background: #444;
            transform: scale(0.93);
        }

        .vk-key-wide   { flex: 1.6; }
        .vk-key-space  { flex: 5; }
        .vk-key-action {
            background: rgba(50, 50, 50, 0.9);
            border-color: rgba(255,255,255,0.12);
        }

        @media (max-width: 768px) {
            .main-content {
                margin-left: 0;
                padding: 20px 16px;
            }
        }

        <%- include('../partials/fixed-sidebar-theme') %>
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { page: 'metar' }) %>

    <div class="main-content">
        <div class="page-wrap">
            <div class="page-header">
                <h1 class="page-title">METAR Report</h1>
                <p class="page-subtitle">Submit weather conditions for air traffic control</p>
            </div>

            <div id="successMessage" class="alert alert-success"></div>
            <div id="errorMessage" class="alert alert-error"></div>

            <form id="metarForm">
                <div class="panel">
                    <div class="section-label">General Information</div>

                    <div class="form-group">
                        <label class="form-label">Report Timestamp</label>
                        <input type="text" class="form-input" id="reportTimestamp" value="<%= new Date().toLocaleString() %>" readonly>
                        <span class="hint">Timestamp is generated automatically on submit.</span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Session ID</label>
                        <input type="text" class="form-input" id="sessionId" placeholder="Enter session ID if applicable">
                    </div>
                </div>

                <div class="panel" style="margin-top: 16px;">
                    <div class="section-label">Wind Information</div>

                    <div class="form-group">
                        <label class="form-label">Wind Direction <span class="required">*</span></label>
                        <div class="input-row">
                            <input type="number" class="form-input" id="windDirection" placeholder="000–360" min="0" max="360" required>
                            <span class="unit-label">°</span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Wind Speed <span class="required">*</span></label>
                        <div class="input-row">
                            <input type="number" class="form-input" id="windSpeed" placeholder="0–100" min="0" max="100" step="0.1" required>
                            <span class="unit-label">knots</span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Wind Gust <span style="color:#555; font-weight:400;">(optional)</span></label>
                        <div class="input-row">
                            <input type="number" class="form-input" id="windGust" placeholder="0–100" min="0" max="100" step="0.1">
                            <span class="unit-label">knots</span>
                        </div>
                    </div>
                </div>

                <div class="panel" style="margin-top: 16px;">
                    <div class="section-label">Visibility</div>

                    <div class="form-group">
                        <label class="form-label">Visibility <span class="required">*</span></label>
                        <div class="input-row">
                            <input type="number" class="form-input" id="visibility" placeholder="0–10" min="0" max="10" step="0.1" required>
                            <span class="unit-label">SM</span>
                        </div>
                    </div>
                </div>

                <div class="panel" style="margin-top: 16px;">
                    <div class="section-label">Weather Conditions</div>

                    <div class="form-group">
                        <div class="checkbox-row">
                            <input type="checkbox" id="isRaining">
                            <label for="isRaining">Currently Raining</label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Additional Weather Notes <span style="color:#555; font-weight:400;">(optional)</span></label>
                        <textarea class="form-input" id="weatherNotes" placeholder="e.g. Thunderstorms, Snow, Fog…" rows="4"></textarea>
                    </div>
                </div>

                <div class="btn-group" style="margin-top: 16px;">
                    <button type="submit" class="btn btn-primary">Submit METAR Report</button>
                    <button type="button" class="btn btn-ghost" onclick="clearMetar()">Clear METAR</button>
                </div>
            </form>

            <footer>
                <p>Bringing realistic aviation simulation to VTOL VR</p>
            </footer>
        </div>
    </div>

    <!-- Virtual Keyboard Toggle -->
    <button class="vk-toggle-btn" id="vkToggleBtn" aria-label="Toggle virtual keyboard" title="Virtual Keyboard">⌨</button>

    <!-- Virtual Keyboard -->
    <div class="virtual-keyboard" id="virtualKeyboard">
        <div class="vk-row">
            <button class="vk-key" data-key="1">1</button>
            <button class="vk-key" data-key="2">2</button>
            <button class="vk-key" data-key="3">3</button>
            <button class="vk-key" data-key="4">4</button>
            <button class="vk-key" data-key="5">5</button>
            <button class="vk-key" data-key="6">6</button>
            <button class="vk-key" data-key="7">7</button>
            <button class="vk-key" data-key="8">8</button>
            <button class="vk-key" data-key="9">9</button>
            <button class="vk-key" data-key="0">0</button>
            <button class="vk-key" data-key=".">.</button>
            <button class="vk-key vk-key-wide vk-key-action" data-action="backspace">⌫</button>
        </div>
        <div class="vk-row">
            <button class="vk-key" data-key="Q">Q</button>
            <button class="vk-key" data-key="W">W</button>
            <button class="vk-key" data-key="E">E</button>
            <button class="vk-key" data-key="R">R</button>
            <button class="vk-key" data-key="T">T</button>
            <button class="vk-key" data-key="Y">Y</button>
            <button class="vk-key" data-key="U">U</button>
            <button class="vk-key" data-key="I">I</button>
            <button class="vk-key" data-key="O">O</button>
            <button class="vk-key" data-key="P">P</button>
        </div>
        <div class="vk-row">
            <button class="vk-key" data-key="A">A</button>
            <button class="vk-key" data-key="S">S</button>
            <button class="vk-key" data-key="D">D</button>
            <button class="vk-key" data-key="F">F</button>
            <button class="vk-key" data-key="G">G</button>
            <button class="vk-key" data-key="H">H</button>
            <button class="vk-key" data-key="J">J</button>
            <button class="vk-key" data-key="K">K</button>
            <button class="vk-key" data-key="L">L</button>
        </div>
        <div class="vk-row">
            <button class="vk-key" data-key="Z">Z</button>
            <button class="vk-key" data-key="X">X</button>
            <button class="vk-key" data-key="C">C</button>
            <button class="vk-key" data-key="V">V</button>
            <button class="vk-key" data-key="B">B</button>
            <button class="vk-key" data-key="N">N</button>
            <button class="vk-key" data-key="M">M</button>
            <button class="vk-key" data-key="-">-</button>
            <button class="vk-key" data-key="/">/</button>
        </div>
        <div class="vk-row">
            <button class="vk-key vk-key-space" data-key=" ">Space</button>
            <button class="vk-key vk-key-wide vk-key-action" data-action="enter">↵ Enter</button>
        </div>
    </div>

    <script src="/form-url-draft.js"></script>
    <script>
        const form = document.getElementById('metarForm');
        const successMessage = document.getElementById('successMessage');
        const errorMessage = document.getElementById('errorMessage');

        (function metarUrlDraft() {
            if (!window.FormUrlDraft) return;
            const draft = window.FormUrlDraft.bind(
                'metarDraft',
                function getState() {
                    return {
                        sessionId: document.getElementById('sessionId').value,
                        windDirection: document.getElementById('windDirection').value,
                        windSpeed: document.getElementById('windSpeed').value,
                        windGust: document.getElementById('windGust').value,
                        visibility: document.getElementById('visibility').value,
                        isRaining: document.getElementById('isRaining').checked,
                        weatherNotes: document.getElementById('weatherNotes').value
                    };
                },
                function applyState(s) {
                    if (!s || typeof s !== 'object') return;
                    const set = (id, v) => { const el = document.getElementById(id); if (el && v != null) el.value = v; };
                    set('sessionId', s.sessionId);
                    set('windDirection', s.windDirection);
                    set('windSpeed', s.windSpeed);
                    set('windGust', s.windGust);
                    set('visibility', s.visibility);
                    const rain = document.getElementById('isRaining');
                    if (rain) rain.checked = !!s.isRaining;
                    set('weatherNotes', s.weatherNotes);
                },
                form
            );
            window.__metarDraftClear = draft.clearDraft;
        })();

        form.addEventListener('submit', async function(e) {
            e.preventDefault();

            const windDirection = document.getElementById('windDirection').value;
            const windSpeed = document.getElementById('windSpeed').value;
            const visibility = document.getElementById('visibility').value;

            if (!windDirection || !windSpeed || !visibility) {
                showError('Please fill in all required fields');
                return;
            }

            if (windDirection < 0 || windDirection > 360) {
                showError('Wind direction must be between 0 and 360 degrees');
                return;
            }

            if (windSpeed < 0 || windSpeed > 100) {
                showError('Wind speed must be between 0 and 100 knots');
                return;
            }

            if (visibility < 0 || visibility > 10) {
                showError('Visibility must be between 0 and 10 SM');
                return;
            }

            const metarData = {
                windDirection: parseInt(windDirection),
                windSpeed: parseFloat(windSpeed),
                windGust: document.getElementById('windGust').value ? parseFloat(document.getElementById('windGust').value) : null,
                visibility: parseFloat(visibility),
                isRaining: document.getElementById('isRaining').checked,
                weatherNotes: document.getElementById('weatherNotes').value || null,
                timestamp: new Date().toISOString(),
                sessionId: document.getElementById('sessionId').value.trim() || null
            };

            try {
                const response = await fetch('/api/metar/submit', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(metarData)
                });

                if (!response.ok) throw new Error('Failed to submit METAR report');

                showSuccess('METAR report submitted successfully!');
                form.reset();
                if (window.__metarDraftClear) window.__metarDraftClear();
                setTimeout(() => successMessage.classList.remove('show'), 3000);
            } catch (error) {
                showError('Error submitting METAR report: ' + error.message);
            }
        });

        function clearMetar() {
            fetch('/api/metar/clear', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ sessionId: document.getElementById('sessionId').value.trim() || null })
            })
            .then(response => {
                if (!response.ok) throw new Error('Failed to clear METAR data');
                return response.json();
            })
            .then(() => {
                showSuccess('Current METAR data cleared successfully!');
                form.reset();
                if (window.__metarDraftClear) window.__metarDraftClear();
            })
            .catch(error => {
                showError('Error clearing METAR data: ' + error.message);
            });
            form.reset();
        }

        function showSuccess(message) {
            successMessage.textContent = message;
            successMessage.classList.add('show');
            errorMessage.classList.remove('show');
        }

        function showError(message) {
            errorMessage.textContent = message;
            errorMessage.classList.add('show');
            successMessage.classList.remove('show');
        }

        // Virtual Keyboard
        const virtualKeyboard = document.getElementById('virtualKeyboard');
        const vkToggleBtn = document.getElementById('vkToggleBtn');
        let lastFocusedInput = null;

        document.addEventListener('focusin', function(e) {
            if (e.target.matches('input, textarea') && !e.target.closest('.virtual-keyboard')) {
                lastFocusedInput = e.target;
            }
        });

        function toggleVirtualKeyboard() {
            const isOpen = virtualKeyboard.classList.toggle('active');
            vkToggleBtn.classList.toggle('kb-open', isOpen);
            vkToggleBtn.title = isOpen ? 'Close Virtual Keyboard' : 'Virtual Keyboard';
            if (isOpen) {
                requestAnimationFrame(() => {
                    document.documentElement.style.setProperty('--kb-height', virtualKeyboard.offsetHeight + 'px');
                });
            }
        }

        vkToggleBtn.addEventListener('click', toggleVirtualKeyboard);

        function insertAtCursor(input, text) {
            const start = input.selectionStart != null ? input.selectionStart : input.value.length;
            const end   = input.selectionEnd   != null ? input.selectionEnd   : input.value.length;
            input.value = input.value.substring(0, start) + text + input.value.substring(end);
            input.selectionStart = input.selectionEnd = start + text.length;
            input.dispatchEvent(new Event('input', { bubbles: true }));
        }

        function deleteAtCursor(input) {
            const start = input.selectionStart != null ? input.selectionStart : input.value.length;
            const end   = input.selectionEnd   != null ? input.selectionEnd   : input.value.length;
            if (start !== end) {
                input.value = input.value.substring(0, start) + input.value.substring(end);
                input.selectionStart = input.selectionEnd = start;
            } else if (start > 0) {
                input.value = input.value.substring(0, start - 1) + input.value.substring(end);
                input.selectionStart = input.selectionEnd = start - 1;
            }
            input.dispatchEvent(new Event('input', { bubbles: true }));
        }

        virtualKeyboard.addEventListener('mousedown', function(e) { e.preventDefault(); });

        virtualKeyboard.addEventListener('click', function(e) {
            const key = e.target.closest('.vk-key');
            if (!key) return;
            const target = lastFocusedInput || document.getElementById('sessionId');
            target.focus();
            if (key.dataset.key !== undefined) {
                insertAtCursor(target, key.dataset.key);
            } else if (key.dataset.action === 'backspace') {
                deleteAtCursor(target);
            } else if (key.dataset.action === 'enter') {
                target.dispatchEvent(new KeyboardEvent('keypress', { key: 'Enter', bubbles: true }));
            }
        });
    </script>
</body>
</html>
