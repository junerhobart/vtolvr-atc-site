<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Browse active VTOL VR lobbies and filter by lobby type.">
    <title>VTOL VR Sessions</title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <style>
        .page-wrap {
            max-width: 1200px;
            margin: 0 auto;
            padding: 60px 20px;
            width: 100%;
        }

        .hero {
            margin-bottom: 32px;
            text-align: center;
            padding-top: 20px;
        }

        .hero h1 {
            font-size: 2.5em;
            font-weight: 700;
            margin-bottom: 10px;
            color: #e0e0e0;
        }

        .hero p {
            color: #e0e0e0;
            font-size: 1.1em;
            opacity: 0.9;
            max-width: 600px;
            margin: 0 auto;
        }

        .sessions-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 16px;
        }

        /* lobby-tile: class name avoids theme.css .session-card transparent override */
        .lobby-tile {
            background: #222222 !important;
            border-radius: 6px;
            padding: 20px;
        }

        .lobby-tile h3 {
            margin: 0 0 10px;
            color: #f5f3ef;
            font-size: 1.05em;
            font-weight: 600;
        }

        .lobby-tile p {
            color: rgba(245,243,239,0.6);
            font-size: 0.875rem;
            margin-bottom: 6px;
        }

        .badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.72rem;
            font-weight: 700;
            margin-right: 6px;
            margin-top: 4px;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .badge.public  { background: rgba(76,175,80,0.15);  color: #73d87a; }
        .badge.private { background: rgba(244,67,54,0.15);  color: #ff8d85; }
        .badge.modded  { background: rgba(255,193,7,0.15);  color: #ffd75e; }

        .loading,
        .empty-state {
            text-align: center;
            padding: 32px 20px;
            background: #232323;
            border-radius: 10px;
            border: 1px solid rgba(255,255,255,0.07);
            color: rgba(245,243,239,0.5);
        }

        .list-status {
            text-align: center;
            font-size: 0.875rem;
            color: rgba(245,243,239,0.5);
            padding: 20px 16px;
            margin: 0 auto;
            max-width: 28rem;
        }

        .list-status--error {
            color: #ffb0b0;
        }

        .content-wrap {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .page-wrap {
            flex: 1;
        }

        footer {
            text-align: center;
            padding: 24px 20px;
        }

        footer p {
            color: rgba(245,243,239,0.3);
            font-size: 0.8rem;
        }

        @media (max-width: 768px) {
            .nav-links { display: none; }
            .page-wrap { padding: 40px 16px; }
            .hero h1 { font-size: 1.8em; margin-bottom: 5px; }
        }
        <%- include('partials/top-nav-theme') %>
    </style>
</head>
<body>
    <%- include('partials/sidebar', { page: 'sessions' }) %>

    <div class="main-content content-wrap">
    <main class="page-wrap">
        <section class="hero">
            <h1>VTOL VR Live Lobbies</h1>
            <p>Track active servers in real-time and quickly find the right session for your next sortie.</p>
        </section>

        <section class="filters toolbar-inline" aria-label="Session filters">
            <div class="filter-toolbar">
                <%- include('partials/filter-popover', {
                    triggerLabel: 'Filters',
                    items: [
                        { id: 'publicFilter', label: 'Public', checked: true },
                        { id: 'privateFilter', label: 'Private', checked: true },
                        { id: 'moddedFilter', label: 'Modded', checked: true }
                    ]
                }) %>
                <button type="button" class="filter-toolbar__action" onclick="loadSessions()">Reload Sessions</button>
            </div>
        </section>

        <div id="loading" class="loading" style="display: none;">Loading sessions…</div>
        <div id="sessions" class="sessions-container"></div>
    </main>

    <footer>
        <%#  <p>&copy; 2026 Aviation Realism Network. All rights reserved.</p> %>
        <p>Bringing realistic aviation simulation to VTOL VR</p>
    </footer>
    </div>

    <script>
        let cachedSessions = [];
        let fetchFailed = false;
        async function fetchSessions() {
            fetchFailed = false;
            try {
                const response = await fetch('/api/sessions', {
                    method: 'GET',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'same-origin'
                });
                if (!response.ok) throw new Error('Failed to fetch sessions');
                cachedSessions = await response.json();
            } catch (err) {
                fetchFailed = true;
            }
        }

        function displaySessions() {
            const sessionsDiv = document.getElementById('sessions');
            if (fetchFailed) {
                sessionsDiv.innerHTML = '<p class="list-status list-status--error">Unable to load sessions right now.</p>';
                return;
            }

            sessionsDiv.innerHTML = '';

            const publicFilter = document.getElementById('publicFilter').checked;
            const privateFilter = document.getElementById('privateFilter').checked;
            const moddedFilter = document.getElementById('moddedFilter').checked;

            const sessions = cachedSessions.filter(session => {
                if (session.IsPrivate && !privateFilter) return false;
                if (!session.IsPrivate && !publicFilter) return false;
                if (session.IsModded && !moddedFilter) return false;
                return true;
            });

            if (sessions.length === 0) {
                sessionsDiv.innerHTML = '<div class="empty-state">No sessions found matching filters.</div>';
                return;
            }

            sessions.forEach(session => {
                const card = document.createElement('div');
                card.className = 'lobby-tile';
                card.innerHTML = `
                    <h3>${session.LobbyName || 'Unknown'} (${session.LobbyId || 'N/A'})</h3>
                    ${session.LobbyOwner ? `<p><strong>Host:</strong> ${session.LobbyOwner}</p>` : ''}
                    ${session.IsPrivate ? '<span class="badge private">Private</span>' : '<span class="badge public">Public</span>'}
                    ${session.IsModded ? '<span class="badge modded">Modded</span>' : ''}
                    <p><strong>Players:</strong> ${session.LobbyPlayerCount || 0}</p>
                    <p><strong>Map:</strong> ${session.LobbyMap || 'N/A'}</p>
                `;
                sessionsDiv.appendChild(card);
            });
        }

        async function loadSessions() {
            const loading = document.getElementById('loading');
            loading.style.display = 'block';
            await fetchSessions();
            displaySessions();
            loading.style.display = 'none';
        }

        loadSessions();

        setInterval(async () => {
            await fetchSessions();
            displaySessions();
        }, 60000);

        document.getElementById('publicFilter').addEventListener('change', displaySessions);
        document.getElementById('privateFilter').addEventListener('change', displaySessions);
        document.getElementById('moddedFilter').addEventListener('change', displaySessions);
    </script>
</body>
</html>