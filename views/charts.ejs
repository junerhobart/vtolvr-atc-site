<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="author" content="Caleb Thomas (TheRavenSeb)">
    <meta name="description" content="Flight Charts - View and select various airport charts.">
    <meta name="keywords" content="Flight Charts, Airport Charts, Aviation, Flight Planning, Navigation Charts,Vtol vr">
    <title>Map Charts</title>
    <script>
        document.addEventListener('DOMContentLoaded', async() => {
            if (window.OpenKneeboard) {
                document.body.classList.add("OpenKneeboard");
                await OpenKneeboard.EnableExperimentalFeature(
                    'GraphicsTabletInfo',
                    2025012901);
                var info = await OpenKneeboard.GetGraphicsTabletInfo();
                if (info && info.SuggestedPixelSize) {
                await OpenKneeboard.SetPreferredPixelSize(
                info.SuggestedPixelSize.Width,
                info.SuggestedPixelSize.Height)}
                else{
                    // set to 600x1300 if no suggested size is provided
                    await OpenKneeboard.SetPreferredPixelSize(600, 1300);
                }
            }
            


            
        });
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.4.0/p5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/gh/IDMNYU/p5.js-speech@0.0.3/lib/p5.speech.js"></script>
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1e1e2e 0%, #2d2d44 100%);
            color: #e0e0e0;
            min-height: 100vh;
            display: flex;
            flex-direction: row;
            padding: 0;
            margin: 0;
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            overflow-y: auto;
        }

        .sidebar {
            width: 280px;
            background: rgba(30, 30, 46, 0.8);
            border-right: 1px solid rgba(102, 126, 234, 0.3);
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 25px;
            overflow-y: auto;
            backdrop-filter: blur(10px);
        }

        .sidebar-logo {
            width: 120px;
            height: 120px;
            background-color: #e0e0e0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
            color: #2a2a2a;
        }

        .sidebar-title {
            text-align: center;
            color: #e0e0e0;
            font-size: 1.3em;
            font-weight: bold;
            line-height: 1.3;
        }

        .sidebar-title a {
            color: #e0e0e0;
            text-decoration: none;
        }

        .sidebar-title a:hover {
            color: #667eea;
        }

        .sidebar-menu {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .sidebar-menu-item {
            padding: 12px 16px;
            color: #b0b0b0;
            text-decoration: none;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
            text-align: left;
            font-size: 0.95em;
        }

        .sidebar-menu-item:hover {
            background: rgba(102, 126, 234, 0.2);
            color: #e0e0e0;
        }

        .sidebar-menu-item.active {
            background-color: #667eea;
            color: #ffffff;
        }

        .sidebar-charts {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .sidebar-charts h3 {
            color: #e0e0e0;
            font-size: 0.95em;
            margin: 0;
            text-transform: uppercase;
            opacity: 0.7;
        }

        .sidebar-chart-btn {
            padding: 10px 12px;
            background: rgba(51, 51, 51, 0.5);
            color: #b0b0b0;
            border: 1px solid rgba(102, 126, 234, 0.2);
            border-radius: 6px;
            cursor: pointer;
            text-align: left;
            font-size: 0.9em;
            transition: all 0.2s;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .sidebar-chart-btn:hover {
            background: rgba(102, 126, 234, 0.2);
            color: #e0e0e0;
            border-color: #667eea;
        }

        .sidebar-chart-btn.active {
            background-color: #667eea;
            color: #ffffff;
            border-color: #667eea;
        }

        header {
            text-align: center;
            color: #e0e0e0;
            margin-bottom: 40px;
            padding-top: 20px;
        }

        header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
        }

        header p {
            font-size: 1.1em;
            opacity: 0.9;
        }

        .container {
            display: flex;
            gap: 30px;
            max-width: 1200px;
            width: 100%;
            max-height: 100%;
            flex-wrap: nowrap;
            justify-content: center;
        }

        .combined-panel {
            background: rgba(51, 51, 51, 0.5);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(102, 126, 234, 0.2);
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            display: flex;
            flex-direction: column;
            gap: 20px;
            flex: 1;
            min-width: 600px;
            max-width: 1200px;
            min-height: auto;
            max-height: 100%;
            width: 100%;
        }

        .selector-panel {
            display: flex;
            flex-direction: column;
            gap: 12px;
            width: 100%;
        }

        .selector-panel h2 {
            color: #e0e0e0;
            font-size: 1.3em;
            margin: 0;
        }

        .chart-list {
            width: 100%;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .chart-buttons-container {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            width: 100%;
        }

        .chart-btn {
            padding: 12px 16px;
            border: 2px solid #667eea;
            background: transparent;
            color: #667eea;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1em;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .chart-btn:hover {
            border-color: #667eea;
            background: #667eea;
            color: white;
            transform: translateY(-2px);
        }

        .chart-btn.active {
            background: #667eea;
            border-color: #667eea;
            color: #fff;
        }

        .chart-btn:focus {
            outline: none;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        }

        .display-panel {
            display: flex;
            flex-direction: column;
            gap: 20px;
            flex: 1;
            max-height: max-content;
        }

        .display-panel h2 {
            color: #e0e0e0  ;
            font-size: 1.3em;
            margin: 0;
        }

        .chart-display {
            width: 100%;
            height: 800px;
            background: rgba(51, 51, 51, 0.5);
            border: 1px solid rgba(102, 126, 234, 0.2);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: auto;
        }

        .chart-display img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
            border-radius: 6px;
        }

        .placeholder {
            color: #999;
            font-size: 1.1em;
            text-align: center;
        }

        footer {
            color: white;
            margin-top: 40px;
            text-align: center;
            opacity: 0.8;
        }

        @media (max-width: 768px) {
            .container {
                flex-direction: column;
                align-items: center;
            }

            .display-panel {
                min-width: 100%;
                max-width: 100%;
                max-height: 100%;
            }

            header h1 {
                font-size: 1.8em;
            }
        }
        @media (max-width: 480px) {
            .chart-btn {
                font-size: 0.9em;
                padding: 10px 14px;
            }
        }

        @media (max-hight: 600px) {
            .chart-display {
                height: 300px;
            }


        }

        .open-window-btn {
            background-color: #4CAF50; /* Green */
            border: none;
            color: white;
            padding: 10px 24px;
            text-align: center;
            text-decoration: none;
            display: inline-block;
            font-size: 16px;
            margin: 4px 2px;
            cursor: pointer;
            border-radius: 12px;
        }

        .DiscordButton {
            background-color: #7289DA; /* Discord Blue */
            border: none;
            color: white;
            padding: 10px 24px;
            text-align: center;
            text-decoration: none;
            display: inline-block;
            font-size: 16px;
            margin: 4px 2px;
            cursor: pointer;
            border-radius: 12px;
        }

        .sidebar-login-btn {
            width: 100%;
            padding: 12px 16px;
            background-color: #667eea;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.95em;
            margin-top: auto;
            transition: all 0.2s;
        }

        .sidebar-login-btn:hover {
            background-color: #5569d8;
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-logo"><img src="/assets/logo.png" alt="Logo"></div>
        <div class="sidebar-title"><a href="/">Aviation Realism<br>Network</a></div>
        <div class="sidebar-menu">
            <a class="sidebar-menu-item active" href="/profile">Profile</a>
            <a class="sidebar-menu-item" href="/announcements">Announcements</a>
            <a class="sidebar-menu-item" href="/pilots">Pilots</a>
            <a class="sidebar-menu-item" href="/applications">Applications</a>
            <a class="sidebar-menu-item" href="/information">Information</a>
        </div>
        <div class="sidebar-charts">
            
            <h3>Available Charts</h3>
            <div class="sidebar-chart-buttons-container">
                <!-- Chart buttons will be dynamically added here -->
            </div>
        </div>
        <a href="/logout" class="sidebar-login-btn">Logout</a>
    </div>

    <div class="main-content">
        <select id="chartList" class="chart-list" style="display:none;">
            <option value="">Select a chart</option>
        </select>
        <header>
            <h1>Raven's Airport Charts</h1>
            <p>Select a chart from the list to view it below. You can also use voice commands by saying "Select chart [chart name]".</p>
            <div class="metar-input-container">
                <label for="sessionIdInput">Session ID for METAR:</label>
                <input type="text" id="sessionIdInput" class="session-id-input" placeholder="Enter session ID">
                <button id="fetchMetarBtn" class="fetch-metar-btn">Fetch METAR</button>
            </div>
        </header>

        <div class="container">
        <div class="display-panel">
            <h2>Chart Display</h2>
            <div class="chart-display" id="chartDisplay">
                <div class="placeholder">Select a chart to display</div>
            </div>
        </div>
    </div>

        <footer>
            <p>&copy; 2026 Flight Charts. All rights reserved.</p>
        </footer>
    </div>

    <script>
        const chartDisplay = document.getElementById('chartDisplay');
        let charts = [];
        
        function openSizedWindow() {
        // Opens a new window with specified dimensions
       
        window.open('/charts', 'ChartsWindow', 'width=600,height=1300');
        }

        // Fetch available chart images from assets folder
        async function loadCharts() {
            try {
                // Common chart image extensions
                const imageExtensions = ['.png'];
                const assetPath = '/assets/'; // Update with your actual asset path

                
                const chartNames = [
                    "Shark",
                    "Military",
                    "Luna",
                    "Island Air base",
                    "Manchester Airport(KMHT)",
                    "SKYHAVEN(KDAW)",
                    "KMRD Meridia"
                ];

                // Try to load each chart image
                for (const name of chartNames) {
                    for (const ext of imageExtensions) {
                        const img = new Image();
                        const src = assetPath + name + ext;

                        img.onload = function() {
                            if (!charts.find(c => c.name === name)) {
                                charts.push({
                                    name: name.replace(/-/g, ' ').toUpperCase(),
                                    src: src
                                });
                                renderChartList();
                            }
                        };

                        img.onerror = function() {
                            console.log('Failed to load: ' + src);
                        };

                        img.src = src;
                    }
                }

                // Fallback: If no images found, show placeholder
                setTimeout(() => {
                    if (charts.length === 0) {
                        document.querySelector('.sidebar-chart-buttons-container').innerHTML = '<p style="color: #999;">No charts found in assets folder</p>';
                    }
                }, 2000);

            } catch (error) {
                console.error('Error loading charts:', error);
                document.querySelector('.sidebar-chart-buttons-container').innerHTML = '<p style="color: #999;">Error loading charts</p>';
            }
        }

        function renderChartList() {
            
            const container = document.querySelector('.sidebar-chart-buttons-container');
            if (container) {
                while (container.children.length > 0) {
                    container.removeChild(container.lastChild);
                }
            }

            // Add chart buttons to sidebar
            charts.forEach((chart, index) => {
                const button = document.createElement('button');
                button.className = 'sidebar-chart-btn';
                button.textContent = chart.name;
                button.dataset.index = index;
                button.addEventListener('click', () => {
                    selectChart(chart);
                    // Update active state
                    document.querySelectorAll('.sidebar-chart-btn').forEach(btn => btn.classList.remove('active'));
                    button.classList.add('active');
                });
                container.appendChild(button);
            });
        }

        function selectChart(chart) {
            // Display the chart image

            chartDisplay.innerHTML = `<img src="${chart.src}" alt="${chart.name}" height="750px">`;
        }
        
        // Handle dropdown change
        chartList.addEventListener('change', function() {
            if (this.value !== '') {
                const chart = charts[this.value];
                selectChart(chart);
            }
        });


        // allow for speech to change charts
        var speech = new p5.SpeechRec();
        var speak = new p5.Speech(); // speech synthesis object
        speech.onResult = showResult;
        speech.start(true, false); // continuous, interimResults
        
        

        function showResult() {
            if (speech.resultValue) {
                const spokenText = speech.resultString.toLowerCase();
                console.log('Heard: ' + spokenText);
                if (spokenText.includes('select chart')) {
                    var chartName = spokenText.replace('select chart', '').trim();
                    
                
                charts.forEach((chart, index) => {
                    if (chartName.includes(chart.name.toLowerCase())) {
                        speak.speak('Loading ' + chart.name + ' chart');
                        chartList.value = index;
                        selectChart(chart);
                    }
                });
            }
            }
        }


       
        // Initialize
        loadCharts();

        // METAR Data Fetching
        const sessionIdInput = document.getElementById('sessionIdInput');
        const fetchMetarBtn = document.getElementById('fetchMetarBtn');
        let metarIntervalId = null;
        let currentSessionId = null;

        // Function to fetch METAR data
        async function fetchMetarData(sessionId) {
            try {
                const response = await fetch(`/api/metar/${sessionId}`);
                if (response.ok) {
                    const data = await response.json();
                    console.log('METAR Data:', data);
                    // You can display this data on the page as needed
                    displayMetarData(data.data);
                } else {
                    console.error('METAR not found for session:', sessionId);
                }
            } catch (error) {
                console.error('Error fetching METAR data:', error);
            }
        }

        // Function to display METAR data
        function displayMetarData(metarData) {
            // Create or update METAR display container
            let metarDisplay = document.getElementById('metarDisplay');
            if (!metarDisplay) {
                metarDisplay = document.createElement('div');
                metarDisplay.id = 'metarDisplay';
                metarDisplay.style.cssText = 'border: 1px solid #ddd; padding: 15px; margin-top: 20px; background-color: #f9f9f9; border-radius: 6px; font-family: monospace;';
                document.querySelector('.container').appendChild(metarDisplay);
            }
            
            // Format METAR data in FAA format
            let faaMetar = '';
            
            // Station identifier (if available)
            if (metarData.stationId) {
                faaMetar += metarData.stationId + ' ';
            }
           
            // Date-time group (DDHHmm)
            const now = new Date(metarData.timestamp || new Date());
            const day = String(now.getUTCDate()).padStart(2, '0');
            const hour = String(now.getUTCHours()).padStart(2, '0');
            const minute = String(now.getUTCMinutes()).padStart(2, '0');
            faaMetar += day + hour + minute + 'Z ';
            
            // Wind group (dddssGggKT)
            if (metarData.windDirection !== null && metarData.windSpeed !== null) {
                const windDir = String(parseInt(metarData.windDirection)).padStart(3, '0');
                const windSpd = String(parseInt(metarData.windSpeed)).padStart(2, '0');
                faaMetar += windDir + windSpd;
                if (metarData.windGust) {
                    const gust = String(parseInt(metarData.windGust)).padStart(2, '0');
                    faaMetar += 'G' + gust;
                }
                faaMetar += 'KT ';
            }
            
            // Visibility (NNNSM format)
            if (metarData.visibility !== null) {
                const vis = parseFloat(metarData.visibility).toFixed(1);
                faaMetar += vis + 'SM ';
            }
            
            // Weather phenomena
            if (metarData.isRaining) {
                if (metarData.weatherNotes && metarData.weatherNotes.includes('heavy')) {
                    faaMetar += '+RA ';
                } else if (metarData.weatherNotes && metarData.weatherNotes.includes('light')) {
                    faaMetar += '-RA ';
                }
            } else if (metarData.weatherNotes) {
                faaMetar += metarData.weatherNotes + ' ';
            }
            
            // Format for display - truncate after AO2
            let metarText = faaMetar.trim();
            
            metarDisplay.innerHTML = `
                <h3>METAR Information</h3>
                <p style="font-size: 1.2em; margin: 10px 0; padding: 10px; background-color: #000000; border-left: 4px solid #0066cc;">${metarText}</p>
                <p style="font-size: 0.9em; color: #333; margin-top: 10px; background-color: #d0e8f0; padding: 8px; border-radius: 4px;">
                    <strong>Raw Data:</strong><br>
                    Wind: ${metarData.windDirection}° @ ${metarData.windSpeed}kt${metarData.windGust ? ' G' + metarData.windGust : '' } <br>
                    Visibility: ${metarData.visibility}SM<br>
                    Conditions: ${metarData.weatherNotes || 'Clear'}<br>
                    Updated: ${now.toLocaleString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' })}
                </p>
            `;
        }

        // Event listener for fetch button
        fetchMetarBtn.addEventListener('click', function() {
            const sessionId = sessionIdInput.value.trim();
            if (!sessionId) {
                alert('Please enter a Session ID');
                return;
            }

            currentSessionId = sessionId;
            
            // Fetch immediately
            fetchMetarData(sessionId);

            // Clear any existing interval
            if (metarIntervalId) {
                clearInterval(metarIntervalId);
            }

            // Set up interval to fetch every minute (60000 ms)
            metarIntervalId = setInterval(() => {
                fetchMetarData(sessionId);
            }, 60000);

            console.log('METAR auto-fetch started for session:', sessionId);
        });

        // Optional: Allow Enter key to trigger fetch
        sessionIdInput.addEventListener('keypress', function(event) {
            if (event.key === 'Enter') {
                fetchMetarBtn.click();
            }
        });

        
    </script>
    
</body>
</html>