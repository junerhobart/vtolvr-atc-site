<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="author" content="Caleb Thomas (TheRavenSeb)">
    <meta name="description" content="Flight Charts - View and select various airport charts.">
    <meta name="keywords" content="Flight Charts, Airport Charts, Aviation, Flight Planning, Navigation Charts,Vtol vr">
    <title>Map Charts</title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <script>
        document.addEventListener('DOMContentLoaded', async() => {
            if (window.OpenKneeboard) {
                document.body.classList.add("OpenKneeboard");
                await OpenKneeboard.EnableExperimentalFeature(
                    'GraphicsTabletInfo',
                    2025012901);
                var info = await OpenKneeboard.GetGraphicsTabletInfo();
                if (info && info.SuggestedPixelSize) {
                await OpenKneeboard.SetPreferredPixelSize(
                info.SuggestedPixelSize.Width,
                info.SuggestedPixelSize.Height)}
                else{
                    // set to 600x1300 if no suggested size is provided
                    await OpenKneeboard.SetPreferredPixelSize(600, 1300);
                }
            }
            


            
        });
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.4.0/p5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/gh/IDMNYU/p5.js-speech@0.0.3/lib/p5.speech.js"></script>
    
    <style>
        .main-content {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .page-wrap {
            flex: 1;
            max-width: 1200px;
            margin: 0 auto;
            padding: 48px 24px;
            width: 100%;
        }

        .hero {
            margin-bottom: 32px;
            text-align: center;
            padding-top: 20px;
        }

        .hero h1 {
            font-size: 2.5em;
            font-weight: 700;
            color: #f5f3ef;
            margin-bottom: 10px;
        }

        .hero p {
            color: rgba(245,243,239,0.7);
            font-size: 1.1em;
            max-width: 600px;
            margin: 0 auto;
        }

        .chart-area {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .chart-display {
            width: 100%;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            overflow: auto;
        }

        .chart-display img {
            max-width: 100%;
            object-fit: contain;
            border-radius: 6px;
        }

        .placeholder {
            color: rgba(245,243,239,0.35);
            font-size: 0.95rem;
            text-align: center;
            padding: 40px 0;
        }

        .chart-area .search-container {
            width: 100%;
            margin-bottom: 8px;
        }

        .metar-display {
            padding: 16px 18px;
            width: 100%;
            font-family: "JetBrains Mono", "Fira Mono", "Courier New", monospace;
        }

        .metar-label {
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            margin-bottom: 8px;
            font-family: "Inter", sans-serif;
        }

        .metar-code {
            font-size: 1.05rem;
            font-weight: 500;
            letter-spacing: 0.04em;
            margin-bottom: 12px;
            word-break: break-all;
        }

        .metar-raw {
            display: flex;
            flex-wrap: wrap;
            gap: 6px 20px;
            font-size: 0.8rem;
            font-family: "Inter", sans-serif;
        }

        footer {
            text-align: center;
            padding: 24px 20px;
            font-size: 0.8rem;
            color: rgba(245,243,239,0.3);
        }

        /* Virtual Keyboard */
        .vk-toggle-btn {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1001;
            border-radius: 50%;
            width: 52px;
            height: 52px;
            font-size: 1.4em;
            transition: bottom 0.25s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .vk-toggle-btn.kb-open {
            bottom: calc(var(--kb-height, 240px) + 14px);
        }

        .virtual-keyboard {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background: rgba(26, 26, 26, 0.97);
            border-top: 1px solid rgba(255,255,255,0.08);
            padding: 10px 8px 16px;
            z-index: 1000;
            transform: translateY(100%);
            transition: transform 0.25s ease;
            display: flex;
            flex-direction: column;
            gap: 5px;
            align-items: center;
        }

        .virtual-keyboard.active { transform: translateY(0); }

        .vk-row {
            display: flex;
            gap: 4px;
            justify-content: center;
            width: 100%;
            max-width: 860px;
        }

        .vk-key {
            background: rgba(50, 50, 50, 0.9);
            color: #e0e0e0;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 6px;
            height: 38px;
            flex: 1;
            min-width: 0;
            font-size: 0.82em;
            cursor: pointer;
            user-select: none;
            -webkit-user-select: none;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 2px;
        }

        .vk-key-wide   { flex: 1.6; }
        .vk-key-space  { flex: 5; }
        .vk-key-action { background: rgba(70, 70, 70, 0.9); }

        @media (max-width: 768px) {
            .page-wrap { padding: 32px 16px; }
            .hero h1 { font-size: 1.8em; }
        }

        <%- include('partials/fixed-sidebar-theme') %>

        .chart-area .chart-display {
            position: relative;
            z-index: 0;
        }

        .search-toolbar-row {
            position: relative;
            z-index: 10;
        }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { page: 'charts' }) %>

    <div class="main-content">
        <div class="page-wrap">
            <div class="hero">
                <h1>Raven's Airport Charts</h1>
                <p>Select a chart, enter a METAR session ID, then fetch. Voice: &quot;Select chart [name]&quot; (Chrome).</p>
            </div>

            <div class="chart-area">
                <div class="search-container">
                    <div class="search-toolbar-row">
                        <section class="filters filters--in-search" aria-label="Chart selection">
                            <div class="filter-toolbar">
                                <div class="sidebar-chart-picker charts-inline-chart-picker">
                                    <button
                                        type="button"
                                        id="sidebarChartDropdownToggle"
                                        class="sidebar-chart-dropdown-toggle"
                                        aria-expanded="false"
                                        aria-controls="sidebarChartList"
                                        aria-label="Select chart"
                                    >
                                        Select a chart...
                                    </button>
                                    <ul id="sidebarChartList" class="sidebar-chart-list" role="listbox" aria-label="Chart list">
                                        <li class="sidebar-chart-empty">Loading charts...</li>
                                    </ul>
                                </div>
                            </div>
                        </section>
                        <div class="search-box">
                            <input
                                type="text"
                                id="sessionIdInput"
                                placeholder="METAR session ID"
                                autocomplete="off"
                                aria-label="METAR session ID"
                            >
                            <button type="button" id="fetchMetarBtn">Fetch METAR</button>
                        </div>
                    </div>
                </div>

                <div class="chart-display" id="chartDisplay">
                    <div class="placeholder">Choose a chart from the dropdown above.</div>
                </div>

                <div id="metarDisplay" class="metar-display" style="display:none"></div>
            </div>
        </div>

        <footer>
            <p>Bringing realistic aviation simulation to VTOL VR</p>
        </footer>
    </div>

    <!-- Virtual Keyboard Toggle Button -->
    <button class="vk-toggle-btn" id="vkToggleBtn" aria-label="Toggle virtual keyboard" title="Virtual Keyboard">⌨</button>

    <!-- Virtual Keyboard -->
    <div class="virtual-keyboard" id="virtualKeyboard">
        <div class="vk-row">
            <button class="vk-key" data-key="1">1</button>
            <button class="vk-key" data-key="2">2</button>
            <button class="vk-key" data-key="3">3</button>
            <button class="vk-key" data-key="4">4</button>
            <button class="vk-key" data-key="5">5</button>
            <button class="vk-key" data-key="6">6</button>
            <button class="vk-key" data-key="7">7</button>
            <button class="vk-key" data-key="8">8</button>
            <button class="vk-key" data-key="9">9</button>
            <button class="vk-key" data-key="0">0</button>
            <button class="vk-key vk-key-wide vk-key-action" data-action="backspace">⌫</button>
        </div>
        <div class="vk-row">
            <button class="vk-key" data-key="Q">Q</button>
            <button class="vk-key" data-key="W">W</button>
            <button class="vk-key" data-key="E">E</button>
            <button class="vk-key" data-key="R">R</button>
            <button class="vk-key" data-key="T">T</button>
            <button class="vk-key" data-key="Y">Y</button>
            <button class="vk-key" data-key="U">U</button>
            <button class="vk-key" data-key="I">I</button>
            <button class="vk-key" data-key="O">O</button>
            <button class="vk-key" data-key="P">P</button>
        </div>
        <div class="vk-row">
            <button class="vk-key" data-key="A">A</button>
            <button class="vk-key" data-key="S">S</button>
            <button class="vk-key" data-key="D">D</button>
            <button class="vk-key" data-key="F">F</button>
            <button class="vk-key" data-key="G">G</button>
            <button class="vk-key" data-key="H">H</button>
            <button class="vk-key" data-key="J">J</button>
            <button class="vk-key" data-key="K">K</button>
            <button class="vk-key" data-key="L">L</button>
        </div>
        <div class="vk-row">
            <button class="vk-key" data-key="Z">Z</button>
            <button class="vk-key" data-key="X">X</button>
            <button class="vk-key" data-key="C">C</button>
            <button class="vk-key" data-key="V">V</button>
            <button class="vk-key" data-key="B">B</button>
            <button class="vk-key" data-key="N">N</button>
            <button class="vk-key" data-key="M">M</button>
            <button class="vk-key" data-key="-">-</button>
            <button class="vk-key" data-key=".">.</button>
            <button class="vk-key" data-key="/">/</button>
        </div>
        <div class="vk-row">
            <button class="vk-key vk-key-space" data-key=" ">Space</button>
            <button class="vk-key vk-key-wide vk-key-action" data-action="enter">↵ Enter</button>
        </div>
    </div>

    <script>
        const chartDisplay = document.getElementById('chartDisplay');
        const sidebarChartPicker = document.querySelector('.sidebar-chart-picker');
        const sidebarChartToggle = document.getElementById('sidebarChartDropdownToggle');
        const sidebarChartList = document.getElementById('sidebarChartList');
        let charts = [];
        let selectedChartIndex = null;
        
        function openSizedWindow() {
        // Opens a new window with specified dimensions
       
        window.open('/charts', 'ChartsWindow', 'width=600,height=1300');
        }

        // Fetch available chart images from assets folder
        async function loadCharts() {
            try {
                // Common chart image extensions
                const imageExtensions = ['.png'];
                const assetPath = '/assets/'; // Update with your actual asset path

                
                const chartNames = [
                    "Shark",
                    "Military",
                    "Luna",
                    "Island Air base",
                    "Manchester Airport(KMHT)",
                    "SKYHAVEN(KDAW)",
                    "KMRD Meridia",
                    "New York City(KJFK)",
                    "Washington state(KSEA)",
                    "Michigan"
                ];

                // Try to load each chart image
                for (const name of chartNames) {
                    for (const ext of imageExtensions) {
                        const img = new Image();
                        const src = assetPath + name + ext;

                        img.onload = function() {
                            if (!charts.find(c => c.name === name)) {
                                charts.push({
                                    name: name.replace(/-/g, ' ').toUpperCase(),
                                    src: src
                                });
                                renderChartList();
                            }
                        };

                        img.onerror = function() {};

                        img.src = src;
                    }
                }

                setTimeout(() => {
                    if (charts.length === 0) {
                        if (sidebarChartList) {
                            sidebarChartList.innerHTML = '<li class="sidebar-chart-empty">No charts found</li>';
                        }
                    }
                }, 2000);

            } catch (error) {
                if (sidebarChartList) {
                    sidebarChartList.innerHTML = '<li class="sidebar-chart-empty">Error loading charts</li>';
                }
            }
        }

        function setChartDropdownLabel(label) {
            if (!sidebarChartToggle) return;
            sidebarChartToggle.textContent = label;
        }

        function setActiveChartInList(index) {
            if (!sidebarChartList) return;
            const items = sidebarChartList.querySelectorAll('.sidebar-chart-item');
            items.forEach((item) => {
                const isActive = parseInt(item.dataset.index, 10) === index;
                item.classList.toggle('active', isActive);
                item.setAttribute('aria-selected', isActive ? 'true' : 'false');
            });
        }

        function selectChartByIndex(index) {
            const chart = charts[index];
            if (!chart) return;
            selectedChartIndex = index;
            setChartDropdownLabel(chart.name);
            setActiveChartInList(index);
            selectChart(chart);
        }

        function renderChartList() {
            if (!sidebarChartList) return;
            sidebarChartList.innerHTML = '';

            charts.forEach((chart, index) => {
                const li = document.createElement('li');
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'sidebar-chart-item';
                btn.dataset.index = index;
                btn.setAttribute('role', 'option');
                btn.setAttribute('aria-selected', 'false');
                btn.textContent = chart.name;
                li.appendChild(btn);
                sidebarChartList.appendChild(li);
            });

            if (selectedChartIndex !== null) {
                setActiveChartInList(selectedChartIndex);
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            if (sidebarChartToggle && sidebarChartPicker) {
                sidebarChartToggle.addEventListener('click', function () {
                    const isOpen = sidebarChartPicker.classList.toggle('open');
                    sidebarChartToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
                });
            }

            if (sidebarChartList && sidebarChartPicker && sidebarChartToggle) {
                sidebarChartList.addEventListener('click', function (event) {
                    const target = event.target.closest('.sidebar-chart-item');
                    if (!target) return;
                    const index = parseInt(target.dataset.index, 10);
                    selectChartByIndex(index);
                    sidebarChartPicker.classList.remove('open');
                    sidebarChartToggle.setAttribute('aria-expanded', 'false');
                    if (window.innerWidth <= 768 && typeof closeSidebar === 'function') {
                        closeSidebar();
                    }
                });

                document.addEventListener('click', function (event) {
                    if (!sidebarChartPicker.contains(event.target)) {
                        sidebarChartPicker.classList.remove('open');
                        sidebarChartToggle.setAttribute('aria-expanded', 'false');
                    }
                });
            }
        });

        function selectChart(chart) {
            // Display the chart image

            chartDisplay.innerHTML = `<img src="${chart.src}" alt="${chart.name}" height="750px">`;
        }


        // allow for speech to change charts
        var speech = new p5.SpeechRec();
        var speak = new p5.Speech(); // speech synthesis object
        speech.onResult = showResult;
        speech.start(true, false); // continuous, interimResults
        
        

        function showResult() {
            if (speech.resultValue) {
                const spokenText = speech.resultString.toLowerCase();
                if (spokenText.includes('select chart')) {
                    var chartName = spokenText.replace('select chart', '').trim();
                    
                
                charts.forEach((chart, index) => {
                    if (chartName.includes(chart.name.toLowerCase())) {
                        speak.speak('Loading ' + chart.name + ' chart');
                        selectChartByIndex(index);
                        if (sidebarChartPicker && sidebarChartToggle) {
                            sidebarChartPicker.classList.remove('open');
                            sidebarChartToggle.setAttribute('aria-expanded', 'false');
                        }
                    }
                });
            }
            }
        }


       
        // Initialize
        loadCharts();

        // METAR Data Fetching
        const sessionIdInput = document.getElementById('sessionIdInput');
        const fetchMetarBtn = document.getElementById('fetchMetarBtn');
        let metarIntervalId = null;
        // Function to fetch METAR data
        async function fetchMetarData(sessionId) {
            const metarDisplay = document.getElementById('metarDisplay');
            try {
                const response = await fetch(`/api/metar/${sessionId}`, { credentials: 'same-origin' });
                if (response.ok) {
                    const payload = await response.json();
                    // You can display this data on the page as needed
                    displayMetarData(payload.data);
                } else if (response.status === 401 || response.status === 403) {
                    metarDisplay.style.display = '';
                    metarDisplay.innerHTML = '<p class="metar-label">Sign in with ATC staff access to load METAR.</p>';
                } else {
                    metarDisplay.style.display = '';
                    metarDisplay.innerHTML = '<p class="metar-label">No METAR found for that session.</p>';
                }
            } catch (error) {
                metarDisplay.style.display = '';
                metarDisplay.innerHTML = '<p class="metar-label">Unable to load METAR data right now.</p>';
            }
        }

        // Function to display METAR data
        function displayMetarData(metarData) {
            let metarDisplay = document.getElementById('metarDisplay');
            
            // Format METAR data in FAA format
            let faaMetar = '';
            
            // Station identifier (if available)
            if (metarData.stationId) {
                faaMetar += metarData.stationId + ' ';
            }
           
            // Date-time group (DDHHmm)
            const now = new Date(metarData.timestamp || new Date());
            const day = String(now.getUTCDate()).padStart(2, '0');
            const hour = String(now.getUTCHours()).padStart(2, '0');
            const minute = String(now.getUTCMinutes()).padStart(2, '0');
            faaMetar += day + hour + minute + 'Z ';
            
            // Wind group (dddssGggKT)
            if (metarData.windDirection !== null && metarData.windSpeed !== null) {
                const windDir = String(parseInt(metarData.windDirection)).padStart(3, '0');
                const windSpd = String(parseInt(metarData.windSpeed)).padStart(2, '0');
                faaMetar += windDir + windSpd;
                if (metarData.windGust) {
                    const gust = String(parseInt(metarData.windGust)).padStart(2, '0');
                    faaMetar += 'G' + gust;
                }
                faaMetar += 'KT ';
            }
            
            // Visibility (NNNSM format)
            if (metarData.visibility !== null) {
                const vis = parseFloat(metarData.visibility).toFixed(1);
                faaMetar += vis + 'SM ';
            }
            
            // Weather phenomena
            if (metarData.isRaining) {
                if (metarData.weatherNotes && metarData.weatherNotes.includes('heavy')) {
                    faaMetar += '+RA ';
                } else if (metarData.weatherNotes && metarData.weatherNotes.includes('light')) {
                    faaMetar += '-RA ';
                }
            } else if (metarData.weatherNotes) {
                faaMetar += metarData.weatherNotes + ' ';
            }
            
            // Format for display - truncate after AO2
            let metarText = faaMetar.trim();
            
            metarDisplay.style.display = '';
            metarDisplay.innerHTML = `
                <p class="metar-label">METAR — updated ${now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' })}</p>
                <p class="metar-code">${metarText}</p>
                <div class="metar-raw">
                    <span>Wind: ${metarData.windDirection}° @ ${metarData.windSpeed}kt${metarData.windGust ? ' G' + metarData.windGust + 'kt' : ''}</span>
                    <span>Visibility: ${metarData.visibility}SM</span>
                    <span>Conditions: ${metarData.weatherNotes || 'Clear'}</span>
                </div>
            `;
        }

        // Event listener for fetch button
        fetchMetarBtn.addEventListener('click', function() {
            const sessionId = sessionIdInput.value.trim();
            if (!sessionId) {
                alert('Please enter a Session ID');
                return;
            }

            // Fetch immediately
            fetchMetarData(sessionId);

            // Clear any existing interval
            if (metarIntervalId) {
                clearInterval(metarIntervalId);
            }

            // Set up interval to fetch every minute (60000 ms)
            metarIntervalId = setInterval(() => {
                fetchMetarData(sessionId);
            }, 60000);
        });

        // Optional: Allow Enter key to trigger fetch
        sessionIdInput.addEventListener('keypress', function(event) {
            if (event.key === 'Enter') {
                fetchMetarBtn.click();
            }
        });


        // Virtual Keyboard
        const virtualKeyboard = document.getElementById('virtualKeyboard');
        const vkToggleBtn = document.getElementById('vkToggleBtn');
        let lastFocusedInput = null;

        // Remember the last focused input so tapping a key doesn't lose context
        document.addEventListener('focusin', function(e) {
            if (e.target.matches('input, textarea') && !e.target.closest('.virtual-keyboard')) {
                lastFocusedInput = e.target;
            }
        });

        function toggleVirtualKeyboard() {
            const isOpen = virtualKeyboard.classList.toggle('active');
            vkToggleBtn.classList.toggle('kb-open', isOpen);
            vkToggleBtn.title = isOpen ? 'Close Virtual Keyboard' : 'Virtual Keyboard';
            if (isOpen) {
                requestAnimationFrame(() => {
                    document.documentElement.style.setProperty('--kb-height', virtualKeyboard.offsetHeight + 'px');
                });
            }
        }

        vkToggleBtn.addEventListener('click', toggleVirtualKeyboard);

        function insertAtCursor(input, text) {
            const start = input.selectionStart != null ? input.selectionStart : input.value.length;
            const end   = input.selectionEnd   != null ? input.selectionEnd   : input.value.length;
            input.value = input.value.substring(0, start) + text + input.value.substring(end);
            input.selectionStart = input.selectionEnd = start + text.length;
            input.dispatchEvent(new Event('input', { bubbles: true }));
        }

        function deleteAtCursor(input) {
            const start = input.selectionStart != null ? input.selectionStart : input.value.length;
            const end   = input.selectionEnd   != null ? input.selectionEnd   : input.value.length;
            if (start !== end) {
                input.value = input.value.substring(0, start) + input.value.substring(end);
                input.selectionStart = input.selectionEnd = start;
            } else if (start > 0) {
                input.value = input.value.substring(0, start - 1) + input.value.substring(end);
                input.selectionStart = input.selectionEnd = start - 1;
            }
            input.dispatchEvent(new Event('input', { bubbles: true }));
        }

        // Prevent keyboard clicks from stealing focus
        virtualKeyboard.addEventListener('mousedown', function(e) {
            e.preventDefault();
        });

        virtualKeyboard.addEventListener('click', function(e) {
            const key = e.target.closest('.vk-key');
            if (!key) return;
            const target = lastFocusedInput || sessionIdInput;
            target.focus();
            if (key.dataset.key !== undefined) {
                insertAtCursor(target, key.dataset.key);
            } else if (key.dataset.action === 'backspace') {
                deleteAtCursor(target);
            } else if (key.dataset.action === 'enter') {
                target.dispatchEvent(new KeyboardEvent('keypress', { key: 'Enter', bubbles: true }));
            }
        });

        
    </script>

</body>
</html>