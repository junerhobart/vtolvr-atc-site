<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="author" content="Caleb Thomas (TheRavenSeb)">
    <meta name="description" content="Applications - View and manage ATC and Enforcer applications.">
    <meta name="keywords" content="Applications, ATC, Enforcer, Aviation, Discord, Vtol VR">
    <title>Applications</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background-color: #1e1e1e;
            color: #e0e0e0;
            min-height: 100vh;
            display: flex;
            flex-direction: row;
            padding: 0;
            margin: 0;
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            overflow-y: auto;
        }

        .sidebar {
            width: 280px;
            background-color: #2a2a2a;
            border-right: 1px solid #444;
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 25px;
            overflow-y: auto;
        }

        .sidebar-logo {
            width: 120px;
            height: 120px;
            background-color: #e0e0e0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
            color: #2a2a2a;
        }

        .sidebar-title {
            text-align: center;
            color: #e0e0e0;
            font-size: 1.3em;
            font-weight: bold;
            line-height: 1.3;
        }

        .sidebar-title a {
            color: #e0e0e0;
            text-decoration: none;
        }

        .sidebar-title a:hover {
            color: #667eea;
        }

        .sidebar-menu {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .sidebar-menu-item {
            padding: 12px 16px;
            color: #b0b0b0;
            text-decoration: none;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
            text-align: left;
            font-size: 0.95em;
        }

        .sidebar-menu-item:hover {
            background-color: #3a3a3a;
            color: #e0e0e0;
        }

        .sidebar-menu-item.active {
            background-color: #667eea;
            color: #ffffff;
        }

        header {
            text-align: center;
            color: #e0e0e0;
            margin-bottom: 40px;
            padding-top: 20px;
        }

        header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
        }

        header p {
            font-size: 1.1em;
            opacity: 0.9;
        }

        .container {
            display: flex;
            gap: 30px;
            max-width: 1200px;
            width: 100%;
            flex-wrap: wrap;
            justify-content: center;
        }

        .applications-panel {
            background: #333;
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            display: flex;
            flex-direction: column;
            gap: 20px;
            flex: 1;
            min-width: 400px;
            max-width: 600px;
            width: 100%;
        }

        .applications-panel h2 {
            color: #e0e0e0;
            font-size: 1.5em;
            margin: 0;
            border-bottom: 2px solid #667eea;
            padding-bottom: 10px;
        }

        .application-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .application-item {
            background: #2a2a2a;
            border-left: 4px solid #667eea;
            padding: 15px;
            border-radius: 6px;
            transition: all 0.2s;
        }

        .application-item:hover {
            background: #3a3a3a;
        }

        .application-item.pending {
            border-left-color: #ffa500;
        }

        .application-item.approved {
            border-left-color: #4CAF50;
        }

        .application-item.rejected {
            border-left-color: #f44336;
        }

        .application-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .applicant-name {
            color: #e0e0e0;
            font-weight: bold;
            font-size: 1.1em;
        }

        .application-status {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: bold;
        }

        .status-pending {
            background-color: #ffa500;
            color: #000;
        }

        .status-approved {
            background-color: #4CAF50;
            color: #fff;
        }

        .status-rejected {
            background-color: #f44336;
            color: #fff;
        }

        .application-position {
            color: #b0b0b0;
            font-size: 0.95em;
            margin-bottom: 5px;
        }

        .application-date {
            color: #888;
            font-size: 0.85em;
        }

        .application-actions {
            display: flex;
            gap: 8px;
            margin-top: 10px;
        }

        .action-btn {
            padding: 6px 12px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.85em;
            transition: all 0.2s;
        }

        .view-btn {
            background-color: #667eea;
            color: white;
        }

        .view-btn:hover {
            background-color: #5568d3;
        }

        .approve-btn {
            background-color: #4CAF50;
            color: white;
        }

        .approve-btn:hover {
            background-color: #45a049;
        }

        .reject-btn {
            background-color: #f44336;
            color: white;
        }

        .reject-btn:hover {
            background-color: #da190b;
        }

        .empty-state {
            text-align: center;
            color: #888;
            padding: 40px 20px;
        }

        .empty-state p {
            font-size: 1.1em;
        }

        footer {
            color: white;
            margin-top: 40px;
            text-align: center;
            opacity: 0.8;
        }

        @media (max-width: 768px) {
            .container {
                flex-direction: column;
                align-items: center;
            }

            header h1 {
                font-size: 1.8em;
            }

            .applications-panel {
                min-width: 100%;
                max-width: 100%;
            }
        }

        @media (max-width: 480px) {
            .application-item {
                padding: 12px;
            }

            .action-btn {
                padding: 4px 8px;
                font-size: 0.75em;
            }
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-logo"><img src="/assets/logo.png" alt="Logo"></div>
        <div class="sidebar-title"><a href="/">Aviation Realism<br>Network</a></div>
        <div class="sidebar-menu">
            <a class="sidebar-menu-item" href="/profile">Profile</a>
            <a class="sidebar-menu-item" href="/announcements">Announcements</a>
            <a class="sidebar-menu-item" href="/pilots">Pilots</a>
            <a class="sidebar-menu-item active" href="/applications">Applications</a>
            <a class="sidebar-menu-item" href="/information">Information</a>
        </div>
    </div>

    <div class="main-content">
        <header>
            <h1>Applications</h1>
            <p>Manage ATC and Enforcer applications for the Aviation Realism Network Discord group.</p>
        </header>

        <div class="container">
            <div class="applications-panel">
                <h2>ATC Applications</h2>
                <div class="application-list" id="atcList">
                    <div class="empty-state">
                        <p>No ATC applications at this time.</p>
                    </div>
                </div>
            </div>

            <div class="applications-panel">
                <h2>Enforcer Applications</h2>
                <div class="application-list" id="enforcerList">
                    <div class="empty-state">
                        <p>No Enforcer applications at this time.</p>
                    </div>
                </div>
            </div>
        </div>

        <footer>
            <p>&copy; 2026 Aviation Realism Network. All rights reserved.</p>
        </footer>
    </div>

    <script>
        function renderApplications(applications, containerId, type) {
            const container = document.getElementById(containerId);
            
            if (applications.length === 0) {
                container.innerHTML = '<div class="empty-state"><p>No ' + type + ' applications at this time.</p></div>';
                return;
            }

            container.innerHTML = applications.map(app => `
                <div class="application-item ${app.status}">
                    <div class="application-header">
                        <span class="applicant-name">${app.name}</span>
                        <span class="application-status status-${app.status}">${app.status.toUpperCase()}</span>
                    </div>
                    <div class="application-position">${type === 'ATC' ? 'Callsign: ' + app.callsign : 'Discord: ' + app.discordHandle}</div>
                    <div class="application-date">Applied: ${new Date(app.date).toLocaleDateString()}</div>
                    <div class="application-actions">
                        <button class="action-btn view-btn">View Full</button>
                        ${app.status === 'pending' ? `
                            <button class="action-btn approve-btn">Approve</button>
                            <button class="action-btn reject-btn">Reject</button>
                        ` : ''}
                    </div>
                </div>
            `).join('');
        }

        // Fetch applications from API
        fetch('/api/applications')
            .then(response => {
                if (!response.ok) {
                    throw new Error('API response was not ok: ' + response.status);
                }
                return response.json();
            })
            .then(result => {
                console.log('Applications fetched:', result);
                const applications = result.data || result || [];
                const atcApplications = applications.filter(app => app.type === 'atc');
                const enforcerApplications = applications.filter(app => app.type === 'enforcer');
                
                renderApplications(atcApplications, 'atcList', 'ATC');
                renderApplications(enforcerApplications, 'enforcerList', 'Enforcer');
            })
            .catch(error => {
                console.error('Error fetching applications:', error);
                alert('Failed to load applications: ' + error.message);
            });
    </script>
</body>
</html>