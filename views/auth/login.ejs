<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="author" content="Caleb Thomas (TheRavenSeb)">
    <meta name="description" content="Login to your Aviation Realism Network account.">
    <meta name="keywords" content="Login, ATC, Aviation, Discord, Vtol VR">
    <title>Login</title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        .main-content {
            display: flex !important;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .hamburger-btn {
            display: none !important;
        }

        @media (max-width: 768px) {
            .hamburger-btn {
                display: flex !important;
            }
        }

        .auth-panel {
            padding: 36px 32px;
            width: 100%;
            max-width: 400px;
        }

        .auth-panel h2 {
            font-size: 1.25rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            margin-bottom: 24px;
            color: #f5f3ef;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .form-group label {
            display: block;
            font-size: 0.85rem;
            font-weight: 500;
            color: rgba(245,243,239,0.6);
            margin-bottom: 6px;
        }

        .form-group input {
            width: 100%;
            padding: 11px 14px;
            background: #1e1e1e;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: #f5f3ef;
            font-family: "Inter", sans-serif;
            font-size: 0.95rem;
            transition: border-color 0.15s;
        }

        .form-group input:focus {
            outline: none;
            border-color: rgba(255,255,255,0.25);
            background: #242424;
        }

        .form-actions {
            margin-top: 24px;
        }

        .submit-btn {
            width: 100%;
            padding: 12px;
            background: #3a3a3a;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: #f5f3ef;
            font-family: "Inter", sans-serif;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.15s;
        }

        .submit-btn:hover {
            background: #444;
            border-color: rgba(255,255,255,0.18);
        }

        .auth-links {
            margin-top: 18px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            text-align: center;
            font-size: 0.875rem;
            color: rgba(245,243,239,0.5);
        }

        .auth-links a {
            color: rgba(245,243,239,0.75);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.15s;
        }

        .auth-links a:hover { color: #f5f3ef; }

        .error-message {
            background: rgba(220,50,50,0.15);
            border: 1px solid rgba(220,50,50,0.3);
            color: #ffb0b0;
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 0.875rem;
            margin-bottom: 16px;
            display: none;
        }

        footer {
            margin-top: 32px;
            text-align: center;
            font-size: 0.8rem;
            color: rgba(245,243,239,0.3);
        }
        <%- include('../partials/fixed-sidebar-theme') %>
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { page: 'login' }) %>

    <div class="main-content">
        <div class="auth-panel">
            <h2>Sign in</h2>
            <div class="error-message" id="errorMessage"></div>
            <form id="loginForm" data-redirect="<%= redirect || '' %>">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="username" required autocomplete="username">
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" required autocomplete="current-password">
                </div>
                <div class="form-actions">
                    <button type="submit" class="submit-btn">Sign in</button>
                </div>
            </form>
            <div class="auth-links">
                <span>No account? <a href="/register">Register</a></span>
                <span>Forgot password? <a href="/forgot-password">Reset it</a></span>
            </div>
        </div>

        <footer>
            <%#  <p>&copy; 2026 Aviation Realism Network. All rights reserved.</p> %>
            <p>Bringing realistic aviation simulation to VTOL VR</p>
        </footer>
    </div>

    <script>
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const redirectUrl = document.getElementById('loginForm').dataset.redirect || '/';
            
            const formData = {
                username: document.getElementById('username').value,
                password: document.getElementById('password').value
            };

            fetch('/api/auth/login', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(formData)
            })
            .then(async response => {
                const payload = await response.json();
                if (!response.ok || payload.error) {
                    throw new Error(payload.error || 'Error logging in. Please try again.');
                }

                window.location.href = redirectUrl;
            })
            .catch(error => {
                document.getElementById('errorMessage').textContent = error.message;
                document.getElementById('errorMessage').style.display = 'block';
            });
        });
    </script>
</body>
</html>