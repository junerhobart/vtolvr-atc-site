<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="author" content="Caleb Thomas (TheRavenSeb)">
    <meta name="description" content="Login to your Aviation Realism Network account.">
    <meta name="keywords" content="Login, ATC, Aviation, Discord, Vtol VR">
    <title>Login</title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        .main-content {
            display: flex !important;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .hamburger-btn {
            display: none !important;
        }

        @media (max-width: 768px) {
            .hamburger-btn {
                display: flex !important;
            }
        }

        .auth-panel {
            padding: 36px 32px;
            width: 100%;
            max-width: 400px;
        }

        .auth-panel h2 {
            font-size: 1.25rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            margin-bottom: 24px;
            color: #f5f3ef;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .form-group label {
            display: block;
            font-size: 0.85rem;
            font-weight: 500;
            color: rgba(245,243,239,0.6);
            margin-bottom: 6px;
        }

        .form-group input {
            width: 100%;
            padding: 11px 14px;
            background: #1e1e1e;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: #f5f3ef;
            font-family: "Inter", sans-serif;
            font-size: 0.95rem;
            transition: border-color 0.15s;
        }

        .form-group input:focus {
            outline: none;
            border-color: rgba(255,255,255,0.25);
            background: #242424;
        }

        .form-actions {
            margin-top: 24px;
        }

        .submit-btn {
            width: 100%;
            padding: 12px;
            background: #3a3a3a;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: #f5f3ef;
            font-family: "Inter", sans-serif;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.15s;
        }

        .submit-btn:hover {
            background: #444;
            border-color: rgba(255,255,255,0.18);
        }

        .auth-links {
            margin-top: 18px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            text-align: center;
            font-size: 0.875rem;
            color: rgba(245,243,239,0.5);
        }

        .auth-links a {
            color: rgba(245,243,239,0.75);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.15s;
        }

        .auth-links a:hover { color: #f5f3ef; }

        .error-message {
            background: rgba(220,50,50,0.15);
            border: 1px solid rgba(220,50,50,0.3);
            color: #ffb0b0;
            padding: 10px 14px;
            border-radius: 8px;
            font-size: 0.875rem;
            margin-bottom: 16px;
            display: none;
        }

        footer {
            margin-top: 32px;
            text-align: center;
            font-size: 0.8rem;
            color: rgba(245,243,239,0.3);
        }

        /* Virtual Keyboard */
        .vk-toggle-btn {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1001;
            border-radius: 50%;
            width: 52px;
            height: 52px;
            font-size: 1.4em;
            transition: bottom 0.25s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .vk-toggle-btn.kb-open {
            bottom: calc(var(--kb-height, 240px) + 14px);
        }

        .virtual-keyboard {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background: rgba(26, 26, 26, 0.97);
            border-top: 1px solid rgba(255,255,255,0.08);
            padding: 10px 8px 16px;
            z-index: 1000;
            transform: translateY(100%);
            transition: transform 0.25s ease;
            display: flex;
            flex-direction: column;
            gap: 5px;
            align-items: center;
        }

        .virtual-keyboard.active { transform: translateY(0); }

        .vk-row {
            display: flex;
            gap: 4px;
            justify-content: center;
            width: 100%;
            max-width: 860px;
        }

        .vk-key {
            background: rgba(50, 50, 50, 0.9);
            color: #e0e0e0;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 6px;
            height: 38px;
            flex: 1;
            min-width: 0;
            font-size: 0.82em;
            cursor: pointer;
            user-select: none;
            -webkit-user-select: none;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 2px;
        }

        .vk-key-wide   { flex: 1.6; }
        .vk-key-space  { flex: 5; }
        .vk-key-action { background: rgba(70, 70, 70, 0.9); }
        <%- include('../partials/fixed-sidebar-theme') %>
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { page: 'login' }) %>

    <div class="main-content">
        <div class="auth-panel">
            <h2>Sign in</h2>
            <div class="error-message" id="errorMessage"></div>
            <form id="loginForm" data-redirect="<%= redirect || '' %>">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="username" required autocomplete="username">
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" required autocomplete="current-password">
                </div>
                <div class="form-actions">
                    <button type="submit" class="submit-btn">Sign in</button>
                </div>
            </form>
            <div class="auth-links">
                <span>No account? <a href="/register">Register</a></span>
                <span>Forgot password? <a href="/forgot-password">Reset it</a></span>
            </div>
        </div>

        <footer>
            <%#  <p>&copy; 2026 Aviation Realism Network. All rights reserved.</p> %>
            <p>Bringing realistic aviation simulation to VTOL VR</p>
        </footer>
    </div>

    <!-- Virtual Keyboard Toggle Button -->
    <button class="vk-toggle-btn" id="vkToggleBtn" aria-label="Toggle virtual keyboard" title="Virtual Keyboard">⌨</button>

    <!-- Virtual Keyboard -->
    <div class="virtual-keyboard" id="virtualKeyboard">
        <div class="vk-row">
            <button class="vk-key" data-key="1">1</button>
            <button class="vk-key" data-key="2">2</button>
            <button class="vk-key" data-key="3">3</button>
            <button class="vk-key" data-key="4">4</button>
            <button class="vk-key" data-key="5">5</button>
            <button class="vk-key" data-key="6">6</button>
            <button class="vk-key" data-key="7">7</button>
            <button class="vk-key" data-key="8">8</button>
            <button class="vk-key" data-key="9">9</button>
            <button class="vk-key" data-key="0">0</button>
            <button class="vk-key vk-key-wide vk-key-action" data-action="backspace">⌫</button>
        </div>
        <div class="vk-row">
            <button class="vk-key" data-key="Q">Q</button>
            <button class="vk-key" data-key="W">W</button>
            <button class="vk-key" data-key="E">E</button>
            <button class="vk-key" data-key="R">R</button>
            <button class="vk-key" data-key="T">T</button>
            <button class="vk-key" data-key="Y">Y</button>
            <button class="vk-key" data-key="U">U</button>
            <button class="vk-key" data-key="I">I</button>
            <button class="vk-key" data-key="O">O</button>
            <button class="vk-key" data-key="P">P</button>
        </div>
        <div class="vk-row">
            <button class="vk-key" data-key="A">A</button>
            <button class="vk-key" data-key="S">S</button>
            <button class="vk-key" data-key="D">D</button>
            <button class="vk-key" data-key="F">F</button>
            <button class="vk-key" data-key="G">G</button>
            <button class="vk-key" data-key="H">H</button>
            <button class="vk-key" data-key="J">J</button>
            <button class="vk-key" data-key="K">K</button>
            <button class="vk-key" data-key="L">L</button>
        </div>
        <div class="vk-row">
            <button class="vk-key" data-key="Z">Z</button>
            <button class="vk-key" data-key="X">X</button>
            <button class="vk-key" data-key="C">C</button>
            <button class="vk-key" data-key="V">V</button>
            <button class="vk-key" data-key="B">B</button>
            <button class="vk-key" data-key="N">N</button>
            <button class="vk-key" data-key="M">M</button>
            <button class="vk-key" data-key="-">-</button>
            <button class="vk-key" data-key=".">.</button>
            <button class="vk-key" data-key="/">/</button>
        </div>
        <div class="vk-row">
            <button class="vk-key vk-key-space" data-key=" ">Space</button>
            <button class="vk-key vk-key-wide vk-key-action" data-action="enter">↵ Enter</button>
        </div>
    </div>

    <script>
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const redirectUrl = document.getElementById('loginForm').dataset.redirect || '/';
            
            const formData = {
                username: document.getElementById('username').value,
                password: document.getElementById('password').value
            };

            fetch('/api/auth/login', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(formData)
            })
            .then(async response => {
                const payload = await response.json();
                if (!response.ok || payload.error) {
                    throw new Error(payload.error || 'Error logging in. Please try again.');
                }

                window.location.href = redirectUrl;
            })
            .catch(error => {
                document.getElementById('errorMessage').textContent = error.message;
                document.getElementById('errorMessage').style.display = 'block';
            });
        });

        // Virtual Keyboard
        const virtualKeyboard = document.getElementById('virtualKeyboard');
        const vkToggleBtn = document.getElementById('vkToggleBtn');
        let lastFocusedInput = null;

        // Remember last focused credential field
        document.addEventListener('focusin', function(e) {
            if (e.target.matches('input, textarea') && !e.target.closest('.virtual-keyboard')) {
                lastFocusedInput = e.target;
            }
        });

        function toggleVirtualKeyboard() {
            const isOpen = virtualKeyboard.classList.toggle('active');
            vkToggleBtn.classList.toggle('kb-open', isOpen);
            vkToggleBtn.title = isOpen ? 'Close Virtual Keyboard' : 'Virtual Keyboard';
            if (isOpen) {
                requestAnimationFrame(() => {
                    document.documentElement.style.setProperty('--kb-height', virtualKeyboard.offsetHeight + 'px');
                });
            }
        }

        vkToggleBtn.addEventListener('click', toggleVirtualKeyboard);

        function insertAtCursor(input, text) {
            const start = input.selectionStart != null ? input.selectionStart : input.value.length;
            const end   = input.selectionEnd   != null ? input.selectionEnd   : input.value.length;
            input.value = input.value.substring(0, start) + text + input.value.substring(end);
            input.selectionStart = input.selectionEnd = start + text.length;
            input.dispatchEvent(new Event('input', { bubbles: true }));
        }

        function deleteAtCursor(input) {
            const start = input.selectionStart != null ? input.selectionStart : input.value.length;
            const end   = input.selectionEnd   != null ? input.selectionEnd   : input.value.length;
            if (start !== end) {
                input.value = input.value.substring(0, start) + input.value.substring(end);
                input.selectionStart = input.selectionEnd = start;
            } else if (start > 0) {
                input.value = input.value.substring(0, start - 1) + input.value.substring(end);
                input.selectionStart = input.selectionEnd = start - 1;
            }
            input.dispatchEvent(new Event('input', { bubbles: true }));
        }

        virtualKeyboard.addEventListener('mousedown', function(e) {
            e.preventDefault();
        });

        virtualKeyboard.addEventListener('click', function(e) {
            const key = e.target.closest('.vk-key');
            if (!key) return;
            const fallbackTarget = document.getElementById('username');
            const target = lastFocusedInput || fallbackTarget;
            if (!target) return;

            target.focus();
            if (key.dataset.key !== undefined) {
                insertAtCursor(target, key.dataset.key);
            } else if (key.dataset.action === 'backspace') {
                deleteAtCursor(target);
            } else if (key.dataset.action === 'enter') {
                document.getElementById('loginForm').requestSubmit();
            }
        });
    </script>
</body>
</html>