<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Knowledge Base</title>
    <link rel="icon" type="image/png" href="/assets/logo.png">

    <style>
        .main-content {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .page-wrap {
            flex: 1;
            max-width: 960px;
            margin: 0 auto;
            padding: 48px 24px;
            width: 100%;
        }

        .hero {
            margin-bottom: 28px;
            text-align: center;
            padding-top: 20px;
        }

        .hero h1 {
            font-size: 2.5em;
            font-weight: 700;
            color: #f5f3ef;
            margin-bottom: 10px;
        }

        .hero p {
            color: rgba(245,243,239,0.7);
            font-size: 1.1em;
            opacity: 0.9;
        }

        .pdf-viewer {
            width: 100%;
            height: 78vh;
            border: none;
            border-radius: 0;
            background: #fff;
            display: block;
        }

        footer {
            text-align: center;
            padding: 24px 20px;
            font-size: 0.8rem;
            color: rgba(245,243,239,0.3);
        }

        @media (max-width: 768px) {
            .page-wrap { padding: 24px 16px; }
            .hero h1 { font-size: 1.6rem; }
            .pdf-viewer { height: 62vh; }
        }
        <%- include('partials/fixed-sidebar-theme') %>
    </style>
</head>

<body>
    <%- include('partials/sidebar', { page: 'information' }) %>

    <div class="main-content">
        <div class="page-wrap">
            <div class="hero">
                <h1>Knowledge Base</h1>
                <p>Role-based manuals, procedures, and operational documentation.</p>
            </div>

            <div class="kb-doc-toolbar">
                <div class="sidebar-chart-picker charts-inline-chart-picker kb-doc-picker">
                    <span class="sidebar-chart-label">Select document</span>
                    <button
                        type="button"
                        id="kbDropdownToggle"
                        class="sidebar-chart-dropdown-toggle"
                        aria-expanded="false"
                        aria-controls="kbDocList"
                    >
                        Select a document...
                    </button>
                    <ul id="kbDocList" class="sidebar-chart-list" role="listbox" aria-label="Knowledge base documents"></ul>
                </div>
            </div>

            <iframe class="pdf-viewer" id="pdfViewer" src="" title="Document viewer"></iframe>
        </div>

        <footer>
            <p>Bringing realistic aviation simulation to VTOL VR</p>
        </footer>
    </div>

    <script>
        const currentUser = JSON.parse('<%- JSON.stringify(user || {}) %>');
        const normalizedRoles = Array.isArray(currentUser.role)
            ? currentUser.role
            : Array.isArray(currentUser.Role)
                ? currentUser.Role
                : typeof currentUser.role === 'string'
                    ? [currentUser.role]
                    : typeof currentUser.Role === 'string'
                        ? [currentUser.Role]
                        : [];

        const userRoles = normalizedRoles.map(r => String(r).toLowerCase());
        if (userRoles.length === 0) userRoles.push('user');

        const knowledgeBase = [
            { title: 'General Information',    pdfPath: 'assets/pdfs/GeneralGuide.pdf',        roles: ['user','atc','enforcer','interceptor','mod','admin','owner'] },
            { title: 'ATC Operations',         pdfPath: 'assets/pdfs/AtcHandbook.pdf',          roles: ['atc','mod','admin','owner'] },
            { title: 'Enforcer Guide',         pdfPath: 'assets/pdfs/enforcer-guide.pdf',       roles: ['enforcer','mod','admin','owner'] },
            { title: 'Interceptor Manual',     pdfPath: 'assets/pdfs/interceptor-manual.pdf',   roles: ['interceptor','mod','admin','owner'] },
            { title: 'Moderation Guidelines',  pdfPath: 'assets/pdfs/ModerationHandbook.pdf',   roles: ['mod','admin','owner'] },
            { title: 'Admin Panel',            pdfPath: 'assets/pdfs/admin-panel.pdf',          roles: ['mod','admin','owner'] },
            { title: 'Owner Documentation',    pdfPath: 'assets/pdfs/owner-docs.pdf',           roles: ['owner'] }
        ];

        const available = knowledgeBase.filter(tab => tab.roles.some(r => userRoles.includes(r)));

        const kbPicker = document.querySelector('.kb-doc-picker');
        const kbToggle = document.getElementById('kbDropdownToggle');
        const kbList = document.getElementById('kbDocList');
        const viewer = document.getElementById('pdfViewer');
        const pdfFallback = 'assets/pdfs/placeholder.pdf';
        const setViewerPdf = (url) => fetch(url, { method: 'HEAD' }).then(r => { viewer.src = r.ok ? url : pdfFallback; }).catch(() => { viewer.src = pdfFallback; });

        let selectedKbIndex = null;

        function setKbDropdownLabel(label) {
            if (kbToggle) kbToggle.textContent = label;
        }

        function setActiveKbInList(index) {
            if (!kbList) return;
            kbList.querySelectorAll('.sidebar-chart-item').forEach((item) => {
                const isActive = parseInt(item.dataset.index, 10) === index;
                item.classList.toggle('active', isActive);
                item.setAttribute('aria-selected', isActive ? 'true' : 'false');
            });
        }

        function selectKbByIndex(index) {
            const tab = available[index];
            if (!tab) return;
            selectedKbIndex = index;
            setKbDropdownLabel(tab.title);
            setActiveKbInList(index);
            setViewerPdf(tab.pdfPath);
        }

        function renderKbList() {
            if (!kbList) return;
            kbList.innerHTML = '';
            if (available.length === 0) {
                const li = document.createElement('li');
                li.className = 'sidebar-chart-empty';
                li.textContent = 'No documents for your role.';
                kbList.appendChild(li);
                setKbDropdownLabel('No documents');
                return;
            }
            available.forEach((tab, index) => {
                const li = document.createElement('li');
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'sidebar-chart-item';
                btn.dataset.index = String(index);
                btn.setAttribute('role', 'option');
                btn.setAttribute('aria-selected', 'false');
                btn.textContent = tab.title;
                li.appendChild(btn);
                kbList.appendChild(li);
            });
            if (selectedKbIndex !== null) setActiveKbInList(selectedKbIndex);
        }

        renderKbList();
        if (available.length > 0) selectKbByIndex(0);

        if (kbToggle && kbPicker) {
            kbToggle.addEventListener('click', function () {
                const isOpen = kbPicker.classList.toggle('open');
                kbToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
            });
        }

        if (kbList && kbPicker && kbToggle) {
            kbList.addEventListener('click', function (event) {
                const target = event.target.closest('.sidebar-chart-item');
                if (!target) return;
                const index = parseInt(target.dataset.index, 10);
                selectKbByIndex(index);
                kbPicker.classList.remove('open');
                kbToggle.setAttribute('aria-expanded', 'false');
            });

            document.addEventListener('click', function (event) {
                if (!kbPicker.contains(event.target)) {
                    kbPicker.classList.remove('open');
                    kbToggle.setAttribute('aria-expanded', 'false');
                }
            });
        }
    </script>
</body>

</html>
