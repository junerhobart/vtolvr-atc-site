<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Knowledge Base</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1e1e2e 0%, #2d2d44 100%);
            color: #e0e0e0;
            min-height: 100vh;
            line-height: 1.6;
            padding: 30px 20px;
        }

        .page-shell {
            max-width: 1200px;
            margin: 0 auto;
        }

        .brand-header {
            display: flex;
            justify-content: center;
            margin-bottom: 24px;
        }

        .brand-logo {
            height: 150px;
            width: 150px;
            object-fit: contain;
            filter: drop-shadow(0 8px 16px rgba(0, 0, 0, 0.35));
        }

        .page-title {
            font-size: 1.8em;
            text-align: center;
            margin-bottom: 6px;
            color: #e0e0e0;
        }

        .page-subtitle {
            text-align: center;
            color: #b0b0b0;
            margin-bottom: 24px;
        }

        .tabs-container {
            background: transparent;
        }

        .tabs-header {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            overflow-x: auto;
            background: transparent;
            padding: 0;
            gap: 18px;
            margin-bottom: 26px;
            scrollbar-width: thin;
        }

        .content-divider {
            border: 0;
            border-top: 1px solid rgba(102, 126, 234, 0.25);
            margin-bottom: 30px;
        }

        .tab-button {
            min-height: 58px;
            padding: 12px 16px;
            border: 1px solid rgba(102, 126, 234, 0.3);
            border-radius: 6px;
            background: rgba(51, 51, 51, 0.55);
            backdrop-filter: blur(10px);
            cursor: pointer;
            font-size: 15px;
            font-weight: 600;
            transition: all 0.3s;
            color: #e0e0e0;
        }

        .tab-button:hover {
            background: rgba(102, 126, 234, 0.25);
            color: #ffffff;
            transform: translateY(-1px);
        }

        .tab-button.active {
            background: #667eea;
            color: #fff;
            border-color: #667eea;
            box-shadow: 0 8px 18px rgba(102, 126, 234, 0.4);
        }

        #tabsContent {
            background: rgba(51, 51, 51, 0.55);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            border: 1px solid rgba(102, 126, 234, 0.25);
            box-shadow: 0 12px 28px rgba(10, 10, 18, 0.35);
            overflow: hidden;
        }

        .tab-content {
            display: none;
            padding: 24px;
            min-height: 600px;
        }

        .tab-content.active {
            display: block;
        }

        .pdf-viewer {
            width: 100%;
            height: 700px;
            border: 1px solid rgba(102, 126, 234, 0.25);
            border-radius: 10px;
            background: #fff;
        }

        h2 {
            color: #e0e0e0;
            margin-top: 0;
            margin-bottom: 14px;
            font-size: 1.5rem;
            letter-spacing: -0.02em;
        }

        .section-copy {
            color: #b0b0b0;
            margin-bottom: 18px;
        }

        .section-divider {
            border: 0;
            border-top: 1px solid rgba(102, 126, 234, 0.2);
            margin-bottom: 20px;
        }

        @media (max-width: 768px) {
            body {
                padding: 18px 14px;
            }

            .brand-logo {
                height: 120px;
                width: 120px;
            }

            .page-title {
                font-size: 1.5em;
            }

            .tabs-header {
                grid-template-columns: 1fr;
                gap: 12px;
            }

            .tab-content {
                padding: 16px;
                min-height: 420px;
            }

            .pdf-viewer {
                height: 62vh;
            }
        }
    </style>
</head>

<body>
    <div class="page-shell">
        <div class="brand-header">
            <img class="brand-logo" src="https://atc-vtolvr.site/assets/logo.png" alt="ARN Badge">
        </div>
        <h1 class="page-title">Knowledge Base</h1>
        <p class="page-subtitle">Role-based manuals, procedures, and operational documentation.</p>

        <div class="tabs-container">
            <div class="tabs-header" id="tabsHeader"></div>
            <hr class="content-divider">
            <div id="tabsContent"></div>
        </div>
    </div>

    <script>
        // Get user roles from template variable (supports both user.role and user.Role)
        const currentUser = JSON.parse('<%- JSON.stringify(user || {}) %>');
        const normalizedRoles = Array.isArray(currentUser.role)
            ? currentUser.role
            : Array.isArray(currentUser.Role)
                ? currentUser.Role
                : typeof currentUser.role === "string"
                    ? [currentUser.role]
                    : typeof currentUser.Role === "string"
                        ? [currentUser.Role]
                        : [];

        const userRoles = normalizedRoles.map((role) => String(role).toLowerCase());
        if (userRoles.length === 0) userRoles.push("guest");

        // Knowledge base content based on roles
        const knowledgeBase = [
            {
                title: 'General Information',
                pdfPath: 'assets/pdfs/general.pdf',
                roles: ['guest', 'atc', 'enforcer', 'interceptor', 'mod', 'admin', 'owner']
            },
            {
                title: 'ATC Operations',
                pdfPath: 'assets/pdfs/atc-operations.pdf',
                roles: ['atc', 'mod', 'admin', 'owner']
            },
            {
                title: 'Enforcer Guide',
                pdfPath: 'assets/pdfs/enforcer-guide.pdf',
                roles: ['enforcer', 'mod', 'admin', 'owner']
            },
            {
                title: 'Interceptor Manual',
                pdfPath: 'assets/pdfs/interceptor-manual.pdf',
                roles: ['interceptor', 'mod', 'admin', 'owner']
            },
            {
                title: 'Moderation Guidelines',
                pdfPath: 'assets/pdfs/ModerationHandbook.pdf',
                roles: ['mod', 'admin', 'owner']
            },
            {
                title: 'Admin Panel',
                pdfPath: 'assets/pdfs/admin-panel.pdf',
                roles: ["mod", "admin", "owner"]
            },
            {
                title: 'Owner Documentation',
                pdfPath: 'assets/pdfs/owner-docs.pdf',
                roles: ['owner']
            }
        ];

        // Filter knowledge base by user role
        const availableTabs = knowledgeBase.filter((tab) =>
            tab.roles.some(role => userRoles.includes(role))
        );

        // Render tabs
        const tabsHeader = document.getElementById('tabsHeader');
        const tabsContent = document.getElementById('tabsContent');

        availableTabs.forEach((tab, index) => {
            // Create tab button
            const button = document.createElement('button');
            button.className = `tab-button ${index === 0 ? "active" : ""}`;
            button.textContent = tab.title;
            button.onclick = () => selectTab(index);
            tabsHeader.appendChild(button);

            // Create tab content
            const content = document.createElement('div');
            content.className = `tab-content ${index === 0 ? "active" : ""}`;
            content.innerHTML = `
                <h2>${tab.title}</h2>
                <p class="section-copy">Review this document carefully and follow all listed procedures and guidance.</p>
                <hr class="section-divider">
                <iframe class="pdf-viewer" src="${tab.pdfPath}" type="application/pdf"></iframe>
            `;
            tabsContent.appendChild(content);
        });

        function selectTab(index) {
            // Remove active class from all tabs
            document.querySelectorAll(".tab-button").forEach((btn) => btn.classList.remove("active"));
            document.querySelectorAll(".tab-content").forEach((content) => content.classList.remove("active"));

            // Add active class to selected tab
            document.querySelectorAll(".tab-button")[index].classList.add("active");
            document.querySelectorAll(".tab-content")[index].classList.add("active");
        }
    </script>
</body>

</html>
