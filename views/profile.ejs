<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="author" content="Caleb Thomas (TheRavenSeb)">
    <meta name="description" content="User Profile - View and manage your account information.">
    <meta name="keywords" content="Profile, User Account, Aviation, VTOL VR">
    <title>User Profile</title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <style>
        .main-content {
            flex-direction: column;
        }

        .container {
            width: 100%;
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 0 0;
        }

        .page-header {
            text-align: center;
            padding-top: 20px;
            margin-bottom: 30px;
        }

        .page-title {
            font-size: 2.5em;
            font-weight: 700;
            color: #e0e0e0;
            margin-bottom: 10px;
        }

        .page-subtitle {
            font-size: 1.1em;
            color: #e0e0e0;
            opacity: 0.9;
        }

        .profile-wrap {
            width: 100%;
        }

        .profile-header {
            display: flex;
            align-items: center;
            gap: 24px;
            margin-bottom: 28px;
            padding-bottom: 24px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }

        .profile-avatar {
            width: 88px;
            height: 88px;
            border-radius: 50%;
            background: #2e2e2e;
            border: 1px solid rgba(255,255,255,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: rgba(245,243,239,0.4);
            flex-shrink: 0;
            overflow: hidden;
        }

        .profile-avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }

        .profile-username {
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #f5f3ef;
            margin-bottom: 8px;
        }

        .profile-status {
            display: inline-block;
            padding: 3px 10px;
            background: rgba(50,180,80,0.12);
            border: 1px solid rgba(50,180,80,0.25);
            color: #b6f3be;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 500;
        }

        .profile-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 28px;
        }

        .detail-section { display: flex; flex-direction: column; gap: 16px; }
        .detail-item { display: flex; flex-direction: column; gap: 3px; }

        .detail-label {
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: rgba(245,243,239,0.35);
        }

        .detail-value {
            font-size: 0.95rem;
            font-weight: 500;
            color: #f5f3ef;
        }

        .stats-section {
            padding: 0 0 24px;
            margin-bottom: 24px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }

        .stats-section:last-of-type {
            border-bottom: none;
            padding-bottom: 0;
            margin-bottom: 0;
        }

        .stats-section h3 {
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: rgba(245,243,239,0.35);
            margin-bottom: 14px;
        }

        .role-badge {
            display: inline-block;
            padding: 4px 10px;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 6px;
            font-size: 0.78rem;
            font-weight: 600;
            color: rgba(245,243,239,0.75);
            margin-right: 6px;
            margin-bottom: 4px;
            letter-spacing: 0.04em;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        .stat-card {
            padding: 16px 0;
        }

        .stat-value {
            font-size: 1.6rem;
            font-weight: 700;
            color: #f5f3ef;
            letter-spacing: -0.02em;
        }

        .stat-label {
            font-size: 0.78rem;
            color: rgba(245,243,239,0.4);
            margin-top: 4px;
        }

        .action-buttons {
            display: flex;
            gap: 10px;
            margin-top: 28px;
        }

        .btn {
            padding: 11px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-family: "Inter", sans-serif;
            font-size: 0.9rem;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            text-align: center;
            transition: all 0.15s;
        }

        .btn-primary {
            background: #3a3a3a;
            border: 1px solid rgba(255,255,255,0.1);
            color: #f5f3ef;
        }
        .btn-primary:hover { background: #444; border-color: rgba(255,255,255,0.18); }

        .btn-secondary {
            background: transparent;
            border: 1px solid rgba(255,255,255,0.08);
            color: rgba(245,243,239,0.6);
        }
        .btn-secondary:hover { background: #2a2a2a; color: #f5f3ef; }

        .not-logged-in { text-align: center; padding: 40px 20px; }
        .not-logged-in h2 { color: #f5f3ef; margin-bottom: 12px; font-size: 1.2rem; }
        .not-logged-in p { color: rgba(245,243,239,0.45); margin-bottom: 24px; font-size: 0.9rem; }

        .modal {
            display: none;
            position: fixed;
            z-index: 2000;
            inset: 0;
            background: rgba(0,0,0,0.65);
        }
        .modal.show { display: flex; align-items: center; justify-content: center; padding: 20px; }

        .modal-content {
            background: #232323;
            border: 1px solid rgba(255,255,255,0.08);
            padding: 28px;
            border-radius: 12px;
            width: 100%;
            max-width: 460px;
            max-height: 85vh;
            overflow-y: auto;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 22px;
            padding-bottom: 16px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }

        .modal-header h2 {
            font-size: 1.1rem;
            font-weight: 700;
            color: #f5f3ef;
        }

        .modal-close {
            background: transparent;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 6px;
            color: rgba(245,243,239,0.5);
            font-size: 1.1rem;
            cursor: pointer;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.15s;
        }
        .modal-close:hover { color: #f5f3ef; background: #2e2e2e; }

        .form-group { margin-bottom: 16px; }

        .form-label {
            display: block;
            font-size: 0.82rem;
            font-weight: 500;
            color: rgba(245,243,239,0.55);
            margin-bottom: 6px;
        }

        .form-input {
            width: 100%;
            padding: 11px 14px;
            background: #1e1e1e;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: #f5f3ef;
            font-family: "Inter", sans-serif;
            font-size: 0.95rem;
            transition: border-color 0.15s;
        }
        .form-input:focus { outline: none; border-color: rgba(255,255,255,0.25); background: #242424; }
        .form-input::placeholder { color: rgba(245,243,239,0.2); }

        .button-group { display: flex; gap: 8px; margin-top: 22px; }

        .btn-save {
            flex: 1; padding: 11px;
            background: #3a3a3a;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: #f5f3ef;
            font-family: "Inter", sans-serif;
            font-size: 0.9rem; font-weight: 600;
            cursor: pointer; transition: all 0.15s;
        }
        .btn-save:hover { background: #444; }

        .btn-cancel {
            flex: 1; padding: 11px;
            background: transparent;
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 8px;
            color: rgba(245,243,239,0.5);
            font-family: "Inter", sans-serif;
            font-size: 0.9rem; font-weight: 500;
            cursor: pointer; transition: all 0.15s;
        }
        .btn-cancel:hover { background: #2a2a2a; color: #f5f3ef; }

        .success-message {
            padding: 10px 14px; border-radius: 8px; margin-bottom: 16px; display: none;
            background: rgba(50,180,80,0.12);
            border: 1px solid rgba(50,180,80,0.3);
            color: #b6f3be; font-size: 0.875rem;
        }
        .success-message.show { display: block; }

        .error-message {
            padding: 10px 14px; border-radius: 8px; margin-bottom: 16px; display: none;
            background: rgba(220,50,50,0.15);
            border: 1px solid rgba(220,50,50,0.3);
            color: #ffb0b0; font-size: 0.875rem;
        }
        .error-message.show { display: block; }

        footer { margin-top: 8px; text-align: center; font-size: 0.8rem; color: rgba(245,243,239,0.3); }

        @media (max-width: 768px) {
            .profile-header { flex-direction: column; text-align: center; }
            .profile-details { grid-template-columns: 1fr; }
            .stats-grid { grid-template-columns: 1fr; }
            .action-buttons { flex-direction: column; }
            .btn { width: 100%; }
            .profile-wrap { padding: 0; }
            .container { padding: 20px; }
        }
        <%- include('partials/fixed-sidebar-theme') %>
    </style>
</head>
<body>
        <%- include('partials/sidebar', { page: 'profile' }) %>

    <div class="main-content">
        <div class="container">
            <div class="page-header">
                <h1 class="page-title">Profile</h1>
                <p class="page-subtitle">Your account details and statistics</p>
            </div>
            <% if (user) { %>
                <div class="profile-wrap">
                    <div class="profile-header">
                        <div class="profile-avatar"><img src="<%= user.avatar || '/assets/logo.png' %>" alt="Avatar" style="border-radius: 50%;" /></div>
                        <div class="profile-info">
                            <div class="profile-username"><%= user.username %></div>
                            <span class="profile-status">Active</span>
                        </div>
                    </div>

                    <div class="profile-details">
                        <div class="detail-section">
                            <div class="detail-item">
                                <span class="detail-label">Username</span>
                                <span class="detail-value"><%= user.username %></span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Flight Hours</span>
                                <span class="detail-value"><%= user.flighthours %></span>
                            </div>
                        </div>
                        <div class="detail-section">
                            <div class="detail-item">
                                <span class="detail-label">Account Status</span>
                                <span class="detail-value">Verified</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Member Since</span>
                                <span class="detail-value">2026</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Account Code</span>
                                <span class="detail-value"><%= user.code %></span>
                            </div>
                        </div>
                    </div>

                    <div class="stats-section">
                        <h3>Account Roles</h3>
                        <div>
                            <% if (user.role && user.role.length > 0) { %>
                                <% user.role.forEach(role => { %>
                                    <span class="role-badge"><%= role.toUpperCase() %></span>
                                <% }); %>
                            <% } else { %>
                                <span class="role-badge">USER</span>
                            <% } %>
                        </div>
                    </div>

                    <div class="stats-section">
                        <h3>Statistics</h3>
                        <div class="stats-grid">
                            <div class="stat-card">
                                <div class="stat-value"><%= user.flighthours %></div>
                                <div class="stat-label">Flight Hours</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-value"><%= user.role.length %></div>
                                <div class="stat-label">Active Roles</div>
                            </div>
                        </div>
                    </div>

                    <div class="action-buttons">
                        <button class="btn btn-primary" onclick="openEditModal()">Edit Profile</button>
                        <a href="/logout" class="btn btn-secondary">Logout</a>
                    </div>
                </div>
            <% } else { %>
                <div class="profile-wrap not-logged-in">
                    <h2>Not Logged In</h2>
                    <p>You need to be logged in to view your profile.</p>
                    <a href="/login" class="btn btn-primary">Login</a>
                </div>
            <% } %>
        </div>

        <div id="editProfileModal" class="modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h2>Edit Profile</h2>
                    <button class="modal-close" onclick="closeEditModal()">&times;</button>
                </div>

                <div id="successMessage" class="success-message"></div>
                <div id="errorMessage" class="error-message"></div>

                <form id="editProfileForm">
                    <div class="form-group">
                        <label class="form-label">Callsign (e.g., N123C)</label>
                        <input type="text" class="form-input" id="callsign" placeholder="N123C" maxlength="5" style="text-transform: uppercase;">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-input" id="email" placeholder="Enter your email address">
                    </div>

                   

                    

                    <div class="button-group">
                        <button type="button" class="btn-save" onclick="saveProfileChanges()">Save Changes</button>
                        <button type="button" class="btn-cancel" onclick="closeEditModal()">Cancel</button>
                    </div>
                </form>
            </div>
        </div>

        <footer>
            <%#  <p>&copy; 2026 Aviation Realism Network. All rights reserved.</p> %>
            <p>Bringing realistic aviation simulation to VTOL VR</p>
        </footer>
    </div>

    <script>
        function openEditModal() {
            clearMessages();
            document.getElementById('editProfileModal').classList.add('show');
        }

        function closeEditModal() {
            document.getElementById('editProfileModal').classList.remove('show');
            document.getElementById('editProfileForm').reset();
        }

        function saveProfileChanges() {
            const callsign = document.getElementById('callsign').value.trim();
            const email = document.getElementById('email').value.trim();
           
            

            // Build the request body with only non-empty fields
            const body = {};
            if (callsign) body.callsign = callsign;
            if (email) body.email = email;
           

            // If nothing is filled, show error
            if (Object.keys(body).length === 0) {
                showError('Please fill in at least one field to update');
                return;
            }

            fetch('/api/profile/update', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(body)
            })
            .then(response => {
                if (!response.ok) {
                    return response.json().then(data => {
                        throw new Error(data.error || 'Failed to update profile');
                    });
                }
                return response.json();
            })
            .then(() => {
                showSuccess('Profile updated successfully!');
                setTimeout(() => {
                    closeEditModal();
                    location.reload(); // Reload to show updated info
                }, 1500);
            })
            .catch(error => {
                showError('Error updating profile: ' + error.message);
            });
        }

        function showSuccess(message) {
            const messageEl = document.getElementById('successMessage');
            messageEl.textContent = message;
            messageEl.classList.add('show');
        }

        function showError(message) {
            const messageEl = document.getElementById('errorMessage');
            messageEl.textContent = message;
            messageEl.classList.add('show');
        }

        function clearMessages() {
            document.getElementById('successMessage').classList.remove('show');
            document.getElementById('errorMessage').classList.remove('show');
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('editProfileModal');
            if (event.target === modal) {
                modal.classList.remove('show');
            }
        }
    </script>
</body>
</html>
