<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="author" content="Caleb Thomas (TheRavenSeb)">
    <meta name="description" content="User Profile - View and manage your account information.">
    <meta name="keywords" content="Profile, User Account, Aviation, VTOL VR">
    <title>User Profile</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1e1e2e 0%, #2d2d44 100%);
            color: #e0e0e0;
            min-height: 100vh;
            display: flex;
            flex-direction: row;
            padding: 0;
            margin: 0;
            line-height: 1.6;
            overflow-x: hidden;
        }

        .sidebar {
            width: 280px;
            background-color: #2a2a2a;
            border-right: 1px solid #444;
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 25px;
            overflow-y: auto;
            position: fixed;
            left: 0;
            top: 0;
            height: 100vh;
            z-index: 999;
            transition: transform 0.3s ease-in-out;
        }

        .sidebar.hidden {
            transform: translateX(-100%);
        }

        .sidebar-logo {
            width: 120px;
            height: 120px;
            background-color: #e0e0e0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
            color: #2a2a2a;
        }

        .sidebar-logo img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
        }

        .sidebar-title {
            text-align: center;
            color: #e0e0e0;
            font-size: 1.3em;
            font-weight: bold;
            line-height: 1.3;
        }

        .sidebar-title a {
            color: #e0e0e0;
            text-decoration: none;
        }

        .sidebar-title a:hover {
            color: #667eea;
        }

        .sidebar-menu {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .sidebar-menu-item {
            padding: 12px 16px;
            color: #b0b0b0;
            text-decoration: none;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
            text-align: left;
            font-size: 0.95em;
        }

        .sidebar-menu-item:hover {
            background-color: #3a3a3a;
            color: #e0e0e0;
        }

        .sidebar-menu-item.active {
            background-color: #667eea;
            color: #ffffff;
        }

        .sidebar-login-btn {
            width: 100%;
            padding: 12px 16px;
            background-color: #667eea;
            color: white;
            text-decoration: none;
            border-radius: 6px;
            text-align: center;
            font-weight: bold;
            transition: all 0.2s;
        }

        .sidebar-login-btn:hover {
            background-color: #5569d8;
        }

        .close-sidebar-btn {
            display: none;
            position: absolute;
            top: 15px;
            right: 15px;
            background: none;
            border: none;
            color: #e0e0e0;
            font-size: 28px;
            cursor: pointer;
            padding: 0;
            width: 30px;
            height: 30px;
            z-index: 1002;
        }

        .close-sidebar-btn:hover {
            color: #667eea;
        }

        .main-content {
            width: calc(100% - 280px);
            margin-left: 280px;
        }

        header {
            background: rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(10px);
            padding: 15px 0;
            border-bottom: 1px solid rgba(102, 126, 234, 0.3);
            position: relative;
            width: 100%;
        }

        nav {
            max-width: 1200px;
            max-height: 100%;
            margin: 0 auto;
            padding: 0 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 100%;
        }

        .logo {
            font-size: 1.5em;
            font-weight: bold;
            color: #667eea;
            text-decoration: none;
            display: flex;
            align-items: center;
        }

        .logo img {
            height: 40px;
            width: 40px;
            object-fit: contain;
            margin-right: 10px;
        }

        .hamburger-btn {
            display: none;
            background: none;
            border: none;
            color: #e0e0e0;
            font-size: 1.5em;
            cursor: pointer;
            padding: 10px 0;
            margin-right: 15px;
            transition: all 0.2s;
        }

        .hamburger-btn:hover {
            color: #667eea;
        }

        .hamburger-btn.active {
            color: #667eea;
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            overflow-y: auto;
            width: calc(100% - 280px);
            margin-left: 280px;
        }

        .sidebar {
            width: 280px;
            background-color: #2a2a2a;
            border-right: 1px solid #444;
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 25px;
            overflow-y: auto;
            flex-shrink: 0;
            position: fixed;
            left: 0;
            top: 0;
            height: 100vh;
            z-index: 999;
            transition: transform 0.3s ease-in-out;
        }

        .sidebar.hidden {
            transform: translateX(-100%);
        }

        .close-sidebar-btn {
            display: none;
            position: absolute;
            top: 15px;
            right: 15px;
            background: none;
            border: none;
            color: #e0e0e0;
            font-size: 28px;
            cursor: pointer;
            padding: 0;
            width: 30px;
            height: 30px;
            z-index: 1002;
        }

        .close-sidebar-btn:hover {
            color: #667eea;
        }

        .sidebar-logo img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
        }

        .sidebar-logo {
            width: 120px;
            height: 120px;
            background-color: #e0e0e0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
            color: #2a2a2a;
        }

        .sidebar-title {
            text-align: center;
            color: #e0e0e0;
            font-size: 1.3em;
            font-weight: bold;
            line-height: 1.3;
        }

        .sidebar-title a {
            color: #e0e0e0;
            text-decoration: none;
        }

        .sidebar-title a:hover {
            color: #667eea;
        }

        .sidebar-menu {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .sidebar-menu-item {
            padding: 12px 16px;
            color: #b0b0b0;
            text-decoration: none;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
            text-align: left;
            font-size: 0.95em;
            display: block;
        }

        .sidebar-menu-item:hover {
            background-color: #3a3a3a;
            color: #e0e0e0;
        }

        .sidebar-menu-item.active {
            background-color: #667eea;
            color: #ffffff;
        }

        .sidebar-login-btn {
            width: 100%;
            padding: 12px 16px;
            background-color: #667eea;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.95em;
            margin-top: auto;
            transition: all 0.2s;
        }

        .sidebar-login-btn:hover {
            background-color: #5569d8;
        }

        header {
            text-align: center;
            color: #e0e0e0;
            margin-bottom: 40px;
            padding-top: 20px;
        }

        header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
        }

        header p {
            font-size: 1.1em;
            opacity: 0.9;
        }

        .container {
            display: flex;
            justify-content: center;
            width: 100%;
            max-width: 800px;
        }

        .profile-card {
            background: #333;
            border-radius: 12px;
            padding: 40px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            width: 100%;
        }

        .profile-header {
            display: flex;
            align-items: center;
            gap: 30px;
            margin-bottom: 40px;
            padding-bottom: 30px;
            border-bottom: 2px solid #444;
        }

        .profile-avatar {
            width: 120px;
            height: 120px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 50px;
            color: white;
            flex-shrink: 0;
        }

        .profile-info {
            flex: 1;
        }

        .profile-username {
            font-size: 1.8em;
            font-weight: bold;
            color: #e0e0e0;
            margin-bottom: 10px;
        }

        .profile-status {
            display: inline-block;
            padding: 4px 12px;
            background-color: #4CAF50;
            color: white;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: 600;
        }

        .profile-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-bottom: 30px;
        }

        .detail-section {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .detail-item {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .detail-label {
            font-size: 0.9em;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .detail-value {
            font-size: 1.1em;
            color: #e0e0e0;
            font-weight: 500;
        }

        .role-badge {
            display: inline-block;
            padding: 6px 12px;
            background-color: #667eea;
            color: white;
            border-radius: 6px;
            font-size: 0.85em;
            margin-right: 8px;
            margin-bottom: 5px;
        }

        .stats-section {
            background-color: #2a2a2a;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 30px;
        }

        .stats-section h3 {
            color: #e0e0e0;
            margin-bottom: 20px;
            font-size: 1.2em;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .stat-card {
            background-color: #333;
            padding: 15px;
            border-radius: 6px;
            border-left: 4px solid #667eea;
        }

        .stat-value {
            font-size: 1.8em;
            font-weight: bold;
            color: #667eea;
        }

        .stat-label {
            font-size: 0.9em;
            color: #999;
            margin-top: 5px;
        }

        .action-buttons {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }

        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1em;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
            text-align: center;
        }

        .btn-primary {
            background-color: #667eea;
            color: white;
        }

        .btn-primary:hover {
            background-color: #5569d8;
        }

        .btn-secondary {
            background-color: #444;
            color: #e0e0e0;
            border: 1px solid #667eea;
        }

        .btn-secondary:hover {
            background-color: #555;
        }

        .not-logged-in {
            text-align: center;
            padding: 40px 20px;
        }

        .not-logged-in h2 {
            color: #e0e0e0;
            margin-bottom: 20px;
        }

        .not-logged-in p {
            color: #999;
            margin-bottom: 30px;
        }

        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.7);
        }

        .modal.show {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background-color: #2a2a2a;
            padding: 30px;
            border-radius: 12px;
            max-width: 500px;
            max-height: 80vh;
            overflow-y: auto;
            color: #e0e0e0;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            border-bottom: 2px solid #667eea;
            padding-bottom: 15px;
        }

        .modal-header h2 {
            margin: 0;
            font-size: 1.5em;
        }

        .modal-close {
            background: none;
            border: none;
            color: #e0e0e0;
            font-size: 28px;
            cursor: pointer;
            padding: 0;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-close:hover {
            color: #667eea;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            color: #e0e0e0;
            font-weight: bold;
            margin-bottom: 8px;
        }

        .form-input {
            width: 100%;
            padding: 10px;
            background-color: #333;
            border: 1px solid #667eea;
            border-radius: 6px;
            color: #e0e0e0;
            font-size: 1em;
        }

        .form-input:focus {
            outline: none;
            border-color: #7f9eff;
            box-shadow: 0 0 8px rgba(102, 126, 234, 0.3);
        }

        .form-input::placeholder {
            color: #888;
        }

        .button-group {
            display: flex;
            gap: 10px;
            margin-top: 25px;
        }

        .btn-save {
            flex: 1;
            padding: 12px;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 1em;
            font-weight: bold;
            transition: all 0.2s;
        }

        .btn-save:hover {
            background-color: #45a049;
        }

        .btn-cancel {
            flex: 1;
            padding: 12px;
            background-color: #555;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 1em;
            font-weight: bold;
            transition: all 0.2s;
        }

        .btn-cancel:hover {
            background-color: #666;
        }

        .success-message {
            background-color: #4CAF50;
            color: white;
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 20px;
            display: none;
        }

        .success-message.show {
            display: block;
        }

        .error-message {
            background-color: #f44336;
            color: white;
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 20px;
            display: none;
        }

        .error-message.show {
            display: block;
        }

        footer {
            color: white;
            margin-top: 40px;
            text-align: center;
            opacity: 0.8;
        }

        @media (max-width: 1024px) {
            .main-content {
                width: calc(100% - 250px);
                padding: 15px;
            }

            .sidebar {
                width: 250px;
            }

            header h1 {
                font-size: 2em;
            }
        }

        @media (max-width: 768px) {
            body {
                flex-direction: column;
            }

            .main-content {
                width: 100%;
                margin-left: 0;
                padding: 15px;
                padding-top: 0;
            }

            .sidebar {
                width: 250px;
                height: auto;
                position: fixed;
                top: 0;
                left: 0;
                transform: translateX(-100%);
                padding: 70px 20px 20px 20px;
                z-index: 1001;
                max-height: 100vh;
                overflow-y: auto;
                border-right: 1px solid #444;
                transition: transform 0.3s ease-in-out;;
            }

            .sidebar.active {
                transform: translateX(0);
            }

            .close-sidebar-btn {
                display: block;
            }

            .hamburger-btn {
                display: block;
            }

            .container {
                max-width: 100%;
            }

            header {
                text-align: left;
                margin-bottom: 20px;
                padding-top: 10px;
            }

            header h1 {
                font-size: 1.8em;
                margin-bottom: 5px;
            }

            header p {
                font-size: 0.95em;
            }

            .profile-header {
                flex-direction: column;
                gap: 20px;
                align-items: center;
                text-align: center;
            }

            .profile-avatar {
                width: 100px;
                height: 100px;
                font-size: 40px;
            }

            .profile-details {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }

            .action-buttons {
                flex-direction: column;
                gap: 10px;
            }

            .btn {
                width: 100%;
            }

            .profile-card {
                padding: 20px;
                width: 100%;
            }

            .modal-content {
                padding: 20px;
                margin: 10px;
                max-width: 90%;
                width: calc(100% - 20px);
            }

            .btn-primary, .btn-secondary {
                padding: 12px 16px;
                font-size: 0.95em;
            }

            nav {
                width: 100%;
                padding: 0 10px;
            }
        }

        @media (max-width: 480px) {
            .main-content {
                padding: 12px;
                padding-top: 0;
            }

            body {
                padding: 0;
            }

            .profile-card {
                padding: 15px;
                width: 100%;
            }

            .profile-username {
                font-size: 1.4em;
                margin-bottom: 8px;
            }

            .profile-status {
                padding: 3px 10px;
                font-size: 0.8em;
            }

            .detail-label {
                font-size: 0.75em;
                letter-spacing: 0.3px;
            }

            .detail-value {
                font-size: 0.9em;
            }

            .sidebar-logo {
                width: 80px;
                height: 80px;
                font-size: 40px;
                margin-bottom: 10px;
            }

            .sidebar-title {
                font-size: 1em;
                line-height: 1.2;
                margin-bottom: 15px;
            }

            .sidebar-menu-item {
                width: 100%;
                padding: 12px 14px;
                font-size: 0.9em;
            }

            .sidebar-login-btn {
                padding: 10px 14px;
                font-size: 0.9em;
            }

            header {
                margin-bottom: 15px;
                padding-top: 8px;
            }

            header h1 {
                font-size: 1.4em;
                margin-bottom: 5px;
            }

            header p {
                font-size: 0.8em;
            }

            nav {
                padding: 0 8px;
            }

            .logo {
                font-size: 1.2em;
            }

            .logo img {
                height: 35px;
                width: 35px;
                margin-right: 8px;
            }

            .profile-avatar {
                width: 85px;
                height: 85px;
                font-size: 35px;
            }

            .profile-header {
                margin-bottom: 25px;
                gap: 15px;
            }

            .profile-details {
                margin-bottom: 20px;
            }

            .stats-section {
                padding: 15px;
                margin-bottom: 20px;
            }

            .stats-section h3 {
                margin-bottom: 15px;
                font-size: 1.1em;
            }

            .stat-card {
                padding: 12px;
            }

            .stat-value {
                font-size: 1.5em;
            }

            .stat-label {
                font-size: 0.8em;
            }

            .role-badge {
                padding: 4px 8px;
                font-size: 0.75em;
                margin-right: 6px;
                margin-bottom: 4px;
            }

            .action-buttons {
                flex-direction: column;
                gap: 8px;
                margin-top: 20px;
            }

            .btn {
                padding: 11px 16px;
                font-size: 0.9em;
                width: 100%;
            }

            .modal-content {
                padding: 15px;
                width: calc(100% - 30px);
                margin: 15px;
                border-radius: 10px;
            }

            .modal-header h2 {
                font-size: 1.2em;
            }

            .form-group {
                margin-bottom: 15px;
            }

            .form-label {
                font-size: 0.85em;
                margin-bottom: 6px;
            }

            .form-input {
                padding: 12px;
                font-size: 16px;
                border-radius: 5px;
            }

            .btn-save,
            .btn-cancel {
                padding: 11px;
                font-size: 0.9em;
                width: 100%;
                margin: 0;
            }

            .button-group {
                gap: 8px;
                flex-direction: column;
            }

            footer {
                margin-top: 25px;
                font-size: 0.8em;
            }
        }

        @media (max-width: 360px) {
            .profile-card {
                padding: 12px;
            }

            header h1 {
                font-size: 1.2em;
            }

            header p {
                font-size: 0.75em;
            }

            .profile-username {
                font-size: 1.2em;
            }

            .profile-avatar {
                width: 75px;
                height: 75px;
                font-size: 30px;
            }

            .modal-content {
                padding: 12px;
                width: calc(100% - 24px);
                margin: 12px;
            }

            .sidebar-logo {
                width: 70px;
                height: 70px;
                font-size: 35px;
                margin-bottom: 8px;
            }

            .sidebar-title {
                font-size: 0.95em;
                margin-bottom: 12px;
            }

            .sidebar-menu-item {
                padding: 10px 12px;
                font-size: 0.85em;
            }

            .detail-value {
                font-size: 0.85em;
            }

            .stat-value {
                font-size: 1.3em;
            }
        }
    </style>
</head>
<body>
    <div class="sidebar" id="sidebar">
        <button type="button" class="close-sidebar-btn" id="closeSidebarBtn" onclick="closeSidebar()" aria-label="Close sidebar">✕</button>
        <div class="sidebar-logo"><img src="/assets/logo.png" alt="Logo"></div>
        <div class="sidebar-title"><a href="/">Aviation Realism<br>Network</a></div>
        <div class="sidebar-menu">
            <a class="sidebar-menu-item active" href="/profile">Profile</a>
            <a class="sidebar-menu-item" href="/announcements">Announcements</a>
            <a class="sidebar-menu-item" href="/pilots">Pilots</a>
            <a class="sidebar-menu-item" href="/applications">Applications</a>
            <a class="sidebar-menu-item" href="/information">Information</a>
        </div>
        <a href="/logout" class="sidebar-login-btn">Logout</a>
    </div>

    <div class="main-content">
        <header>
            <nav>
                <button class="hamburger-btn" id="hamburgerBtn" onclick="toggleSidebar()" aria-label="Toggle menu">☰</button>
                <a href="/" class="logo"><img src="/assets/logo.png" alt="ARN Logo">ARN</a>
            </nav>
        </header>
        <header>
            <h1>User Profile</h1>
            <p>View and manage your account information</p>
        </header>

        <div class="container">
            <% if (user) { %>
                <div class="profile-card">
                    <div class="profile-header">
                        <div class="profile-avatar">👤</div>
                        <div class="profile-info">
                            <div class="profile-username"><%= user.username %></div>
                            <span class="profile-status">Active</span>
                        </div>
                    </div>

                    <div class="profile-details">
                        <div class="detail-section">
                            <div class="detail-item">
                                <span class="detail-label">Username</span>
                                <span class="detail-value"><%= user.username %></span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Flight Hours</span>
                                <span class="detail-value"><%= user.flighthours %></span>
                            </div>
                        </div>
                        <div class="detail-section">
                            <div class="detail-item">
                                <span class="detail-label">Account Status</span>
                                <span class="detail-value">Verified</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Member Since</span>
                                <span class="detail-value">2026</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Account Code</span>
                                <span class="detail-value"><%= user.code %></span>
                            </div>
                        </div>
                    </div>

                    <div class="stats-section">
                        <h3>Account Roles</h3>
                        <div>
                            <% if (user.role && user.role.length > 0) { %>
                                <% user.role.forEach(role => { %>
                                    <span class="role-badge"><%= role.toUpperCase() %></span>
                                <% }); %>
                            <% } else { %>
                                <span class="role-badge">USER</span>
                            <% } %>
                        </div>
                    </div>

                    <div class="stats-section">
                        <h3>Statistics</h3>
                        <div class="stats-grid">
                            <div class="stat-card">
                                <div class="stat-value"><%= user.flighthours %></div>
                                <div class="stat-label">Flight Hours</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-value"><%= user.role.length %></div>
                                <div class="stat-label">Active Roles</div>
                            </div>
                        </div>
                    </div>

                    <div class="action-buttons">
                        <button class="btn btn-primary" onclick="openEditModal()">Edit Profile</button>
                        <a href="/logout" class="btn btn-secondary">Logout</a>
                    </div>
                </div>
            <% } else { %>
                <div class="profile-card not-logged-in">
                    <h2>Not Logged In</h2>
                    <p>You need to be logged in to view your profile.</p>
                    <a href="/login" class="btn btn-primary">Login</a>
                </div>
            <% } %>
        </div>

        <div id="editProfileModal" class="modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h2>Edit Profile</h2>
                    <button class="modal-close" onclick="closeEditModal()">&times;</button>
                </div>

                <div id="successMessage" class="success-message"></div>
                <div id="errorMessage" class="error-message"></div>

                <form id="editProfileForm">
                    <div class="form-group">
                        <label class="form-label">Callsign (e.g., N123C)</label>
                        <input type="text" class="form-input" id="callsign" placeholder="N123C" maxlength="5" style="text-transform: uppercase;">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-input" id="email" placeholder="Enter your email address">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Discord ID</label>
                        <input type="text" class="form-input" id="discordId" placeholder="Enter your Discord ID">
                    </div>

                    

                    <div class="button-group">
                        <button type="button" class="btn-save" onclick="saveProfileChanges()">Save Changes</button>
                        <button type="button" class="btn-cancel" onclick="closeEditModal()">Cancel</button>
                    </div>
                </form>
            </div>
        </div>

        <footer>
            <p>&copy; 2026 Aviation Realism Network. All rights reserved.</p>
        </footer>
    </div>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const hamburgerBtn = document.getElementById('hamburgerBtn');
            sidebar.classList.toggle('active');
            hamburgerBtn.classList.toggle('active');
            // Show close button when sidebar is active
            const closeBtn = document.getElementById('closeSidebarBtn');
            if (sidebar.classList.contains('active')) {
                closeBtn.style.display = 'block';
            } else {
                closeBtn.style.display = 'none';
            }
        }

        // Close sidebar when menu item is clicked on mobile
        document.addEventListener('DOMContentLoaded', function() {
            const sidebarMenuItems = document.querySelectorAll('.sidebar-menu-item');
            sidebarMenuItems.forEach(item => {
                item.addEventListener('click', function() {
                    if (window.innerWidth <= 768) {
                        const sidebar = document.getElementById('sidebar');
                        const hamburgerBtn = document.getElementById('hamburgerBtn');
                        const closeBtn = document.getElementById('closeSidebarBtn');
                        sidebar.classList.remove('active');
                        hamburgerBtn.classList.remove('active');
                        closeBtn.style.display = 'none';
                    }
                });
            });
        });

        function closeSidebar() {
            const sidebar = document.getElementById('sidebar');
            const hamburgerBtn = document.getElementById('hamburgerBtn');
            const closeBtn = document.getElementById('closeSidebarBtn');
            sidebar.classList.remove('active');
            hamburgerBtn.classList.remove('active');
            closeBtn.style.display = 'none';
        }

        // Close sidebar when clicking outside
        window.addEventListener('click', function(event) {
            const sidebar = document.getElementById('sidebar');
            const hamburgerBtn = document.getElementById('hamburgerBtn');
            if (sidebar.classList.contains('active') && !sidebar.contains(event.target) && event.target !== hamburgerBtn) {
                closeSidebar();
            }
        });

        function openEditModal() {
            clearMessages();
            document.getElementById('editProfileModal').classList.add('show');
        }

        function closeEditModal() {
            document.getElementById('editProfileModal').classList.remove('show');
            document.getElementById('editProfileForm').reset();
        }

        function saveProfileChanges() {
            const callsign = document.getElementById('callsign').value.trim();
            const email = document.getElementById('email').value.trim();
            const discordId = document.getElementById('discordId').value.trim();
            

            // Build the request body with only non-empty fields
            const body = {};
            if (callsign) body.callsign = callsign;
            if (email) body.email = email;
            if (discordId) body.discordId = discordId;
           

            // If nothing is filled, show error
            if (Object.keys(body).length === 0) {
                showError('Please fill in at least one field to update');
                return;
            }

            fetch('/api/profile/update', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(body)
            })
            .then(response => {
                if (!response.ok) {
                    return response.json().then(data => {
                        throw new Error(data.error || 'Failed to update profile');
                    });
                }
                return response.json();
            })
            .then(data => {
                showSuccess('Profile updated successfully!');
                setTimeout(() => {
                    closeEditModal();
                    location.reload(); // Reload to show updated info
                }, 1500);
            })
            .catch(error => {
                console.error('Error updating profile:', error);
                showError('Error updating profile: ' + error.message);
            });
        }

        function showSuccess(message) {
            const messageEl = document.getElementById('successMessage');
            messageEl.textContent = message;
            messageEl.classList.add('show');
        }

        function showError(message) {
            const messageEl = document.getElementById('errorMessage');
            messageEl.textContent = message;
            messageEl.classList.add('show');
        }

        function clearMessages() {
            document.getElementById('successMessage').classList.remove('show');
            document.getElementById('errorMessage').classList.remove('show');
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('editProfileModal');
            if (event.target === modal) {
                modal.classList.remove('show');
            }
        }
    </script>
</body>
</html>
