<style>
    .sidebar-overlay {
        display: none;
    }
    
    .mobile-top-bar {
        display: none !important;
    }

    @media (max-width: 768px) {
        .mobile-top-bar {
            display: flex !important;
        }
    }

    /* flatten the folder boxes so they match the sidebar vibe */
    .sidebar-folder {
        border: none !important;
        border-radius: 0 !important;
        background: transparent !important;
    }

    .sidebar-folder + .sidebar-folder {
        margin-top: 0 !important;
        padding-top: 4px !important;
        border-top: 1px solid var(--line) !important;
    }

    .sidebar-folder-title {
        color: rgba(245, 243, 239, 0.38) !important;
        font-size: 0.68rem !important;
        letter-spacing: 0.1em !important;
        padding: 6px 4px !important;
        border-bottom: none !important;
    }

    .sidebar-folder-title::marker,
    .sidebar-folder-title::-webkit-details-marker {
        display: none !important;
    }

    .sidebar-folder[open] .sidebar-folder-title {
        border-bottom: none !important;
    }

    .sidebar-folder-items {
        padding: 2px 0 6px !important;
        gap: 2px !important;
    }
</style>

<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<div class="mobile-top-bar">
    <button class="hamburger-btn" id="hamburgerBtn" onclick="toggleSidebar()" aria-label="Open menu">☰</button>
    <a href="/" class="mobile-brand">
        <img src="/assets/logo.png" alt="ARN Logo">
        <span>ARN</span>
    </a>
</div>

