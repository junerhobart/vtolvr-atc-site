<% if (!locals.isProduction) { %>
<%- include('./client-ui-mock') %>
<% } %>

<script>
    function toggleSidebar() {
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay') || document.getElementById('overlay');
        const btn = document.getElementById('hamburgerBtn');
        const isOpen = sidebar.classList.toggle('active');
        if (overlay) overlay.classList.toggle('active', isOpen);
        if (btn) btn.classList.toggle('active', isOpen);
    }

    function closeSidebar() {
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay') || document.getElementById('overlay');
        const btn = document.getElementById('hamburgerBtn');
        sidebar.classList.remove('active');
        if (overlay) overlay.classList.remove('active');
        if (btn) btn.classList.remove('active');
    }

    document.addEventListener('DOMContentLoaded', function () {
        const folderStateUser = '<%= locals.user ? (locals.user._id || locals.user.id || locals.user.username || locals.user.discordId || "user") : "guest" %>';
        const folderStateKey = 'arn:folder-state:' + folderStateUser;

        function loadFolderState() {
            try {
                const parsed = JSON.parse(localStorage.getItem(folderStateKey) || '{}');
                return (parsed && typeof parsed === 'object') ? parsed : {};
            } catch (_) {
                return {};
            }
        }

        function saveFolderState(state) {
            try {
                localStorage.setItem(folderStateKey, JSON.stringify(state));
            } catch (_) {
                // ignore storage errors
            }
        }

        const folderState = loadFolderState();
        const allFolders = Array.from(document.querySelectorAll('details[data-folder]'));

        allFolders.forEach(function (folder) {
            const folderId = folder.dataset.folder;
            if (!folderId) return;
            if (Object.prototype.hasOwnProperty.call(folderState, folderId)) {
                folder.open = !!folderState[folderId];
            }
        });

        allFolders.forEach(function (folder) {
            folder.addEventListener('toggle', function () {
                const folderId = folder.dataset.folder;
                if (!folderId) return;

                folderState[folderId] = folder.open;
                saveFolderState(folderState);

                allFolders.forEach(function (other) {
                    if (other === folder) return;
                    if (other.dataset.folder !== folderId) return;
                    other.open = folder.open;
                });
            });
        });

        document.querySelectorAll('.sidebar-menu-item, .sidebar-auth-item').forEach(function (link) {
            link.addEventListener('click', function () {
                if (window.innerWidth <= 768) closeSidebar();
            });
        });

        document.querySelectorAll('.top-nav-desktop details').forEach(function (dropdown) {
            dropdown.addEventListener('toggle', function () {
                if (!dropdown.open) return;
                document.querySelectorAll('.top-nav-desktop details').forEach(function (other) {
                    if (other !== dropdown) other.open = false;
                });
            });
        });

        window.addEventListener('resize', function () {
            if (window.innerWidth > 768) closeSidebar();
        });

        var _rp = new URLSearchParams(window.location.search).get('redirect');
        var _back = _rp;
        if (!_back) {
            var _p = window.location.pathname;
            if (_p === '/login' || _p === '/register' || _p === '/forgot-password') _back = '/';
            else _back = window.location.pathname + window.location.search + window.location.hash;
        }
        var _enc = encodeURIComponent(_back);
        document.querySelectorAll('a[href="/login"]').forEach(function (el) { el.href = '/login?redirect=' + _enc; });
        document.querySelectorAll('a[href="/register"]').forEach(function (el) { el.href = '/register?redirect=' + _enc; });
    });
</script>
