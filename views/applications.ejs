<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="author" content="Caleb Thomas (TheRavenSeb)">
    <meta name="description" content="Apply to become an ATC Controller or Enforcer for the Aviation Realism Network.">
    <meta name="keywords" content="Applications, ATC, Enforcer, Aviation, Discord, Vtol VR">
    <title>Submit Application</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background-color: #1e1e1e;
            color: #e0e0e0;
            min-height: 100vh;
            display: flex;
            flex-direction: row;
            padding: 0;
            margin: 0;
            overflow-x: hidden;
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            overflow-y: auto;
            width: calc(100% - 280px);
        }

        .sidebar {
            width: 280px;
            background-color: #2a2a2a;
            border-right: 1px solid #444;
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 25px;
            overflow-y: auto;
            position: fixed;
            left: 0;
            top: 0;
            height: 100vh;
            z-index: 999;
            transition: transform 0.3s ease-in-out;
        }

        .sidebar.hidden {
            transform: translateX(-100%);
        }

        .close-sidebar-btn {
            display: none;
            position: absolute;
            top: 15px;
            right: 15px;
            background: none;
            border: none;
            color: #e0e0e0;
            font-size: 28px;
            cursor: pointer;
            padding: 0;
            width: 30px;
            height: 30px;
            z-index: 1002;
        }

        .close-sidebar-btn:hover {
            color: #667eea;
        }

        .hamburger-btn {
            display: none;
            background: none;
            border: none;
            color: #e0e0e0;
            font-size: 1.5em;
            cursor: pointer;
            padding: 10px 0;
            margin-bottom: 20px;
            transition: all 0.2s;
            margin-right: 15px;
        }

        .hamburger-btn:hover {
            color: #667eea;
        }

        .hamburger-btn.active {
            color: #667eea;
        }

        .header-top {
            width: 100%;
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 20px;
        }

        .sidebar-logo {
            width: 120px;
            height: 120px;
            background-color: #e0e0e0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
            color: #2a2a2a;
        }

        .sidebar-title {
            text-align: center;
            color: #e0e0e0;
            font-size: 1.3em;
            font-weight: bold;
            line-height: 1.3;
        }

        .sidebar-title a {
            color: #e0e0e0;
            text-decoration: none;
        }

        .sidebar-title a:hover {
            color: #667eea;
        }

        .sidebar-menu {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .sidebar-menu-item {
            padding: 12px 16px;
            color: #b0b0b0;
            text-decoration: none;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
            text-align: left;
            font-size: 0.95em;
        }

        .sidebar-menu-item:hover {
            background-color: #3a3a3a;
            color: #e0e0e0;
        }

        .sidebar-menu-item.active {
            background-color: #667eea;
            color: #ffffff;
        }

        header {
            text-align: center;
            color: #e0e0e0;
            margin-bottom: 40px;
            padding-top: 20px;
        }

        header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
        }

        header p {
            font-size: 1.1em;
            opacity: 0.9;
        }

        .container {
            display: flex;
            gap: 30px;
            max-width: 1200px;
            width: 100%;
            flex-wrap: wrap;
            justify-content: center;
        }

        .applications-panel {
            background: #333;
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            display: flex;
            flex-direction: column;
            gap: 20px;
            flex: 1;
            min-width: 400px;
            max-width: 600px;
            width: 100%;
        }

        .applications-panel h2 {
            color: #e0e0e0;
            font-size: 1.5em;
            margin: 0;
            border-bottom: 2px solid #667eea;
            padding-bottom: 10px;
        }

        .application-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .application-item {
            background: #2a2a2a;
            border-left: 4px solid #667eea;
            padding: 15px;
            border-radius: 6px;
            transition: all 0.2s;
        }

        .application-item:hover {
            background: #3a3a3a;
        }

        .application-item.pending {
            border-left-color: #ffa500;
        }

        .application-item.approved {
            border-left-color: #4CAF50;
        }

        .application-item.rejected {
            border-left-color: #f44336;
        }

        .application-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .applicant-name {
            color: #e0e0e0;
            font-weight: bold;
            font-size: 1.1em;
        }

        .application-status {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: bold;
        }

        .status-pending {
            background-color: #ffa500;
            color: #000;
        }

        .status-approved {
            background-color: #4CAF50;
            color: #fff;
        }

        .status-rejected {
            background-color: #f44336;
            color: #fff;
        }

        .application-position {
            color: #b0b0b0;
            font-size: 0.95em;
            margin-bottom: 5px;
        }

        .application-date {
            color: #888;
            font-size: 0.85em;
        }

        .application-actions {
            display: flex;
            gap: 8px;
            margin-top: 10px;
        }

        .action-btn {
            padding: 6px 12px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.85em;
            transition: all 0.2s;
        }

        .view-btn {
            background-color: #667eea;
            color: white;
        }

        .view-btn:hover {
            background-color: #5568d3;
        }

        .approve-btn {
            background-color: #4CAF50;
            color: white;
        }

        .approve-btn:hover {
            background-color: #45a049;
        }

        .reject-btn {
            background-color: #f44336;
            color: white;
        }

        .reject-btn:hover {
            background-color: #da190b;
        }

        .empty-state {
            text-align: center;
            color: #888;
            padding: 40px 20px;
        }

        .empty-state p {
            font-size: 1.1em;
        }

        footer {
            color: white;
            margin-top: 40px;
            text-align: center;
            opacity: 0.8;
        }

        @media (max-width: 768px) {
            .container {
                flex-direction: column;
                align-items: center;
            }

            header h1 {
                font-size: 1.8em;
            }

            .applications-panel {
                min-width: 100%;
                max-width: 100%;
            }
        }

        @media (max-width: 480px) {
            .application-item {
                padding: 12px;
            }

            .action-btn {
                padding: 4px 8px;
                font-size: 0.75em;
            }
        }

        .position-selection {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .position-btn {
            flex: 1;
            min-width: 200px;
            padding: 30px;
            background-color: #2a2a2a;
            border: 2px solid #444;
            border-radius: 8px;
            color: #e0e0e0;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            font-size: 1.1em;
        }

        .position-btn:hover {
            background-color: #3a3a3a;
            border-color: #667eea;
            transform: translateY(-2px);
        }

        .position-btn.active {
            background-color: #667eea;
            border-color: #667eea;
        }

        .position-icon {
            font-size: 2.5em;
        }

        .position-name {
            font-weight: bold;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: bold;
            color: #e0e0e0;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 10px;
            background-color: #2a2a2a;
            border: 1px solid #444;
            border-radius: 4px;
            color: #e0e0e0;
            font-family: Arial, sans-serif;
            font-size: 1em;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #667eea;
            background-color: #323232;
        }

        .form-actions {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-top: 30px;
        }

        .form-actions button {
            min-width: 150px;
        }

        @media (max-width: 1024px) {
            .main-content {
                width: 100%;
                padding: 15px;
            }

            header h1 {
                font-size: 2em;
            }
        }

        @media (max-width: 768px) {
            body {
                flex-direction: column;
            }

            .hamburger-btn {
                display: block;
            }

            .main-content {
                width: 100%;
                padding: 15px;
                padding-top: 0;
            }

            .sidebar {
                width: 250px;
                height: auto;
                position: fixed;
                top: 0;
                left: 0;
                transform: translateX(-100%);
                padding: 70px 20px 20px 20px;
                z-index: 1001;
                max-height: 100vh;
                overflow-y: auto;
                border-right: 1px solid #444;
                transition: transform 0.3s ease-in-out;
            }

            .sidebar.active {
                transform: translateX(0);
            }

            .close-sidebar-btn {
                display: block;
            }

            header h1 {
                font-size: 1.8em;
            }

            header p {
                font-size: 0.95em;
            }

            .applications-panel {
                min-width: 100%;
                max-width: 100%;
                padding: 20px;
            }

            .position-btn {
                min-width: 150px;
                padding: 20px;
                font-size: 0.95em;
            }

            .position-icon {
                font-size: 2em;
            }

            .form-group input,
            .form-group textarea {
                font-size: 16px;
                padding: 12px;
            }

            .form-actions {
                flex-direction: column;
                gap: 12px;
            }

            .form-actions button {
                width: 100%;
                min-width: auto;
            }
        }

        @media (max-width: 480px) {
            .application-item {
                padding: 12px;
            }

            .action-btn {
                padding: 4px 8px;
                font-size: 0.75em;
            }

            header h1 {
                font-size: 1.5em;
                margin-bottom: 5px;
            }

            header p {
                font-size: 0.85em;
            }

            .applications-panel {
                padding: 15px;
                border-radius: 8px;
            }

            .applications-panel h2 {
                font-size: 1.2em;
            }

            .position-btn {
                min-width: 100%;
                padding: 20px 15px;
                font-size: 0.9em;
            }

            .position-icon {
                font-size: 1.8em;
            }

            .position-selection {
                flex-direction: column;
                gap: 15px;
            }

            .form-group {
                margin-bottom: 18px;
            }

            .form-group label {
                font-size: 0.95em;
                margin-bottom: 6px;
            }

            .form-group input,
            .form-group textarea {
                font-size: 16px;
                padding: 12px;
                border-radius: 4px;
            }

            footer {
                font-size: 0.85em;
                margin-top: 30px;
            }
        }
    </style>
</head>
<body>
    <div class="sidebar" id="sidebar">
        <button type="button" class="close-sidebar-btn" id="closeSidebarBtn" onclick="closeSidebar()" aria-label="Close sidebar">✕</button>
        <div class="sidebar-logo"><img src="/assets/logo.png" alt="Logo"></div>
        <div class="sidebar-title"><a href="/">Aviation Realism<br>Network</a></div>
        <div class="sidebar-menu">
            <a class="sidebar-menu-item" href="/profile">Profile</a>
            <a class="sidebar-menu-item" href="/announcements">Announcements</a>
            <a class="sidebar-menu-item" href="/pilots">Pilots</a>
            <a class="sidebar-menu-item active" href="/applications">Applications</a>
            <a class="sidebar-menu-item" href="/information">Information</a>
        </div>
    </div>

    <div class="main-content">
        <div class="header-top">
            <button class="hamburger-btn" id="hamburgerBtn" onclick="toggleSidebar()">☰</button>
        </div>
        <header>
            <h1>Submit Application</h1>
            <p>Apply to become an ATC Controller or Enforcer for the Aviation Realism Network Discord group.</p>
        </header>

        <div class="container">
            <div class="applications-panel">
                <h2>Select Position Type</h2>
                <div class="position-selection">
                    <button class="position-btn" id="atcBtn" onclick="selectPosition('atc')">
                        <span class="position-icon">🎧</span>
                        <span class="position-name">ATC Controller</span>
                    </button>
                    <button class="position-btn" id="enforcerBtn" onclick="selectPosition('enforcer')">
                        <span class="position-icon">🛡️</span>
                        <span class="position-name">Enforcer</span>
                    </button>
                </div>
            </div>

            <div class="applications-panel" id="formPanel" style="display: none;">
                <h2 id="formTitle"></h2>
                <form id="applicationForm">
                    <div class="form-group">
                        <label for="fullName">Username:</label>
                        <input type="text" id="fullName" name="fullName" required>
                    </div>

                    <div class="form-group">
                        <label for="discord">Discord Handle:</label>
                        <input type="text" id="discord" name="discord" placeholder="YourName#1234" required>
                    </div>
                    <div class="form-group">
                        <label for="discordId">Discord ID <a href="https://support.discord.com/hc/en-us/articles/200156798-FAQs-User-IDs-in-Discord" target="_blank" rel="noopener noreferrer">?</a>:</label>
                        <input type="text" id="discordId" name="discordId" placeholder="123456789012345678" required>
                    </div>

                    <div class="form-group" id="callsignGroup" >
                        <label for="callsign">Preferred Callsign:</label>
                        <input type="text" id="callsign" name="callsign" maxlength="20">
                    </div>

                    <div class="form-group">
                        <label for="experience">Previous Experience:</label>
                        <textarea id="experience" name="experience" rows="4" placeholder="Tell us about your experience..."></textarea>
                    </div>

                    <div class="form-group">
                        <label for="whyJoin">Why do you want to join?</label>
                        <textarea id="whyJoin" name="whyJoin" rows="4" placeholder="Tell us why you're interested..." required></textarea>
                    </div>

                    <div class="form-actions">
                        <button type="button" class="action-btn" onclick="resetForm()">Cancel</button>
                        <button type="submit" class="action-btn approve-btn">Submit Application</button>
                    </div>
                </form>
            </div>
        </div>

        <footer>
            <p>&copy; 2026 Aviation Realism Network. All rights reserved.</p>
        </footer>
    </div>

    <script>
        let selectedPosition = null;

        // Toggle sidebar on mobile
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const hamburgerBtn = document.getElementById('hamburgerBtn');
            sidebar.classList.toggle('active');
            hamburgerBtn.classList.toggle('active');
            const closeBtn = document.getElementById('closeSidebarBtn');
            if (sidebar.classList.contains('active')) {
                closeBtn.style.display = 'block';
            } else {
                closeBtn.style.display = 'none';
            }
        }

        // Close sidebar when menu item is clicked on mobile
        document.addEventListener('DOMContentLoaded', function() {
            const sidebarMenuItems = document.querySelectorAll('.sidebar-menu-item');
            sidebarMenuItems.forEach(item => {
                item.addEventListener('click', function() {
                    if (window.innerWidth <= 768) {
                        const sidebar = document.getElementById('sidebar');
                        const hamburgerBtn = document.getElementById('hamburgerBtn');
                        const closeBtn = document.getElementById('closeSidebarBtn');
                        sidebar.classList.remove('active');
                        hamburgerBtn.classList.remove('active');
                        closeBtn.style.display = 'none';
                    }
                });
            });
        });

        function closeSidebar() {
            const sidebar = document.getElementById('sidebar');
            const hamburgerBtn = document.getElementById('hamburgerBtn');
            const closeBtn = document.getElementById('closeSidebarBtn');
            sidebar.classList.remove('active');
            hamburgerBtn.classList.remove('active');
            closeBtn.style.display = 'none';
        }

        function selectPosition(position) {
            selectedPosition = position;
            document.getElementById('atcBtn').classList.remove('active');
            document.getElementById('enforcerBtn').classList.remove('active');
            
            if (position === 'atc') {
                document.getElementById('atcBtn').classList.add('active');
                document.getElementById('formTitle').textContent = 'ATC Controller Application';
                
            } else if (position === 'enforcer') {
                document.getElementById('enforcerBtn').classList.add('active');
                document.getElementById('formTitle').textContent = 'Enforcer Application';
                
            }
            
            document.getElementById('formPanel').style.display = 'block';
        }

        function resetForm() {
            selectedPosition = null;
            document.getElementById('applicationForm').reset();
            document.getElementById('formPanel').style.display = 'none';
            document.getElementById('atcBtn').classList.remove('active');
            document.getElementById('enforcerBtn').classList.remove('active');
        }

        document.getElementById('applicationForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const formData = {
                type: selectedPosition,
                Username: document.getElementById('fullName').value,
                discord: document.getElementById('discord').value,
                callsign: document.getElementById('callsign').value || null,
                experience: document.getElementById('experience').value,
                whyJoin: document.getElementById('whyJoin').value,
                submittedAt: new Date().toISOString(),
                discordId: document.getElementById('discordId').value || null
            };

            console.log('Application submitted:', formData);
            
            // Send to server
            fetch('/api/applications/submit', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(formData)
            })
            .then(response => response.json())
            .then(data => {
                alert('Application submitted successfully!');
                resetForm();
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error submitting application. Please try again.');
            });
        });
    </script>
</body>
</html>