<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="author" content="Caleb Thomas (TheRavenSeb)">
    <meta name="description" content="Apply to become an ATC Controller or Enforcer for the Aviation Realism Network.">
    <meta name="keywords" content="Applications, ATC, Enforcer, Aviation, Discord, Vtol VR">
    <title>Applications</title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <style>
        .main-content {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .page-wrap {
            flex: 1;
            max-width: 860px;
            margin: 0 auto;
            padding: 60px 24px;
            width: 100%;
        }

        .hero {
            margin-bottom: 40px;
            text-align: center;
            padding-top: 20px;
        }

        .hero h1 {
            font-size: 2.5em;
            font-weight: 700;
            color: #e0e0e0;
            margin-bottom: 10px;
        }

        .hero p {
            color: #e0e0e0;
            font-size: 1.1em;
            opacity: 0.9;
            max-width: 520px;
            margin: 0 auto;
        }

        /* Position selector */
        .position-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 32px;
        }

        .position-btn {
            background: transparent;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 10px;
            padding: 24px 20px;
            color: rgba(245,243,239,0.7);
            cursor: pointer;
            text-align: left;
            transition: all 0.15s;
            display: flex;
            flex-direction: column;
            gap: 6px;
            font-family: "Inter", sans-serif;
        }

        .position-btn:hover {
            border-color: rgba(255,255,255,0.22);
            color: #f5f3ef;
        }

        .position-btn.active {
            border-color: rgba(255,255,255,0.35);
            color: #f5f3ef;
        }

        .position-icon {
            width: 28px;
            height: 28px;
            color: rgba(245,243,239,0.5);
        }

        .position-btn.active .position-icon,
        .position-btn:hover .position-icon {
            color: #f5f3ef;
        }

        .position-name {
            font-size: 1rem;
            font-weight: 700;
            color: #f5f3ef;
            letter-spacing: -0.01em;
        }

        .position-desc {
            font-size: 0.8rem;
            color: rgba(245,243,239,0.45);
        }

        /* Form panel */
        .form-panel {
            padding: 28px 0;
        }

        .form-panel h2 {
            font-size: 1.05rem;
            font-weight: 700;
            color: #f5f3ef;
            letter-spacing: -0.01em;
            margin-bottom: 24px;
        }

        .form-group {
            margin-bottom: 18px;
        }

        .form-group label {
            display: block;
            font-size: 0.825rem;
            font-weight: 500;
            color: rgba(245,243,239,0.55);
            margin-bottom: 6px;
        }

        .form-group label a {
            color: rgba(245,243,239,0.4);
            font-size: 0.75rem;
            text-decoration: none;
        }

        .form-group label a:hover { color: rgba(245,243,239,0.7); }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 11px 14px;
            background: #1e1e1e;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: #f5f3ef;
            font-family: "Inter", sans-serif;
            font-size: 0.9rem;
            transition: border-color 0.15s;
            resize: vertical;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: rgba(255,255,255,0.25);
            background: #242424;
        }

        .form-group input[readonly] {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        .form-actions {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            margin-top: 24px;
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.06);
        }

        .btn {
            padding: 11px 20px;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 600;
            font-family: "Inter", sans-serif;
            cursor: pointer;
            transition: all 0.15s;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .btn-ghost {
            background: transparent;
            color: rgba(245,243,239,0.6);
        }

        .btn-ghost:hover {
            background: #2a2a2a;
            color: #f5f3ef;
        }

        .btn-primary {
            background: #3a3a3a;
            color: #f5f3ef;
        }

        .btn-primary:hover {
            background: #444;
            border-color: rgba(255,255,255,0.16);
        }

        /* Alerts */
        .alert {
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 0.875rem;
            margin-bottom: 20px;
            display: none;
        }

        .alert-error {
            background: rgba(220,50,50,0.12);
            border: 1px solid rgba(220,50,50,0.25);
            color: #ffb0b0;
        }

        .alert-success {
            background: rgba(50,180,80,0.1);
            border: 1px solid rgba(50,180,80,0.25);
            color: #b6f3be;
        }

        footer {
            text-align: center;
            padding: 24px 20px;
            font-size: 0.8rem;
            color: rgba(245,243,239,0.3);
        }

        @media (max-width: 768px) {
            .position-grid { grid-template-columns: 1fr; }
            .form-row { grid-template-columns: 1fr; }
            .page-wrap { padding: 40px 16px; }
            .hero h1 { font-size: 1.8em; }
        }

        <%- include('partials/fixed-sidebar-theme') %>
    </style>
</head>
<body>
    <%- include('partials/sidebar', { page: 'applications' }) %>

    <div class="main-content">
        <div class="page-wrap">
            <div class="hero">
                <h1>Applications</h1>
                <p>Apply to become an ATC Controller or Enforcer for the Aviation Realism Network.</p>
            </div>

            <div class="position-grid">
                <button class="position-btn" id="atcBtn" onclick="selectPosition('atc')">
                    <svg class="position-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 14h2a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4a9 9 0 0 1 18 0v4a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-2a2 2 0 0 1 2-2h2"/>
                    </svg>
                    <span class="position-name">ATC Controller</span>
                    <span class="position-desc">Manage airspace and guide pilots through controlled zones</span>
                </button>
                <button class="position-btn" id="enforcerBtn" onclick="selectPosition('enforcer')">
                    <svg class="position-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                    <span class="position-name">Enforcer</span>
                    <span class="position-desc">Maintain order and enforce server rules in-game</span>
                </button>
            </div>

            <div class="form-panel" id="formPanel" style="display: none;">
                <h2 id="formTitle"></h2>
                <div class="alert alert-error" id="alertError"></div>
                <div class="alert alert-success" id="alertSuccess"></div>
                <form id="applicationForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="fullName">Username</label>
                            <input type="text" id="fullName" name="fullName" required>
                        </div>
                        <div class="form-group">
                            <label for="callsign">Preferred Callsign</label>
                            <input type="text" id="callsign" name="callsign" maxlength="20">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label for="discord">Discord Handle</label>
                            <input type="text" id="discord" name="discord" placeholder="YourName#1234" required>
                        </div>
                        <div class="form-group">
                            <label for="discordId">Discord ID <a href="https://support.discord.com/hc/en-us/articles/200156798-FAQs-User-IDs-in-Discord" target="_blank" rel="noopener noreferrer">(what's this?)</a></label>
                            <input type="text" id="discordId" name="discordId" placeholder="Optional if logged in">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="experience">Previous Experience</label>
                        <textarea id="experience" name="experience" rows="3" placeholder="Tell us about your experience..."></textarea>
                    </div>
                    <div class="form-group">
                        <label for="whyJoin">Why do you want to join?</label>
                        <textarea id="whyJoin" name="whyJoin" rows="3" placeholder="Tell us why you're interested..." required></textarea>
                    </div>
                    <div class="form-actions">
                        <button type="button" class="btn btn-ghost" onclick="resetForm()">Cancel</button>
                        <button type="submit" class="btn btn-primary">Submit Application</button>
                    </div>
                </form>
            </div>
        </div>

        <footer>
            <%#  <p>&copy; 2026 Aviation Realism Network. All rights reserved.</p> %>
            <p>Bringing realistic aviation simulation to VTOL VR</p>
        </footer>
    </div>

    <script>
        let selectedPosition = null;

        document.addEventListener('DOMContentLoaded', function() {
            const user = <%- JSON.stringify(user || null) %>;
            if (user && user.DiscordID) {
                const discordIdInput = document.getElementById('discordId');
                discordIdInput.value = user.DiscordID;
                discordIdInput.readOnly = true;
            }
        });

        function selectPosition(position) {
            selectedPosition = position;
            document.getElementById('atcBtn').classList.toggle('active', position === 'atc');
            document.getElementById('enforcerBtn').classList.toggle('active', position === 'enforcer');
            document.getElementById('formTitle').textContent =
                position === 'atc' ? 'ATC Controller Application' : 'Enforcer Application';
            document.getElementById('formPanel').style.display = 'block';
            document.getElementById('formPanel').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        function resetForm() {
            selectedPosition = null;
            document.getElementById('applicationForm').reset();
            document.getElementById('formPanel').style.display = 'none';
            document.getElementById('atcBtn').classList.remove('active');
            document.getElementById('enforcerBtn').classList.remove('active');
        }

        function showAlert(type, message) {
            const el = document.getElementById(type === 'error' ? 'alertError' : 'alertSuccess');
            el.textContent = message;
            el.style.display = 'block';
            setTimeout(() => el.style.display = 'none', 5000);
        }

        document.getElementById('applicationForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const btn = this.querySelector('[type="submit"]');
            btn.disabled = true;
            btn.textContent = 'Submitting...';

            const formData = {
                type: selectedPosition,
                Username: document.getElementById('fullName').value,
                discord: document.getElementById('discord').value,
                callsign: document.getElementById('callsign').value || null,
                experience: document.getElementById('experience').value,
                whyJoin: document.getElementById('whyJoin').value,
                submittedAt: new Date().toISOString(),
                discordId: document.getElementById('discordId').value || null
            };

            fetch('/api/applications/submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            })
            .then(async response => {
                const payload = await response.json();
                if (!response.ok || payload.error) {
                    throw new Error(payload.error || 'Error submitting application. Please try again.');
                }

                showAlert('success', 'Application submitted successfully!');
                resetForm();
            })
            .catch(error => showAlert('error', error.message))
            .finally(() => {
                btn.disabled = false;
                btn.textContent = 'Submit Application';
            });
        });
    </script>
</body>
</html>
