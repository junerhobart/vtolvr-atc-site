<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Aviation Realism Network - Join a realistic flight simulation community">
    <title><%= title %></title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1e1e2e 0%, #2d2d44 100%);
            color: #e0e0e0;
            min-height: 100vh;
            line-height: 1.6;
        }

        header {
            background: rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(10px);
            padding: 20px 0;
            border-bottom: 1px solid rgba(102, 126, 234, 0.3);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        nav {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 1.8em;
            font-weight: bold;
            color: #667eea;
            text-decoration: none;
            display: flex;
            align-items: center;
        }

        .logo img {
            height: 50px;
            width: 50px;
            object-fit: contain;
        }

        .nav-links {
            display: flex;
            gap: 14px;
            list-style: none;
            align-items: center;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .nav-links > li {
            list-style: none;
        }

        .nav-links > li > a,
        .nav-dropdown > summary {
            color: #e0e0e0;
            text-decoration: none;
            transition: color 0.3s;
            font-weight: 500;
            cursor: pointer;
            list-style: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .nav-links > li > a:hover,
        .nav-dropdown > summary:hover {
            color: #667eea;
        }

        .nav-dropdown {
            position: relative;
        }

        .nav-dropdown > summary {
            user-select: none;
        }

        .nav-dropdown > summary::-webkit-details-marker {
            display: none;
        }

        .nav-dropdown > summary::after {
            content: '▾';
            font-size: 0.75em;
            transition: transform 0.2s ease;
        }

        .nav-dropdown[open] > summary::after {
            transform: rotate(180deg);
        }

        .dropdown-menu {
            display: none;
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            min-width: 210px;
            list-style: none;
            padding: 8px;
            border-radius: 10px;
            background: rgba(20, 20, 30, 0.98);
            border: 1px solid rgba(102, 126, 234, 0.35);
            box-shadow: 0 12px 25px rgba(0, 0, 0, 0.35);
            z-index: 120;
        }

        .nav-dropdown[open] .dropdown-menu {
            display: block;
        }

        .dropdown-menu li {
            list-style: none;
        }

        .dropdown-menu a {
            display: block;
            color: #e0e0e0;
            text-decoration: none;
            border-radius: 8px;
            padding: 9px 12px;
            transition: all 0.25s;
            white-space: nowrap;
        }

        .dropdown-menu a:hover {
            background: rgba(102, 126, 234, 0.2);
            color: #8ea2ff;
        }

        .hamburger-btn {
            display: none;
            background: none;
            border: none;
            color: #e0e0e0;
            font-size: 1.8em;
            cursor: pointer;
            padding: 10px;
            transition: color 0.3s;
        }

        .hamburger-btn:hover {
            color: #667eea;
        }

        .sidebar {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 280px;
            height: 100vh;
            background-color: rgba(20, 20, 30, 0.98);
            backdrop-filter: blur(10px);
            border-right: 1px solid rgba(102, 126, 234, 0.3);
            padding: 80px 20px 20px 20px;
            z-index: 999;
            overflow-y: auto;
            flex-direction: column;
            gap: 15px;
        }

        .sidebar.active {
            display: flex;
        }

        .sidebar-close-btn {
            position: absolute;
            top: 20px;
            right: 20px;
            background: none;
            border: none;
            color: #e0e0e0;
            font-size: 1.8em;
            cursor: pointer;
            padding: 5px 10px;
            transition: color 0.3s;
        }

        .sidebar-close-btn:hover {
            color: #667eea;
        }

        .sidebar a {
            color: #e0e0e0;
            text-decoration: none;
            padding: 12px 16px;
            border-radius: 6px;
            transition: all 0.3s;
            display: block;
        }

        .sidebar a:hover {
            background-color: rgba(102, 126, 234, 0.2);
            color: #667eea;
        }

        .overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            z-index: 998;
        }

        .overlay.active {
            display: block;
        }

        .hero {
            max-width: 1200px;
            margin: 0 auto;
            padding: 90px 20px 50px;
            text-align: center;
        }

        .hero h1 {
            font-size: 3.5em;
            margin-bottom: 20px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero p {
            font-size: 1.3em;
            color: #b0b0b0;
            margin-bottom: 40px;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
        }

        .cta-buttons {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: nowrap;
            margin-bottom: 80px;
        }

        .btn {
            padding: 14px 32px;
            font-size: 1.1em;
            border: 2px solid #667eea;
            border-radius: 8px;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s;
            font-weight: 600;
            display: inline-block;
        }

        .btn-primary {
            background: #667eea;
            color: white;
        }

        .btn-primary:hover {
            background: #764ba2;
            border-color: #764ba2;
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        }

        .btn-secondary {
            background: transparent;
            color: #667eea;
        }

        .btn-secondary:hover {
            background: #667eea;
            color: white;
            transform: translateY(-2px);
        }

        .features {
            max-width: 1200px;
            margin: 0 auto;
            padding: 60px 20px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }

        .feature-link {
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .feature-card {
            background: rgba(51, 51, 51, 0.5);
            backdrop-filter: blur(10px);
            padding: 30px;
            border-radius: 12px;
            border: 1px solid rgba(102, 126, 234, 0.2);
            transition: all 0.3s;
            text-align: center;
            height: 100%;
        }

        .feature-card:hover {
            border-color: #667eea;
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(102, 126, 234, 0.2);
        }

        .feature-card h3 {
            color: #667eea;
            font-size: 1.5em;
            margin-bottom: 15px;
        }

        .feature-card p {
            color: #b0b0b0;
        }

        .content-section {
            max-width: 1200px;
            margin: 60px auto;
            padding: 0 20px;
        }

        .sessions-shell {
            background: rgba(51, 51, 51, 0.55);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(102, 126, 234, 0.2);
            border-radius: 12px;
            padding: 24px;
        }

        .section-title {
            font-size: 2.2em;
            margin-bottom: 40px;
            text-align: center;
            color: #e0e0e0;
            border-bottom: 3px solid #667eea;
            padding-bottom: 20px;
        }

        .sessions-preview {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            margin-bottom: 40px;
        }

        .session-card {
            background: rgba(51, 51, 51, 0.7);
            padding: 25px;
            border-radius: 10px;
            border: 1px solid rgba(102, 126, 234, 0.25);
            border-left: 4px solid #667eea;
            transition: all 0.3s;
        }

        .session-card:hover {
            border-color: #667eea;
            transform: translateY(-4px);
            box-shadow: 0 14px 30px rgba(102, 126, 234, 0.2);
        }

        .session-card h4 {
            color: #667eea;
            margin-bottom: 10px;
            font-size: 1.2em;
        }

        .session-card p {
            color: #b0b0b0;
            margin-bottom: 8px;
        }

        .session-status {
            display: inline-block;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: 600;
            margin-top: 10px;
        }

        .status-active {
            background: rgba(76, 175, 80, 0.3);
            color: #4caf50;
        }

        .status-upcoming {
            background: rgba(255, 193, 7, 0.3);
            color: #ffc107;
        }

        footer {
            background: rgba(0, 0, 0, 0.5);
            border-top: 1px solid rgba(102, 126, 234, 0.3);
            padding: 40px 20px;
            text-align: center;
            margin-top: 80px;
        }

        footer p {
            color: #999;
            margin-bottom: 10px;
        }

        .footer-links {
            display: flex;
            justify-content: center;
            gap: 25px;
            flex-wrap: wrap;
            margin-top: 20px;
        }

        .footer-links a {
            color: #667eea;
            text-decoration: none;
            transition: color 0.3s;
        }

        .footer-links a:hover {
            color: #764ba2;
        }

        @media (max-width: 1024px) {
            .nav-links {
                gap: 20px;
            }
        }

        @media (max-width: 768px) {
            .hamburger-btn {
                display: block;
            }

            .nav-links {
                display: none;
            }

            nav {
                justify-content: space-between;
            }

            .logo {
                font-size: 1.5em;
            }

            .logo img {
                height: 40px;
                width: 40px;
            }

            .hero {
                padding: 60px 20px 40px;
            }

            .hero h1 {
                font-size: 2.2em;
                margin-bottom: 15px;
            }

            .hero p {
                font-size: 1.1em;
            }

            .cta-buttons {
                flex-direction: column;
                align-items: center;
            }

            .btn {
                width: 100%;
                max-width: 300px;
                padding: 12px 24px;
                font-size: 1em;
            }

            .features {
                grid-template-columns: 1fr;
                padding: 40px 20px;
                gap: 20px;
            }

            .feature-card {
                padding: 20px;
            }

            .feature-card h3 {
                font-size: 1.3em;
            }

            .content-section {
                margin: 40px auto;
                padding: 0 15px;
            }

            .sessions-shell {
                padding: 18px;
            }

            .section-title {
                font-size: 1.8em;
                margin-bottom: 30px;
            }

            .sessions-preview {
                grid-template-columns: 1fr;
                gap: 15px;
            }

            .session-card {
                padding: 20px;
            }

            .session-card h4 {
                font-size: 1.1em;
            }

            .session-card p {
                font-size: 0.95em;
            }
        }

        @media (max-width: 480px) {
            body {
                font-size: 14px;
            }

            header {
                padding: 15px 0;
            }

            nav {
                padding: 0 15px;
            }

            .logo {
                font-size: 1.3em;
            }

            .logo img {
                height: 35px;
                width: 35px;
            }

            .hamburger-btn {
                font-size: 1.5em;
                padding: 8px;
            }

            .hero {
                padding: 40px 15px 30px;
            }

            .hero h1 {
                font-size: 1.8em;
                margin-bottom: 10px;
            }

            .hero p {
                font-size: 0.95em;
                margin-bottom: 25px;
            }

            .cta-buttons {
                gap: 10px;
                margin-bottom: 40px;
            }

            .btn {
                padding: 10px 20px;
                font-size: 0.9em;
            }

            .features {
                padding: 30px 15px;
            }

            .feature-card {
                padding: 15px;
            }

            .feature-card h3 {
                font-size: 1.1em;
                margin-bottom: 10px;
            }

            .feature-card p {
                font-size: 0.9em;
            }

            .content-section {
                margin: 30px auto;
                padding: 0 12px;
            }

            .sessions-shell {
                padding: 14px;
                border-radius: 10px;
            }

            .section-title {
                font-size: 1.5em;
                margin-bottom: 20px;
                padding-bottom: 15px;
            }

            .sessions-preview {
                gap: 12px;
            }

            .session-card {
                padding: 15px;
                border-radius: 8px;
            }

            .session-card h4 {
                font-size: 1em;
                margin-bottom: 8px;
            }

            .session-card p {
                font-size: 0.9em;
                margin-bottom: 5px;
            }

            .session-status {
                padding: 4px 10px;
                font-size: 0.8em;
            }

            footer {
                padding: 30px 15px;
                margin-top: 40px;
            }

            .footer-links {
                gap: 15px;
                flex-wrap: wrap;
            }

            .footer-links a {
                font-size: 0.9em;
            }
        }
    </style>
</head>
<body>
    <div class="overlay" id="overlay"></div>
    
    <div class="sidebar" id="sidebar">
        <button class="sidebar-close-btn" id="sidebarCloseBtn" onclick="closeSidebar()">&times;</button>
        <a href="/profile">Profile</a>
        <a href="/sessions">Sessions</a>
        <a href="/charts">Charts</a>
        <a href="/announcements">Announcements</a>
        <% if (user && user.role.includes('atc')) { %>
            <a href="/events">Create Events</a>
            <a href="/atc/metar">Submit METAR</a>
        <% } %>
        <% if (user && user.role.includes('admin')) { %>
            <a href="/admin">Admin Panel</a>
            <a href="/applications/admin">Review Applications</a>
            <a href="/admin/discord">Discord Users</a>
        <% } %>
        <% if (user) { %>
            <a href="/logout">Logout</a>
        <% } else { %>
            <a href="/login/home">Login</a>
            <a href="/register">Register</a>
        <% } %>
    </div>

    <header>
        <nav>
            <a href="/" class="logo"><img src="https://atc-vtolvr.site/assets/logo.png" alt="ARN Logo">ARN</a>
            <button class="hamburger-btn" id="hamburgerBtn" onclick="toggleSidebar()" aria-label="Toggle navigation menu">☰</button>
            <ul class="nav-links">
                <li><a href="/profile">Profile</a></li>
                <li><a href="/sessions">Sessions</a></li>
                <li>
                    <details class="nav-dropdown">
                        <summary>Resources</summary>
                        <ul class="dropdown-menu">
                            <li><a href="/charts">Charts</a></li>
                            <li><a href="/information">Information</a></li>
                            <li><a href="/announcements">Announcements</a></li>
                        </ul>
                    </details>
                </li>
                <% if (user && user.role.includes('atc')) { %>
                    <li>
                        <details class="nav-dropdown">
                            <summary>ATC Tools</summary>
                            <ul class="dropdown-menu">
                                <li><a href="/events">Create Events</a></li>
                                <li><a href="/atc/metar">Submit METAR</a></li>
                            </ul>
                        </details>
                    </li>
                <% } %>
                <% if (user && user.role.includes('admin')) { %>
                    <li>
                        <details class="nav-dropdown">
                            <summary>Admin</summary>
                            <ul class="dropdown-menu">
                                <li><a href="/admin">Admin Panel</a></li>
                                <li><a href="/applications/admin">Apps Panel</a></li>
                                <li><a href="/admin/discord">Discord Users</a></li>
                            </ul>
                        </details>
                    </li>
                <% } %>
                <li>
                    <details class="nav-dropdown">
                        <summary>Account</summary>
                        <ul class="dropdown-menu">
                            <% if (user) { %>
                                <li><a href="/logout">Logout</a></li>
                            <% } else { %>
                                <li><a href="/login/home">Login</a></li>
                                <li><a href="/register">Register</a></li>
                            <% } %>
                        </ul>
                    </details>
                </li>
            </ul>
        </nav>
    </header>

    <main>
        <section class="hero">
            <h1><%= title %></h1>
            <p><%= message %></p>
            <div class="cta-buttons">
                <a href="/sessions" class="btn btn-primary">View Game Sessions</a>
                <a href="/charts" class="btn btn-secondary">Airport Charts</a>
            </div>
        </section>

        <section class="features">
            <a href="/sessions" class="feature-link">
                <div class="feature-card">
                    <h3>🎮 Live Sessions</h3>
                    <p>Join active game sessions with other pilots and air traffic controllers in real-time gameplay.</p>
                </div>
            </a>
            <a href="/charts" class="feature-link">
                <div class="feature-card">
                    <h3>📊 Flight Charts</h3>
                    <p>Access comprehensive airport charts and navigation data for accurate flight planning.</p>
                </div>
            </a>
            <a href="/discord" class="feature-link">
                <div class="feature-card">
                    <h3>👥 Community</h3>
                    <p>Connect with fellow aviation enthusiasts and participate in a realistic flight simulation community.</p>
                </div>
            </a>
        </section>

        <section class="content-section">
            <h2 class="section-title">Current Game Sessions</h2>
            <div class="sessions-shell">
                <div class="sessions-preview" id="sessionsList">
                    <p>Loading sessions...</p>
                </div>
            </div>
            <div style="text-align: center; margin-top: 30px;">
                <a href="/sessions" class="btn btn-primary">View All Sessions</a>
            </div>
        </section>

        <script>
            fetch('/api/events')
                .then(response => response.json())
                .then(data => {
                    const sessionsList = document.getElementById('sessionsList');
                    sessionsList.innerHTML = '';
                    const events = Array.isArray(data?.data) ? data.data : [];
                    
                    if (events.length === 0) {
                        sessionsList.innerHTML = '<p>No sessions available at this time.</p>';
                        return;
                    }
                    
                    events.slice(0, 3).forEach(session => {
                        const statusClass = session.status === 'active' ? 'status-active' : 'status-upcoming';
                        
                        // Format duration: show in minutes if less than 1 hour
                        let formattedDuration = session.duration;
                        if (session.duration_minutes && session.duration_minutes < 60) {
                            formattedDuration = `${session.duration_minutes} minutes`;
                        }
                        
                        // Format start time
                        const startTime = session.startTime ? new Date(session.startTime).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '';
                        
                        const sessionHTML = `
                            <div class="session-card">
                                <h4>${session.name}</h4>
                                <p>Hosted by: ${session.hostName}</p>
                                <p>📍 Location: ${session.map}</p>
                                <p>🛫 Airport: ${session.airport}</p>
                                <p>👤 Expected Pilots: ${session.pilots}</p>
                                <p>🕐 Start: ${startTime}</p>
                                <p>⏱️ Duration: ${formattedDuration}</p>
                                <span class="session-status ${statusClass}">${(session.status || 'upcoming').toUpperCase()}</span>
                            </div>
                        `;
                        sessionsList.innerHTML += sessionHTML;
                    });
                })
                .catch(error => {
                    console.error('Error fetching sessions:', error);
                    document.getElementById('sessionsList').innerHTML = '<p>Unable to load sessions. Please try again later.</p>';
                });
        </script>
    </main>

    <footer>
        <p>&copy; 2026 Aviation Realism Network. All rights reserved.</p>
        <p>Bringing realistic aviation simulation to VTOL VR</p>
        <div class="footer-links">
            <a href="/information">Information</a>
            <a href="/announcements">Announcements</a>
            <a href="/pilots">Pilots Directory</a>
            <a href="/applications">Applications</a>
        </div>
    </footer>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('overlay');
            sidebar.classList.toggle('active');
            overlay.classList.toggle('active');
        }

        function closeSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('overlay');
            sidebar.classList.remove('active');
            overlay.classList.remove('active');
        }

        // Close sidebar when clicking overlay
        document.getElementById('overlay').addEventListener('click', closeSidebar);

        // Close sidebar when clicking a link
        const sidebarLinks = document.querySelectorAll('.sidebar a');
        sidebarLinks.forEach(link => {
            link.addEventListener('click', closeSidebar);
        });

        // Close sidebar on window resize if screen is large
        window.addEventListener('resize', function() {
            if (window.innerWidth > 768) {
                closeSidebar();
            }
        });
    </script>
</body>
</html>
