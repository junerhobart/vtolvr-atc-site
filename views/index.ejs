<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Aviation Realism Network - Join a realistic flight simulation community">
    <meta property="og:image" content="/assets/diagrams/airportChartEmptyDark.png">
    <title><%= title %></title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Material+Symbols+Rounded:FILL@1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles/theme.css">
    <style>
        .material-symbols-rounded {
            font-family: "Material Symbols Rounded";
            font-weight: normal;
            font-style: normal;
            font-size: 1.1rem;
            line-height: 1;
            letter-spacing: normal;
            text-transform: none;
            display: inline-block;
            white-space: nowrap;
            word-wrap: normal;
            direction: ltr;
            -webkit-font-smoothing: antialiased;
            font-variation-settings: "FILL" 1, "wght" 500, "GRAD" 0, "opsz" 24;
        }

        main {
            position: relative;
        }

        .hero,
        .features,
        .content-section,
        footer {
            position: relative;
            z-index: 1;
        }

        .hero {
            max-width: 1200px;
            margin: 0 auto;
            padding: 60px 24px 48px;
            text-align: left;
        }

        .hero h1 {
            max-width: none;
            margin-bottom: 18px;
            font-size: clamp(2.4rem, 6vw, 5rem);
            line-height: 0.95;
            letter-spacing: -0.04em;
            color: var(--text);
            white-space: nowrap;
        }

        .hero p {
            max-width: 650px;
            margin-bottom: 46px;
            font-size: clamp(1rem, 2vw, 1.2rem);
            color: var(--muted);
        }

        .cta-buttons {
            display: flex;
            gap: 14px;
            justify-content: flex-start;
            flex-wrap: wrap;
            margin-bottom: 0;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            min-height: 52px;
            padding: 0 24px;
            border-radius: 999px;
            border: none;
            font-size: 0.95rem;
            font-weight: 600;
            text-decoration: none;
            transition: background-color 0.2s ease, color 0.2s ease;
        }

        .btn-primary {
            background: var(--accent);
            color: #1a1a1a !important; 
            box-shadow: none;
        }
        
        .btn-primary:hover {
            background: #ebe8e2;
        }

        .btn-secondary {
            background: var(--bg-soft);
            color: var(--text);
        }

        .btn-secondary:hover {
            background: #2a2a2a;
        }

        .features {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 24px 24px;
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 18px;
        }

        .feature-link {
            display: block;
            text-decoration: none;
            color: inherit;
        }

        .feature-card,
        .sessions-shell,
        .session-card {
            background: var(--panel);
            border: none;
            box-shadow: none;
        }

        .feature-card {
            height: 100%;
            padding: 28px;
            border-radius: 8px;
            transition: border-color 0.22s ease, background-color 0.22s ease;
            text-align: left;
        }

        .feature-card:hover {
            border-color: var(--line-strong);
            background: var(--bg-soft);
        }

        .feature-card h3 {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
            font-size: 1.2rem;
            color: var(--text);
        }

        .feature-card p {
            color: var(--muted);
        }

        .content-section {
            max-width: 1200px;
            margin: 88px auto 0;
            padding: 0 24px;
        }

        .sessions-shell {
            border-radius: 8px;
            padding: 24px;
        }

        .section-title {
            margin-bottom: 20px;
            font-size: clamp(1.7rem, 4vw, 2.4rem);
            color: var(--text);
            letter-spacing: -0.03em;
        }

        .sessions-preview {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 18px;
            margin-bottom: 8px;
        }

        .session-card {
            padding: 22px;
            border-radius: 8px;
            transition: border-color 0.22s ease, background-color 0.22s ease;
        }

        .session-card:hover {
            border-color: var(--line-strong);
            background: var(--bg-soft);
        }

        .session-card h4 {
            margin-bottom: 12px;
            font-size: 1.05rem;
            color: var(--text);
        }

        .session-card p {
            margin-bottom: 8px;
            color: var(--muted);
        }

        .session-status {
            display: inline-flex;
            align-items: center;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            margin-top: 12px;
        }

        .status-active {
            background: rgba(182, 243, 190, 0.12);
            color: var(--success);
        }

        .status-upcoming {
            background: rgba(255, 225, 160, 0.12);
            color: var(--warning);
        }

        footer {
            max-width: 1200px;
            margin: 112px auto 0;
            padding: 32px 24px 72px;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 24px;
            text-align: left;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        footer p {
            color: var(--muted);
            margin-bottom: 6px;
        }

        .footer-copy {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .footer-links {
            display: flex;
            gap: 18px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .footer-links a {
            color: var(--text);
            text-decoration: none;
            opacity: 0.8;
            transition: opacity 0.2s ease, color 0.2s ease;
        }

        .footer-links a:hover {
            opacity: 1;
            color: var(--text);
        }

        @media (max-width: 1024px) {
            .features {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .hero {
                padding: 88px 18px 40px;
            }

            .features,
            .content-section,
            footer {
                padding-left: 18px;
                padding-right: 18px;
            }

            .sessions-shell,
            .feature-card {
                border-radius: 8px;
            }
        }

        @media (max-width: 480px) {
            body {
                font-size: 14px;
            }

            .hero h1 {
                white-space: normal;
            }

            footer {
                flex-direction: column;
                gap: 18px;
            }

            .footer-links {
                justify-content: flex-start;
            }

            .btn {
                width: 100%;
            }

            .cta-buttons {
                flex-direction: column;
            }

            .sessions-shell,
            .feature-card,
            .session-card {
                padding: 18px;
            }
        }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { page: 'home' }) %>

    <div class="main-content">
        <main>
        <section class="hero">
            <h1><%= title %></h1>
            <p><%= message %></p>
            <div class="cta-buttons">
                <a href="/sessions" class="btn btn-primary">
                    <span class="material-symbols-rounded">flight</span>
                    View Game Sessions
                </a>
                <a href="/charts" class="btn btn-secondary">
                    <span class="material-symbols-rounded">map</span>
                    Airport Charts
                </a>
            </div>
        </section>

        <section class="features">
            <a href="/sessions" class="feature-link">
                <div class="feature-card">
                    <h3><span class="material-symbols-rounded">radar</span>Live Sessions</h3>
                    <p>Join active game sessions with other pilots and air traffic controllers in real-time gameplay.</p>
                </div>
            </a>
            <a href="/charts" class="feature-link">
                <div class="feature-card">
                    <h3><span class="material-symbols-rounded">route</span>Flight Charts</h3>
                    <p>Access comprehensive airport charts and navigation data for accurate flight planning.</p>
                </div>
            </a>
            <a href="/discord" class="feature-link">
                <div class="feature-card">
                    <h3><span class="material-symbols-rounded">groups</span>Community</h3>
                    <p>Connect with fellow aviation enthusiasts and participate in a realistic flight simulation community.</p>
                </div>
            </a>
        </section>

        <section class="content-section">
            <h2 class="section-title">Upcoming Events</h2>
            <div class="sessions-shell">
                <div class="sessions-preview" id="sessionsList">
                    <p>Loading events...</p>
                </div>
            </div>
            <div style="text-align: center; margin-top: 30px;">
                <a href="/events" class="btn btn-primary">View All Events</a>
            </div>
        </section>

        <script>
            fetch('/api/events')
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Unable to load events right now.');
                    }

                    return response.json();
                })
                .then(payload => {
                    const sessionsList = document.getElementById('sessionsList');
                    sessionsList.innerHTML = '';
                    const events = Array.isArray(payload?.data) ? payload.data : [];
                    
                    if (events.length === 0) {
                        sessionsList.innerHTML = '<p>No events available at this time.</p>';
                        return;
                    }
                    
                    events.slice(0, 3).forEach(session => {
                        const statusClass = session.status === 'active' ? 'status-active' : 'status-upcoming';
                        
                        // Format duration: show in minutes if less than 1 hour
                        let formattedDuration = session.duration;
                        if (session.duration_minutes && session.duration_minutes < 60) {
                            formattedDuration = `${session.duration_minutes} minutes`;
                        }
                        
                        // Format start time
                        const startTime = session.startTime ? new Date(session.startTime).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '';
                        
                        const sessionHTML = `
                            <div class="session-card">
                                <h4>${session.name}</h4>
                                <p>Hosted by: ${session.hostName}</p>
                                <p>📍 Location: ${session.map}</p>
                                <p>🛫 Airport: ${session.airport}</p>
                                <p>👤 Expected Pilots: ${session.pilots}</p>
                                <p>🕐 Start: ${startTime}</p>
                                <p>⏱️ Duration: ${formattedDuration}</p>
                                <span class="session-status ${statusClass}">${(session.status || 'upcoming').toUpperCase()}</span>
                            </div>
                        `;
                        sessionsList.innerHTML += sessionHTML;
                    });
                })
                .catch(error => {
                    document.getElementById('sessionsList').innerHTML = '<p>' + error.message + '</p>';
                });
        </script>
        </main>

        <footer>
            <div class="footer-copy">
                <%#  <p>&copy; 2026 Aviation Realism Network. All rights reserved.</p> %>
                <p>Bringing realistic aviation simulation to VTOL VR</p>
            </div>
            <div class="footer-links">
                <a href="/information">Information</a>
                <%# <a href="/announcements">Announcements</a> %>
                <a href="/pilots">Pilots Directory</a>
                <a href="/applications">Applications</a>
            </div>
        </footer>
    </div>
</body>
</html>
