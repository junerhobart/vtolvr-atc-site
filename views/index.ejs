<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Aviation Realism Network - Join a realistic flight simulation community">
    <title><%= title %></title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Material+Symbols+Rounded:FILL@1&display=swap" rel="stylesheet">
    <style>
        :root {
            color-scheme: dark;
            --bg: #1a1a1a;
            --bg-soft: #202020;
            --panel: #232323;
            --panel-hover: #2a2a2a;
            --line: rgba(255, 255, 255, 0.05);
            --line-strong: rgba(255, 255, 255, 0.09);
            --text: #f5f3ef;
            --muted: rgba(245, 243, 239, 0.7);
            --accent: #f5f3ef;
            --success: #b6f3be;
            --warning: #ffe1a0;
            --shadow: 0 16px 40px rgba(0, 0, 0, 0.22);
            --max-width: 1200px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: "Inter", "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            background:
                radial-gradient(circle at top left, rgba(116, 144, 255, 0.025), transparent 24%),
                linear-gradient(180deg, #1b1b1b 0%, #181818 100%);
            color: var(--text);
            min-height: 100vh;
            line-height: 1.6;
            letter-spacing: 0.01em;
        }

        a {
            color: inherit;
        }

        .material-symbols-rounded {
            font-family: "Material Symbols Rounded";
            font-weight: normal;
            font-style: normal;
            font-size: 1.1rem;
            line-height: 1;
            letter-spacing: normal;
            text-transform: none;
            display: inline-block;
            white-space: nowrap;
            word-wrap: normal;
            direction: ltr;
            -webkit-font-smoothing: antialiased;
            font-variation-settings: "FILL" 1, "wght" 500, "GRAD" 0, "opsz" 24;
        }

        header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(26, 26, 26, 0.96);
            border-bottom: 1px solid var(--line);
        }

        nav {
            max-width: var(--max-width);
            margin: 0 auto;
            padding: 16px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-decoration: none;
            color: var(--text);
        }

        .logo img {
            height: 56px;
            width: 56px;
            object-fit: contain;
        }

        .nav-links {
            display: flex;
            gap: 8px;
            list-style: none;
            align-items: center;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .nav-links > li {
            list-style: none;
        }

        .nav-links > li > a,
        .nav-dropdown > summary {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 10px 12px;
            border-radius: 10px;
            border: 1px solid transparent;
            color: var(--muted);
            text-decoration: none;
            font-size: 0.92rem;
            font-weight: 500;
            cursor: pointer;
            list-style: none;
            transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
        }

        .nav-links > li > a:hover,
        .nav-dropdown > summary:hover,
        .nav-dropdown[open] > summary {
            color: var(--text);
            background: var(--bg-soft);
            border-color: var(--line);
        }

        .nav-dropdown {
            position: relative;
        }

        .nav-dropdown > summary {
            user-select: none;
        }

        .nav-dropdown > summary::-webkit-details-marker {
            display: none;
        }

        .nav-dropdown > summary::after {
            content: '▾';
            font-size: 0.72em;
            transition: transform 0.2s ease;
        }

        .nav-dropdown[open] > summary::after {
            transform: rotate(180deg);
        }

        .dropdown-menu {
            display: none;
            position: absolute;
            top: calc(100% + 12px);
            right: 0;
            min-width: 220px;
            list-style: none;
            padding: 10px;
            border-radius: 14px;
            background: var(--panel);
            border: 1px solid var(--line-strong);
            box-shadow: var(--shadow);
            z-index: 120;
        }

        .nav-dropdown[open] .dropdown-menu {
            display: block;
        }

        .dropdown-menu li {
            list-style: none;
        }

        .dropdown-menu a {
            display: block;
            padding: 10px 12px;
            border-radius: 10px;
            color: var(--muted);
            text-decoration: none;
            transition: background-color 0.2s ease, color 0.2s ease;
            white-space: nowrap;
        }

        .dropdown-menu a:hover {
            background: var(--bg-soft);
            color: var(--text);
        }

        .hamburger-btn {
            display: none;
            background: transparent;
            border: 1px solid var(--line);
            border-radius: 10px;
            color: var(--text);
            font-size: 1rem;
            cursor: pointer;
            padding: 10px;
            transition: border-color 0.2s ease, background-color 0.2s ease;
        }

        .hamburger-btn:hover {
            border-color: var(--line-strong);
            background: var(--bg-soft);
        }

        .sidebar {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: min(320px, 88vw);
            height: 100vh;
            background: rgba(26, 26, 26, 0.98);
            border-right: 1px solid var(--line);
            padding: 88px 20px 24px;
            z-index: 999;
            overflow-y: auto;
            flex-direction: column;
            gap: 8px;
            box-shadow: var(--shadow);
        }

        .sidebar.active {
            display: flex;
        }

        .sidebar-close-btn {
            position: absolute;
            top: 18px;
            right: 18px;
            background: transparent;
            border: 1px solid var(--line);
            border-radius: 10px;
            color: var(--text);
            font-size: 1rem;
            cursor: pointer;
            padding: 10px;
            transition: border-color 0.2s ease, background-color 0.2s ease;
        }

        .sidebar-close-btn:hover {
            border-color: var(--line-strong);
            background: var(--bg-soft);
        }

        .sidebar a {
            display: block;
            padding: 12px 14px;
            border-radius: 5px;
            border: 1px solid transparent;
            color: var(--muted);
            text-decoration: none;
            font-size: 1.05rem;
            font-weight: 500;
            transition: border-color 0.2s ease, background-color 0.2s ease, color 0.2s ease;
        }

        .sidebar a:hover {
            border-color: var(--line);
            background: var(--bg-soft);
            color: var(--text);
        }

        .sidebar-brand {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 12px;
            padding: 0 6px 10px;
            margin-bottom: 8px;
        }

        .sidebar-brand img {
            width: 82px;
            height: 82px;
            object-fit: contain;
        }

        .sidebar-brand span {
            max-width: 210px;
            font-size: 1.35rem;
            font-weight: 700;
            line-height: 1.15;
            letter-spacing: -0.03em;
            color: var(--text);
        }

        .overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.5);
            z-index: 998;
        }

        .overlay.active {
            display: block;
        }

        main {
            position: relative;
        }

        .hero,
        .features,
        .content-section,
        footer {
            position: relative;
            z-index: 1;
        }

        .hero {
            max-width: var(--max-width);
            margin: 0 auto;
            padding: 108px 24px 64px;
            text-align: left;
        }

        .hero h1 {
            max-width: none;
            margin-bottom: 18px;
            font-size: clamp(2.4rem, 6vw, 5rem);
            line-height: 0.95;
            letter-spacing: -0.04em;
            color: var(--text);
            white-space: nowrap;
        }

        .hero p {
            max-width: 650px;
            margin-bottom: 46px;
            font-size: clamp(1rem, 2vw, 1.2rem);
            color: var(--muted);
        }

        .cta-buttons {
            display: flex;
            gap: 14px;
            justify-content: flex-start;
            flex-wrap: wrap;
            margin-bottom: 0;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            min-height: 52px;
            padding: 0 24px;
            border-radius: 999px;
            border: none;
            font-size: 0.95rem;
            font-weight: 600;
            text-decoration: none;
            transition: background-color 0.2s ease, color 0.2s ease;
        }

        .btn-primary {
            background: var(--accent);
            color: #1a1a1a;
            box-shadow: none;
        }

        .btn-primary:hover {
            background: #ebe8e2;
        }

        .btn-secondary {
            background: var(--bg-soft);
            color: var(--text);
        }

        .btn-secondary:hover {
            background: #2a2a2a;
        }

        .features {
            max-width: var(--max-width);
            margin: 0 auto;
            padding: 40px 24px 24px;
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 18px;
        }

        .feature-link {
            display: block;
            text-decoration: none;
            color: inherit;
        }

        .feature-card,
        .sessions-shell,
        .session-card {
            background: var(--panel);
            border: none;
            box-shadow: none;
        }

        .feature-card {
            height: 100%;
            padding: 28px;
            border-radius: 8px;
            transition: border-color 0.22s ease, background-color 0.22s ease;
            text-align: left;
        }

        .feature-card:hover {
            border-color: var(--line-strong);
            background: var(--bg-soft);
        }

        .feature-card h3 {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
            font-size: 1.2rem;
            color: var(--text);
        }

        .feature-card p {
            color: var(--muted);
        }

        .content-section {
            max-width: var(--max-width);
            margin: 88px auto 0;
            padding: 0 24px;
        }

        .sessions-shell {
            border-radius: 8px;
            padding: 24px;
        }

        .section-title {
            margin-bottom: 20px;
            font-size: clamp(1.7rem, 4vw, 2.4rem);
            color: var(--text);
            letter-spacing: -0.03em;
        }

        .sessions-preview {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 18px;
            margin-bottom: 8px;
        }

        .session-card {
            padding: 22px;
            border-radius: 8px;
            transition: border-color 0.22s ease, background-color 0.22s ease;
        }

        .session-card:hover {
            border-color: var(--line-strong);
            background: var(--bg-soft);
        }

        .session-card h4 {
            margin-bottom: 12px;
            font-size: 1.05rem;
            color: var(--text);
        }

        .session-card p {
            margin-bottom: 8px;
            color: var(--muted);
        }

        .session-status {
            display: inline-flex;
            align-items: center;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            margin-top: 12px;
        }

        .status-active {
            background: rgba(182, 243, 190, 0.12);
            color: var(--success);
        }

        .status-upcoming {
            background: rgba(255, 225, 160, 0.12);
            color: var(--warning);
        }

        footer {
            max-width: var(--max-width);
            margin: 112px auto 0;
            padding: 32px 24px 72px;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 24px;
            text-align: left;
            border-top: 1px solid var(--line);
        }

        footer p {
            color: var(--muted);
            margin-bottom: 6px;
        }

        .footer-copy {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .footer-links {
            display: flex;
            gap: 18px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .footer-links a {
            color: var(--text);
            text-decoration: none;
            opacity: 0.8;
            transition: opacity 0.2s ease, color 0.2s ease;
        }

        .footer-links a:hover {
            opacity: 1;
            color: var(--text);
        }

        @media (max-width: 1024px) {
            .features {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            nav {
                padding: 16px 18px;
            }

            .hamburger-btn {
                display: inline-flex;
            }

            .nav-links {
                display: none;
            }

            .logo {
                font-size: 0.9rem;
                letter-spacing: 0.06em;
            }

            .logo img {
                height: 40px;
                width: 40px;
            }

            .hero {
                padding: 72px 18px 40px;
            }

            .features,
            .content-section,
            footer {
                padding-left: 18px;
                padding-right: 18px;
            }

            .sessions-shell,
            .feature-card {
                border-radius: 8px;
            }
        }

        @media (max-width: 480px) {
            body {
                font-size: 14px;
            }

            .hero h1 {
                white-space: normal;
            }

            footer {
                flex-direction: column;
                gap: 18px;
            }

            .footer-links {
                justify-content: flex-start;
            }

            .btn {
                width: 100%;
            }

            .cta-buttons {
                flex-direction: column;
            }

            .sessions-shell,
            .feature-card,
            .session-card {
                padding: 18px;
            }
        }
    </style>
</head>
<body>
    <%- include('partials/sidebar', { page: 'home' }) %>

    <div class="main-content">
    <main>
        <section class="hero">
            <h1><%= title %></h1>
            <p><%= message %></p>
            <div class="cta-buttons">
                <a href="/sessions" class="btn btn-primary">
                    <span class="material-symbols-rounded">flight</span>
                    View Game Sessions
                </a>
                <a href="/charts" class="btn btn-secondary">
                    <span class="material-symbols-rounded">map</span>
                    Airport Charts
                </a>
            </div>
        </section>

        <section class="features">
            <a href="/sessions" class="feature-link">
                <div class="feature-card">
                    <h3><span class="material-symbols-rounded">radar</span>Live Sessions</h3>
                    <p>Join active game sessions with other pilots and air traffic controllers in real-time gameplay.</p>
                </div>
            </a>
            <a href="/charts" class="feature-link">
                <div class="feature-card">
                    <h3><span class="material-symbols-rounded">route</span>Flight Charts</h3>
                    <p>Access comprehensive airport charts and navigation data for accurate flight planning.</p>
                </div>
            </a>
            <a href="/discord" class="feature-link">
                <div class="feature-card">
                    <h3><span class="material-symbols-rounded">groups</span>Community</h3>
                    <p>Connect with fellow aviation enthusiasts and participate in a realistic flight simulation community.</p>
                </div>
            </a>
        </section>

        <section class="content-section">
            <h2 class="section-title">Upcoming Events</h2>
            <div class="sessions-shell">
                <div class="sessions-preview" id="sessionsList">
                    <p>Loading events...</p>
                </div>
            </div>
            <div style="text-align: center; margin-top: 30px;">
                <a href="/events" class="btn btn-primary">View All Events</a>
            </div>
        </section>

        <script>
            fetch('/api/events')
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Unable to load events right now.');
                    }

                    return response.json();
                })
                .then(payload => {
                    const sessionsList = document.getElementById('sessionsList');
                    sessionsList.innerHTML = '';
                    const events = Array.isArray(payload?.data) ? payload.data : [];
                    
                    if (events.length === 0) {
                        sessionsList.innerHTML = '<p>No events available at this time.</p>';
                        return;
                    }
                    
                    events.slice(0, 3).forEach(session => {
                        const statusClass = session.status === 'active' ? 'status-active' : 'status-upcoming';
                        
                        // Format duration: show in minutes if less than 1 hour
                        let formattedDuration = session.duration;
                        if (session.duration_minutes && session.duration_minutes < 60) {
                            formattedDuration = `${session.duration_minutes} minutes`;
                        }
                        
                        // Format start time
                        const startTime = session.startTime ? new Date(session.startTime).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '';
                        
                        const sessionHTML = `
                            <div class="session-card">
                                <h4>${session.name}</h4>
                                <p>Hosted by: ${session.hostName}</p>
                                <p>📍 Location: ${session.map}</p>
                                <p>🛫 Airport: ${session.airport}</p>
                                <p>👤 Expected Pilots: ${session.pilots}</p>
                                <p>🕐 Start: ${startTime}</p>
                                <p>⏱️ Duration: ${formattedDuration}</p>
                                <span class="session-status ${statusClass}">${(session.status || 'upcoming').toUpperCase()}</span>
                            </div>
                        `;
                        sessionsList.innerHTML += sessionHTML;
                    });
                })
                .catch(error => {
                    document.getElementById('sessionsList').innerHTML = '<p>' + error.message + '</p>';
                });
        </script>
    </main>

    <footer>
        <div class="footer-copy">
            <%#  <p>&copy; 2026 Aviation Realism Network. All rights reserved.</p> %>
            <p>Bringing realistic aviation simulation to VTOL VR</p>
        </div>
        <div class="footer-links">
            <a href="/information">Information</a>
            <%# <a href="/announcements">Announcements</a> %>
            <a href="/pilots">Pilots Directory</a>
            <a href="/applications">Applications</a>
        </div>
    </footer>
    </div>
</body>
</html>
