<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="author" content="Caleb Thomas (TheRavenSeb)">
    <meta name="description" content="Pilots Directory - Browse and search all pilots.">
    <meta name="keywords" content="Pilots, Directory, Aviation, VTOL VR">
    <title>Pilots Directory</title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        .main-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            min-height: 100vh;
        }

        .hamburger-btn {
            display: none;
            background: transparent;
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 10px;
            color: #e0e0e0;
            font-size: 1rem;
            cursor: pointer;
            padding: 10px;
            margin-right: 15px;
            transition: all 0.2s;
        }

        .hamburger-btn:hover,
        .hamburger-btn.active {
            color: #f5f3ef;
            background: #202020;
        }

        .hero {
            text-align: center;
            color: #e0e0e0;
            margin-bottom: 30px;
            padding-top: 20px;
        }

        .hero h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
        }

        .hero p {
            font-size: 1.1em;
            opacity: 0.9;
        }

        .search-container {
            width: 100%;
            max-width: 1200px;
            margin-left: auto;
            margin-right: auto;
            margin-bottom: 40px;
        }

        /* Grid + tile class name: theme.css strips *-card backgrounds; match sessions .lobby-tile */
        .pilots-container {
            width: 100%;
            max-width: 1200px;
            margin-left: auto;
            margin-right: auto;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 16px;
            margin-bottom: 40px;
        }

        .pilots-container > .no-results {
            grid-column: 1 / -1;
            max-width: 36rem;
            margin-left: auto;
            margin-right: auto;
        }

        .pilot-tile {
            background: #222222 !important;
            border-radius: 6px;
            padding: 20px;
        }

        .pilot-tile-head {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 14px;
        }

        .pilot-avatar {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            overflow: hidden;
            flex-shrink: 0;
            background: #2e2e2e;
            border: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .pilot-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .pilot-avatar-initials {
            font-size: 1.05rem;
            font-weight: 700;
            color: rgba(245, 243, 239, 0.45);
            letter-spacing: -0.02em;
            user-select: none;
        }

        .pilot-avatar-emoji {
            font-size: 1.5rem;
            line-height: 1;
            user-select: none;
        }

        .pilot-tile-head-text {
            min-width: 0;
            flex: 1;
        }

        .pilot-tile h3 {
            margin: 0 0 4px;
            color: #f5f3ef;
            font-size: 1.05em;
            font-weight: 600;
            line-height: 1.3;
        }

        .pilot-tile .pilot-callsign-line {
            margin: 0;
            color: rgba(245, 243, 239, 0.55);
            font-size: 0.875rem;
            font-weight: 500;
            line-height: 1.35;
        }

        .pilot-tile-body {
            padding-top: 14px;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
        }

        .pilot-tile-body p {
            color: rgba(245, 243, 239, 0.6);
            font-size: 0.875rem;
            margin-bottom: 6px;
            line-height: 1.45;
        }

        .pilot-tile-body p:last-child {
            margin-bottom: 0;
        }

        .no-results {
            text-align: center;
            padding: 32px 20px;
            background: #232323;
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.07);
            color: rgba(245, 243, 239, 0.5);
        }

        .no-results h3 {
            color: #e0e0e0;
            margin: 0 0 10px;
            font-size: 1.05em;
            font-weight: 600;
        }

        .no-results p {
            margin: 0;
            font-size: 0.875rem;
        }

        .results-count {
            color: #999;
            font-size: 0.95em;
            margin-bottom: 20px;
            text-align: center;
        }

        .results-count.is-error #resultsCount {
            color: #ffb0b0;
            font-size: 0.875rem;
        }

        footer {
            color: white;
            margin-top: 40px;
            text-align: center;
            opacity: 0.8;
            font-size: 0.8rem;
        }

        @media (max-width: 768px) {
            .hero h1 {
                font-size: 1.8em;
            }

            .hero p {
                font-size: 0.95em;
            }

            .search-container {
                max-width: 100%;
            }
        }

        @media (max-width: 480px) {
            .main-content {
                padding: 12px;
                padding-top: 0;
            }

            .hero {
                margin-bottom: 20px;
                padding-top: 10px;
            }

            .hero h1 {
                font-size: 1.6em;
                margin-bottom: 5px;
            }

            .hero p {
                font-size: 0.9em;
            }

            .pilots-container {
                gap: 16px;
                max-width: 100%;
            }

            .pilot-tile {
                padding: 18px 16px;
            }

            .results-count {
                font-size: 0.85em;
            }

            footer {
                font-size: 0.85em;
                margin-top: 30px;
            }
        }
        <%- include('partials/fixed-sidebar-theme') %>
    </style>
</head>
<body>
        <%- include('partials/sidebar', { page: 'pilots' }) %>

    <div class="main-content">
        <div class="hero">
            <h1>Pilots Directory</h1>
            <p>Browse and search all pilots in our network</p>
        </div>

        <div class="search-container">
            <div class="search-toolbar-row">
                <div class="search-box">
                    <input 
                        type="text" 
                        id="searchInput" 
                        placeholder="Search pilots by name or callsign..." 
                        onkeyup="searchPilots()"
                    >
                    <button type="button" onclick="searchPilots()">Search</button>
                </div>
                <section class="filters filters--in-search" aria-label="Pilot filters">
                    <div class="filter-toolbar">
                        <%- include('partials/filter-popover', {
                            triggerLabel: 'Filters',
                            items: [
                                { id: 'pilotFilterAtc', label: 'ATC', checked: true },
                                { id: 'pilotFilterEnforcer', label: 'Enforcer', checked: true }
                            ]
                        }) %>
                    </div>
                </section>
            </div>

            <div class="results-count" id="resultsCountWrap">
                <span id="resultsCount">Loading pilots…</span>
            </div>
        </div>

        <div class="pilots-container" id="pilotsContainer"></div>

        <footer>
            <%#  <p>&copy; 2026 Aviation Realism Network. All rights reserved.</p> %>
            <p>Bringing realistic aviation simulation to VTOL VR</p>
        </footer>
    </div>

    <script>
        let allPilots = [];

        function escapeHtml(value) {
            if (value == null) return '';
            return String(value)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }

        function escapeAttr(value) {
            if (value == null) return '';
            return String(value)
                .replace(/&/g, '&amp;')
                .replace(/"/g, '&quot;')
                .replace(/</g, '&lt;');
        }

        function isAvatarImageUrl(s) {
            if (s == null || typeof s !== 'string') return false;
            var t = s.trim();
            if (!t) return false;
            return /^https?:\/\//i.test(t) || t.indexOf('/') === 0 || t.indexOf('data:image/') === 0;
        }

        function pilotInitials(username) {
            var n = (username && String(username).trim()) || '';
            if (!n) return '?';
            return n.slice(0, 2).toUpperCase();
        }

        function pilotAvatarHtml(pilot) {
            var av = pilot.avatar;
            if (isAvatarImageUrl(av)) {
                return (
                    '<img src="' + escapeAttr(av) + '" alt="" loading="lazy" decoding="async">'
                );
            }
            if (av != null && String(av).trim() !== '') {
                return '<span class="pilot-avatar-emoji" aria-hidden="true">' + escapeHtml(String(av).trim()) + '</span>';
            }
            return '<span class="pilot-avatar-initials">' + escapeHtml(pilotInitials(pilot.Username)) + '</span>';
        }

        var ROLE_ORDER = ['atc', 'enforcer', 'user'];

        function roleLabelUpper(key) {
            if (key === 'atc') return 'ATC';
            if (key === 'enforcer') return 'ENFORCER';
            if (key === 'user') return 'PILOT';
            if (key === 'none') return 'NONE';
            return String(key).toUpperCase();
        }

        /** Ordered role keys for display and filtering. */
        function pilotRoleEntries(roles) {
            if (!roles || !roles.length) {
                return [{ key: 'none' }];
            }
            var set = {};
            roles.forEach(function (r) {
                set[String(r).toLowerCase().trim()] = true;
            });
            var out = [];
            ROLE_ORDER.forEach(function (k) {
                if (set[k]) {
                    out.push({ key: k });
                    delete set[k];
                }
            });
            Object.keys(set).sort().forEach(function (k) {
                out.push({ key: k });
            });
            return out;
        }

        function pilotRolesLine(pilot) {
            var entries = pilotRoleEntries(pilot.Role);
            var labels = entries
                .filter(function (e) { return e.key !== 'none'; })
                .map(function (e) { return roleLabelUpper(e.key); });
            if (labels.length) return labels.join(' · ');
            return 'None';
        }

        function matchesPilotRoleFilters(pilot) {
            const atcOn = document.getElementById('pilotFilterAtc')?.checked;
            const enfOn = document.getElementById('pilotFilterEnforcer')?.checked;
            const roles = (pilot.Role || []).map(function (r) { return String(r).toLowerCase(); });
            if (roles.length === 0) return true;

            if (roles.includes('atc') && !atcOn) return false;
            if (roles.includes('enforcer') && !enfOn) return false;
            return true;
        }

        document.addEventListener('DOMContentLoaded', function() {
            fetchPilots();
            ['pilotFilterAtc', 'pilotFilterEnforcer'].forEach(function (id) {
                const el = document.getElementById(id);
                if (el) el.addEventListener('change', searchPilots);
            });
        });

        async function fetchPilots() {
            try {
                const response = await fetch('/api/pilots', { credentials: 'same-origin' });
                if (!response.ok) {
                    throw new Error('Unable to load pilots data right now.');
                }

                const data = await response.json();
                allPilots = data.data || [];
                displayPilots(allPilots);
            } catch {
                document.getElementById('pilotsContainer').innerHTML = '';
                document.getElementById('resultsCountWrap').classList.add('is-error');
                document.getElementById('resultsCount').textContent = 'Unable to load pilots right now.';
            }
        }

        function displayPilots(pilots) {
            const container = document.getElementById('pilotsContainer');
            const resultsCount = document.getElementById('resultsCount');
            document.getElementById('resultsCountWrap').classList.remove('is-error');

            if (pilots.length === 0) {
                container.innerHTML = `
                    <div class="no-results">
                        <h3>No pilots found</h3>
                        <p>Try adjusting your search filters or criteria.</p>
                    </div>
                `;
                resultsCount.textContent = 'No results found';
            } else {
                resultsCount.textContent = `Showing ${pilots.length} pilot(s)`;
                container.innerHTML = pilots.map(function (pilot) {
                    var name = escapeHtml(pilot.Username || 'Unknown');
                    var callsignRaw = pilot.Callsign ? String(pilot.Callsign).trim() : '';
                    var callsignDisplay = escapeHtml(callsignRaw || 'No callsign');
                    var hours = Number(pilot.Flighthours);
                    var hoursDisplay = Number.isFinite(hours) ? hours : 0;
                    var rolesLine = escapeHtml(pilotRolesLine(pilot));
                    var avatarInner = pilotAvatarHtml(pilot);
                    return (
                        '<article class="pilot-tile">' +
                            '<div class="pilot-tile-head">' +
                                '<div class="pilot-avatar">' + avatarInner + '</div>' +
                                '<div class="pilot-tile-head-text">' +
                                    '<h3>' + name + '</h3>' +
                                    '<p class="pilot-callsign-line">' + callsignDisplay + '</p>' +
                                '</div>' +
                            '</div>' +
                            '<div class="pilot-tile-body">' +
                                '<p><strong>Flight hours:</strong> ' + hoursDisplay + '</p>' +
                                '<p><strong>Roles:</strong> ' + rolesLine + '</p>' +
                            '</div>' +
                        '</article>'
                    );
                }).join('');
            }
        }

        function searchPilots() {
            const searchQuery = document.getElementById('searchInput').value.toLowerCase();
            
            let filtered = allPilots.filter(pilot => {
                const matchesSearch = !searchQuery || 
                    (pilot.Username && pilot.Username.toLowerCase().includes(searchQuery)) ||
                    (pilot.Callsign && pilot.Callsign.toLowerCase().includes(searchQuery));

                return matchesSearch && matchesPilotRoleFilters(pilot);
            });

            displayPilots(filtered);
        }
    </script>
</body>
</html>
