<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="author" content="Caleb Thomas (TheRavenSeb)">
    <meta name="description" content="Admin Panel - Manage members, roles, and flight hours.">
    <title>Admin Dashboard</title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #1a1a1a;
            color: #e0e0e0;
            min-height: 100vh;
            display: flex;
        }

        .main-content {
            margin-left: 280px;
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            padding: 40px 32px;
        }

        .page-header {
            text-align: center;
            padding-top: 20px;
            margin-bottom: 30px;
        }

        .page-title {
            font-size: 2.5em;
            font-weight: 700;
            color: #e0e0e0;
            margin-bottom: 10px;
        }

        .page-subtitle {
            font-size: 1.1em;
            color: #e0e0e0;
            opacity: 0.9;
        }

        .panel {
            display: flex;
            flex-direction: column;
            gap: 20px;
            max-width: 1100px;
            width: 100%;
            margin: 0 auto;
        }

        .panel-title {
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #888;
        }

        .search-input {
            width: 100%;
            padding: 10px 12px;
            background: #1a1a1a;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 6px;
            color: #e0e0e0;
            font-size: 0.92rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .search-input:focus {
            outline: none;
            border-color: rgba(255,255,255,0.25);
            box-shadow: 0 0 0 3px rgba(255,255,255,0.04);
        }

        .search-input::placeholder { color: #555; }

        .members-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .member-item {
            border-left: 3px solid rgba(255,255,255,0.18);
            padding: 16px 18px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            transition: border-color 0.2s;
        }

        .member-item:hover { border-left-color: rgba(255,255,255,0.4); }

        .member-info { flex: 1; min-width: 0; }

        .member-name {
            font-weight: 600;
            font-size: 0.98rem;
            color: #f0f0f0;
            margin-bottom: 6px;
        }

        .member-details {
            display: flex;
            gap: 18px;
            flex-wrap: wrap;
            font-size: 0.82rem;
            color: #888;
        }

        .detail-item { display: flex; gap: 5px; }
        .detail-label { color: #666; }

        .member-actions {
            display: flex;
            gap: 8px;
            flex-shrink: 0;
        }

        .btn {
            padding: 7px 16px;
            border: none;
            border-radius: 6px;
            font-size: 0.82rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .btn:hover { opacity: 0.82; }

        .btn-edit {
            background: rgba(255,255,255,0.1);
            color: #e0e0e0;
            border: 1px solid rgba(255,255,255,0.12);
        }

        .btn-primary {
            background: #e0e0e0;
            color: #1a1a1a;
        }

        .btn-secondary {
            background: transparent;
            color: #aaa;
            border: 1px solid rgba(255,255,255,0.12);
        }

        .btn-danger {
            background: rgba(224, 92, 92, 0.15);
            color: #ef9a9a;
            border: 1px solid rgba(224, 92, 92, 0.25);
        }

        .empty-state {
            text-align: center;
            color: #555;
            padding: 40px 20px;
            font-size: 0.9rem;
        }

        .list-status {
            text-align: center;
            font-size: 0.875rem;
            color: rgba(245,243,239,0.45);
            padding: 24px 16px;
        }

        .list-status--error {
            color: #ffb0b0;
        }

        /* Modal */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            inset: 0;
            background: rgba(0,0,0,0.65);
            backdrop-filter: blur(4px);
        }

        .modal.show {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: #232323;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            padding: 28px;
            max-width: 500px;
            width: calc(100% - 32px);
            max-height: 85vh;
            overflow-y: auto;
            color: #e0e0e0;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            padding-bottom: 14px;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .modal-header h2 {
            font-size: 1.1rem;
            font-weight: 700;
            color: #f0f0f0;
        }

        .modal-close {
            background: none;
            border: none;
            color: #888;
            font-size: 22px;
            cursor: pointer;
            line-height: 1;
            padding: 2px;
            transition: color 0.2s;
        }

        .modal-close:hover { color: #e0e0e0; }

        .form-group { margin-bottom: 18px; }

        .form-label {
            display: block;
            font-size: 0.82rem;
            font-weight: 600;
            color: #aaa;
            margin-bottom: 6px;
        }

        .form-input,
        .form-select {
            width: 100%;
            padding: 9px 12px;
            background: #1a1a1a;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 6px;
            color: #e0e0e0;
            font-size: 0.9rem;
            transition: border-color 0.2s;
        }

        .form-input:focus,
        .form-select:focus {
            outline: none;
            border-color: rgba(255,255,255,0.25);
        }

        .form-input::placeholder { color: #555; }

        .member-display {
            padding: 9px 12px;
            background: #1a1a1a;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 6px;
            color: #888;
            font-size: 0.9rem;
        }

        .role-list {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 16px;
        }

        .role-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 12px;
            background: #1a1a1a;
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 6px;
        }

        .role-name {
            font-size: 0.88rem;
            font-weight: 600;
            color: #c0c0c0;
        }

        .remove-role-btn {
            background: rgba(224, 92, 92, 0.15);
            color: #ef9a9a;
            border: 1px solid rgba(224, 92, 92, 0.25);
            padding: 3px 10px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.78rem;
            transition: opacity 0.2s;
        }

        .remove-role-btn:hover { opacity: 0.75; }

        .button-group {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }

        .button-group .btn { flex: 1; padding: 11px; font-size: 0.9rem; }

        .alert {
            padding: 11px 14px;
            border-radius: 6px;
            font-size: 0.85rem;
            font-weight: 500;
            margin-bottom: 16px;
            display: none;
        }

        .alert.show { display: block; }

        .alert-success {
            background: rgba(74, 175, 80, 0.12);
            border: 1px solid rgba(74, 175, 80, 0.3);
            color: #81c784;
        }

        .alert-error {
            background: rgba(224, 92, 92, 0.12);
            border: 1px solid rgba(224, 92, 92, 0.28);
            color: #ef9a9a;
        }

        footer {
            margin-top: auto;
            padding-top: 40px;
            text-align: center;
            font-size: 0.8rem;
            color: #555;
        }

        @media (max-width: 768px) {
            .main-content { margin-left: 0; padding: 20px 16px; }

            .member-item {
                flex-direction: column;
                align-items: flex-start;
                gap: 12px;
            }

            .member-actions { width: 100%; }
            .btn-edit { flex: 1; text-align: center; }
        }

        <%- include('../partials/fixed-sidebar-theme') %>
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { page: 'admin' }) %>

    <div class="main-content">
        <div class="page-header">
            <h1 class="page-title">Admin Dashboard</h1>
            <p class="page-subtitle">Manage members, roles, and flight hours for the Aviation Realism Network.</p>
        </div>

        <div class="panel">
            <div class="panel-title">Members Management</div>

            <div class="search-toolbar-row" style="margin-bottom: 16px;">
                <div class="search-box">
                    <input type="text" class="search-input" id="searchInput" placeholder="Search by username or Discord ID…" onkeyup="filterMembers()">
                </div>
                <section class="filters filters--in-search" aria-label="Role filters">
                    <div class="filter-toolbar">
                        <%- include('../partials/filter-popover', {
                            triggerLabel: 'Roles',
                            panelId: 'adminMemberRoleFilterPanel',
                            items: []
                        }) %>
                    </div>
                </section>
            </div>

            <div class="members-list" id="membersList">
                <div class="empty-state">Loading members…</div>
            </div>
        </div>

        <div id="editMemberModal" class="modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 id="modalTitle">Edit Member</h2>
                    <button class="modal-close" onclick="closeEditModal()">&times;</button>
                </div>

                <div id="successMessage" class="alert alert-success"></div>
                <div id="errorMessage" class="alert alert-error"></div>

                <div class="form-group">
                    <label class="form-label">Username</label>
                    <div class="member-display" id="memberUsername"></div>
                </div>

                <div class="form-group">
                    <label class="form-label">Flight Hours</label>
                    <input type="number" class="form-input" id="flighthours" placeholder="Enter flight hours" min="0" step="0.1">
                </div>

                <div class="form-group">
                    <label class="form-label">Callsign</label>
                    <input type="text" class="form-input" id="callsign" placeholder="e.g. N123C" maxlength="5" style="text-transform: uppercase;">
                </div>

                <div class="form-group">
                    <label class="form-label">Current Roles</label>
                    <div class="role-list" id="currentRoles"></div>
                    <label class="form-label" style="margin-top: 12px;">Add Role</label>
                    <select class="form-select" id="roleSelect">
                        <option value="">Select a role to add…</option>
                        <option value="admin">Admin</option>
                        <option value="atc">ATC</option>
                        <option value="enforcer">Enforcer</option>
                        <option value="mod">Moderator</option>
                        <option value="user">User</option>
                        <option value="owner">Owner</option>
                    </select>
                </div>

                <div class="button-group">
                    <button class="btn btn-primary" onclick="saveChanges()">Save Changes</button>
                    <button class="btn btn-secondary" onclick="closeEditModal()">Cancel</button>
                </div>
            </div>
        </div>

        <footer>
            <p>Bringing realistic aviation simulation to VTOL VR</p>
        </footer>
    </div>

    <script>
        let allMembers = [];
        let filteredMembers = [];
        let currentEditingMemberId = null;
        let currentEditingMemberRoles = [];

        function buildAdminMemberRoleFilterCheckboxes() {
            const panel = document.getElementById('adminMemberRoleFilterPanel');
            if (!panel) return;
            panel.querySelectorAll('[data-role-filter-dynamic]').forEach(function (el) { el.remove(); });

            const roleSet = new Set();
            allMembers.forEach(function (m) {
                const roles = m.Role && m.Role.length ? m.Role : ['user'];
                roles.forEach(function (r) { if (r) roleSet.add(r); });
            });
            const sorted = Array.from(roleSet).sort(function (a, b) { return a.localeCompare(b); });
            sorted.forEach(function (role) {
                const safeId = 'adminRole_' + role.replace(/[^a-zA-Z0-9_-]/g, '_');
                const label = document.createElement('label');
                label.className = 'filter-popover__row';
                label.setAttribute('data-role-filter-dynamic', '1');
                label.setAttribute('for', safeId);
                const input = document.createElement('input');
                input.type = 'checkbox';
                input.id = safeId;
                input.checked = true;
                input.setAttribute('data-role-name', role);
                const span = document.createElement('span');
                span.className = 'filter-popover__row-label';
                span.textContent = role;
                label.appendChild(input);
                label.appendChild(span);
                panel.appendChild(label);
                input.addEventListener('change', filterMembers);
            });
        }

        function adminMemberRoleFilterPass(member) {
            const panel = document.getElementById('adminMemberRoleFilterPanel');
            if (!panel) return true;
            const checked = Array.prototype.slice.call(panel.querySelectorAll('input[type="checkbox"]'))
                .filter(function (cb) { return cb.checked; })
                .map(function (cb) { return cb.getAttribute('data-role-name'); })
                .filter(Boolean);
            if (checked.length === 0) return true;
            const roles = member.Role && member.Role.length ? member.Role : ['user'];
            return roles.some(function (r) { return checked.indexOf(r) !== -1; });
        }

        function filterMembers() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            filteredMembers = allMembers.filter(m => {
                const searchOk = searchTerm === '' ||
                    m.Username.toLowerCase().includes(searchTerm) ||
                    (m.DiscordId && m.DiscordId.toString().includes(searchTerm));
                return searchOk && adminMemberRoleFilterPass(m);
            });
            renderMembers();
        }

        function renderMembers() {
            const container = document.getElementById('membersList');
            if (filteredMembers.length === 0) {
                container.innerHTML = '<div class="empty-state">No members found.</div>';
                return;
            }
            container.innerHTML = filteredMembers.map(member => `
                <div class="member-item">
                    <div class="member-info">
                        <div class="member-name">${member.Username}</div>
                        <div class="member-details">
                            <div class="detail-item">
                                <span class="detail-label">Hours:</span>
                                <span>${member.Flighthours || 0}</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Callsign:</span>
                                <span>${member.Callsign || '—'}</span>
                            </div>
                            <div class="detail-item">
                                <span class="detail-label">Roles:</span>
                                <span>${member.Role ? member.Role.join(', ') : 'user'}</span>
                            </div>
                            ${member.DiscordId ? `<div class="detail-item">
                                <span class="detail-label">Discord:</span>
                                <span>${member.DiscordId}</span>
                            </div>` : ''}
                        </div>
                    </div>
                    <div class="member-actions">
                        <button class="btn btn-edit" onclick="openEditModal('${member._id}')">Edit</button>
                    </div>
                </div>
            `).join('');
        }

        function openEditModal(memberId) {
            const member = allMembers.find(m => m._id === memberId);
            if (!member) return;

            currentEditingMemberId = memberId;
            currentEditingMemberRoles = member.Role ? [...member.Role] : [];

            document.getElementById('modalTitle').textContent = 'Edit ' + member.Username;
            document.getElementById('memberUsername').textContent = member.Username;
            document.getElementById('flighthours').value = member.Flighthours || 0;
            document.getElementById('callsign').value = member.Callsign || '';
            document.getElementById('roleSelect').value = '';

            renderRoleList();
            clearMessages();
            document.getElementById('editMemberModal').classList.add('show');
        }

        function closeEditModal() {
            document.getElementById('editMemberModal').classList.remove('show');
            currentEditingMemberId = null;
            currentEditingMemberRoles = [];
        }

        function renderRoleList() {
            const container = document.getElementById('currentRoles');
            if (currentEditingMemberRoles.length === 0) {
                container.innerHTML = '<div style="color:#555; font-size:0.85rem;">No roles assigned</div>';
                return;
            }
            container.innerHTML = currentEditingMemberRoles.map(role => `
                <div class="role-item">
                    <span class="role-name">${role}</span>
                    <button class="remove-role-btn" onclick="removeRole('${role}')">Remove</button>
                </div>
            `).join('');
        }

        function removeRole(role) {
            currentEditingMemberRoles = currentEditingMemberRoles.filter(r => r !== role);
            renderRoleList();
        }

        function addRole() {
            const roleSelect = document.getElementById('roleSelect');
            const role = roleSelect.value;
            if (!role) { showError('Please select a role to add'); return; }
            if (currentEditingMemberRoles.includes(role)) { showError('Member already has this role'); return; }
            currentEditingMemberRoles.push(role);
            roleSelect.value = '';
            renderRoleList();
        }

        document.addEventListener('change', function(e) {
            if (e.target.id === 'roleSelect' && e.target.value) addRole();
        });

        function saveChanges() {
            if (!currentEditingMemberId) { showError('No member selected'); return; }

            const flighthours = parseFloat(document.getElementById('flighthours').value);
            if (isNaN(flighthours) || flighthours < 0) { showError('Flight hours must be a valid non-negative number'); return; }

            const member = allMembers.find(m => m._id === currentEditingMemberId);
            const originalRoles = member.Role || [];
            const rolesToAdd = currentEditingMemberRoles.filter(r => !originalRoles.includes(r));
            const rolesToRemove = originalRoles.filter(r => !currentEditingMemberRoles.includes(r));

            const promises = [
                fetch('/api/admin/users/' + currentEditingMemberId + '/updateFlighthours', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ flighthours })
                }).then(r => { if (!r.ok) throw new Error('Failed to update flight hours'); return r.json(); }),
                ...rolesToAdd.map(role =>
                    fetch('/api/admin/users/' + currentEditingMemberId + '/updateRole', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ role })
                    }).then(r => { if (!r.ok) throw new Error('Failed to add role: ' + role); return r.json(); })
                ),
                ...rolesToRemove.map(role =>
                    fetch('/api/admin/users/' + currentEditingMemberId + '/removeRole', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ role })
                    }).then(r => { if (!r.ok) throw new Error('Failed to remove role: ' + role); return r.json(); })
                )
            ];

            Promise.all(promises)
                .then(() => {
                    showSuccess('Member updated successfully');
                    setTimeout(() => { closeEditModal(); loadMembers(); }, 1500);
                })
                .catch(error => {
                    showError('Error saving changes: ' + error.message);
                });
        }

        function showSuccess(message) {
            const el = document.getElementById('successMessage');
            el.textContent = message;
            el.classList.add('show');
        }

        function showError(message) {
            const el = document.getElementById('errorMessage');
            el.textContent = message;
            el.classList.add('show');
        }

        function clearMessages() {
            document.getElementById('successMessage').classList.remove('show');
            document.getElementById('errorMessage').classList.remove('show');
        }

        function loadMembers() {
            fetch('/api/admin/users')
                .then(r => { if (!r.ok) throw new Error('Failed to load members.'); return r.json(); })
                .then(payload => {
                    allMembers = payload.data || payload || [];
                    buildAdminMemberRoleFilterCheckboxes();
                    filterMembers();
                })
                .catch(() => {
                    document.getElementById('membersList').innerHTML =
                        '<p class="list-status list-status--error">Unable to load members right now.</p>';
                });
        }

        loadMembers();

        window.onclick = function(event) {
            const modal = document.getElementById('editMemberModal');
            if (event.target === modal) modal.classList.remove('show');
        };
    </script>
</body>
</html>
