<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="author" content="Caleb Thomas (TheRavenSeb)">
    <meta name="description" content="Applications - View and manage ATC and Enforcer applications.">
    <title>Applications Admin</title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #1a1a1a;
            color: #e0e0e0;
            min-height: 100vh;
            display: flex;
        }

        .main-content {
            margin-left: 280px;
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            padding: 40px 32px;
        }

        .page-header {
            text-align: center;
            padding-top: 20px;
            margin-bottom: 30px;
        }

        .page-title {
            font-size: 2.5em;
            font-weight: 700;
            color: #e0e0e0;
            margin-bottom: 10px;
        }

        .page-subtitle {
            font-size: 1.1em;
            color: #e0e0e0;
            opacity: 0.9;
        }

        .content-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            max-width: 1100px;
            width: 100%;
            margin: 0 auto;
        }

        .panel {
            padding: 24px 0;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .panel-title {
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #888;
            padding-bottom: 12px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .search-input {
            width: 100%;
            padding: 10px 12px;
            background: #1a1a1a;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 6px;
            color: #e0e0e0;
            font-size: 0.88rem;
            transition: border-color 0.2s;
        }

        .search-input:focus {
            outline: none;
            border-color: rgba(255,255,255,0.25);
        }

        .search-input::placeholder { color: #555; }

        .application-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .application-item {
            background: #1e1e1e;
            border: 1px solid rgba(255,255,255,0.07);
            border-left: 3px solid rgba(255,255,255,0.15);
            border-radius: 8px;
            padding: 14px 16px;
            transition: border-color 0.2s;
        }

        .application-item:hover { border-color: rgba(255,255,255,0.18); }

        .application-item.pending  { border-left-color: #e8a838; }
        .application-item.approved { border-left-color: #5ca85e; }
        .application-item.rejected { border-left-color: #c05050; }

        .application-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 6px;
        }

        .applicant-name {
            font-weight: 600;
            font-size: 0.95rem;
            color: #f0f0f0;
        }

        .status-badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .status-pending  { background: rgba(232, 168, 56, 0.18); color: #e8a838; border: 1px solid rgba(232,168,56,0.3); }
        .status-approved { background: rgba(92, 168, 94, 0.15);  color: #81c784; border: 1px solid rgba(92,168,94,0.3); }
        .status-rejected { background: rgba(192, 80, 80, 0.15);  color: #ef9a9a; border: 1px solid rgba(192,80,80,0.3); }

        .application-meta {
            font-size: 0.8rem;
            color: #888;
            margin-bottom: 4px;
        }

        .application-date {
            font-size: 0.76rem;
            color: #555;
        }

        .application-actions {
            display: flex;
            gap: 6px;
            margin-top: 10px;
            flex-wrap: wrap;
        }

        .btn {
            padding: 5px 14px;
            border: none;
            border-radius: 5px;
            font-size: 0.78rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .btn:hover { opacity: 0.8; }

        .btn-view {
            background: rgba(255,255,255,0.1);
            color: #e0e0e0;
            border: 1px solid rgba(255,255,255,0.12);
        }

        .btn-approve {
            background: rgba(92, 168, 94, 0.15);
            color: #81c784;
            border: 1px solid rgba(92, 168, 94, 0.3);
        }

        .btn-reject {
            background: rgba(192, 80, 80, 0.15);
            color: #ef9a9a;
            border: 1px solid rgba(192, 80, 80, 0.3);
        }

        .empty-state {
            text-align: center;
            color: #555;
            padding: 32px 16px;
            font-size: 0.88rem;
        }

        .list-status {
            text-align: center;
            font-size: 0.875rem;
            color: #ffb0b0;
            padding: 20px 16px;
        }

        /* Modal */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            inset: 0;
            background: rgba(0,0,0,0.65);
            backdrop-filter: blur(4px);
        }

        .modal.show {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: #232323;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            padding: 28px;
            max-width: 580px;
            width: calc(100% - 32px);
            max-height: 85vh;
            overflow-y: auto;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 22px;
            padding-bottom: 14px;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .modal-header h2 {
            font-size: 1.05rem;
            font-weight: 700;
            color: #f0f0f0;
        }

        .modal-close {
            background: none;
            border: none;
            color: #888;
            font-size: 22px;
            cursor: pointer;
            line-height: 1;
            transition: color 0.2s;
        }

        .modal-close:hover { color: #e0e0e0; }

        .qa-item { margin-bottom: 16px; }

        .qa-question {
            font-size: 0.78rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #888;
            margin-bottom: 5px;
        }

        .qa-answer {
            font-size: 0.88rem;
            color: #c0c0c0;
            padding: 10px 12px;
            background: #1a1a1a;
            border-left: 2px solid rgba(255,255,255,0.15);
            border-radius: 4px;
            line-height: 1.5;
        }

        footer {
            margin-top: auto;
            padding-top: 40px;
            text-align: center;
            font-size: 0.8rem;
            color: #555;
        }

        @media (max-width: 900px) {
            .content-grid { grid-template-columns: 1fr; }
        }

        @media (max-width: 768px) {
            .main-content { margin-left: 0; padding: 20px 16px; }
        }

        <%- include('../partials/fixed-sidebar-theme') %>
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { page: 'applicationsAdmin' }) %>

    <div class="main-content">
        <div class="page-header">
            <h1 class="page-title">Applications</h1>
            <p class="page-subtitle">Manage ATC and Enforcer applications for the Aviation Realism Network.</p>
        </div>

        <div style="max-width: 1100px; width: 100%; margin: 0 auto 20px;">
            <div class="search-toolbar-row" style="margin-bottom: 0;">
                <div class="search-box">
                    <input type="text" class="search-input" id="searchInput" placeholder="Search by name, callsign, or Discord handle…" onkeyup="filterApplications()">
                </div>
                <section class="filters filters--in-search" aria-label="Application status filters">
                    <div class="filter-toolbar">
                        <%- include('../partials/filter-popover', {
                            triggerLabel: 'Status',
                            panelId: 'appFilterStatusPanel',
                            items: [
                                { id: 'appFilterPending', label: 'Pending', checked: true },
                                { id: 'appFilterApproved', label: 'Approved', checked: true },
                                { id: 'appFilterRejected', label: 'Rejected', checked: true }
                            ]
                        }) %>
                    </div>
                </section>
            </div>
        </div>

        <div class="content-grid">
            <div class="panel">
                <div class="panel-title">ATC Applications</div>
                <div class="application-list" id="atcList">
                    <div class="empty-state">No ATC applications at this time.</div>
                </div>
            </div>

            <div class="panel">
                <div class="panel-title">Enforcer Applications</div>
                <div class="application-list" id="enforcerList">
                    <div class="empty-state">No Enforcer applications at this time.</div>
                </div>
            </div>
        </div>

        <div id="applicationModal" class="modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 id="modalTitle">Application Details</h2>
                    <button class="modal-close" onclick="closeModal()">&times;</button>
                </div>
                <div id="modalBody"></div>
            </div>
        </div>

        <footer>
            <p>Bringing realistic aviation simulation to VTOL VR</p>
        </footer>
    </div>

    <script>
        let allApplications = [];
        let filteredApplications = [];

        function applicationStatusFilterPass(app) {
            const s = (app.status || '').toLowerCase();
            if (s === 'pending') return !!(document.getElementById('appFilterPending') && document.getElementById('appFilterPending').checked);
            if (s === 'approved') return !!(document.getElementById('appFilterApproved') && document.getElementById('appFilterApproved').checked);
            if (s === 'rejected') return !!(document.getElementById('appFilterRejected') && document.getElementById('appFilterRejected').checked);
            return true;
        }

        function filterApplications() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            filteredApplications = allApplications.filter(app => {
                const searchOk = searchTerm === '' ||
                    app.name.toLowerCase().includes(searchTerm) ||
                    app.callsign.toLowerCase().includes(searchTerm) ||
                    app.discordHandle.toLowerCase().includes(searchTerm);
                return searchOk && applicationStatusFilterPass(app);
            });

            renderApplications(filteredApplications.filter(a => a.type === 'atc'), 'atcList', 'ATC');
            renderApplications(filteredApplications.filter(a => a.type === 'enforcer'), 'enforcerList', 'Enforcer');
        }

        function renderApplications(applications, containerId, type) {
            const container = document.getElementById(containerId);
            if (applications.length === 0) {
                container.innerHTML = '<div class="empty-state">No ' + type + ' applications at this time.</div>';
                return;
            }
            container.innerHTML = applications.map(app => `
                <div class="application-item ${app.status}">
                    <div class="application-header">
                        <span class="applicant-name">${app.name}</span>
                        <span class="status-badge status-${app.status}">${app.status}</span>
                    </div>
                    <div class="application-meta">${app.callsign} &middot; ${app.discordHandle}</div>
                    <div class="application-date">Applied ${new Date(app.date).toLocaleDateString()}</div>
                    <div class="application-actions">
                        <button class="btn btn-view" onclick="openApplicationModal('${app._id || app.id}')">View</button>
                        ${app.status === 'pending' ? `
                            <button class="btn btn-approve" onclick="approveApplication('${app._id || app.id}')">Approve</button>
                            <button class="btn btn-reject" onclick="rejectApplication('${app._id || app.id}')">Reject</button>
                        ` : ''}
                    </div>
                </div>
            `).join('');
        }

        function openApplicationModal(appId) {
            const application = allApplications.find(app => (app._id || app.id) === appId);
            if (!application) return;

            document.getElementById('modalTitle').textContent = application.name + ' — Application';

            const fields = [
                { q: 'Name', a: application.name },
                { q: 'Callsign / Discord', a: application.callsign + ' / ' + application.discordHandle },
                { q: 'Application Type', a: application.type.toUpperCase() },
                { q: 'Status', a: application.status.toUpperCase() },
                { q: 'Applied On', a: new Date(application.date).toLocaleString() },
                { q: 'Experience', a: application.experience || 'N/A' },
                { q: 'Why do you want to join?', a: application.whyJoin || 'N/A' },
            ];

            let html = fields.map(f => `
                <div class="qa-item">
                    <div class="qa-question">${f.q}</div>
                    <div class="qa-answer">${f.a}</div>
                </div>
            `).join('');

            if (application.responses && Array.isArray(application.responses)) {
                application.responses.forEach(resp => {
                    html += `
                        <div class="qa-item">
                            <div class="qa-question">${resp.question || 'Question'}</div>
                            <div class="qa-answer">${resp.answer || 'No answer provided'}</div>
                        </div>
                    `;
                });
            }

            document.getElementById('modalBody').innerHTML = html;
            document.getElementById('applicationModal').classList.add('show');
        }

        function closeModal() {
            document.getElementById('applicationModal').classList.remove('show');
        }

        function approveApplication(appId) {
            if (!confirm('Approve this application?')) return;
            fetch('/api/applications/' + appId + '/approve', { method: 'POST' })
                .then(async response => {
                    const payload = await response.json();
                    if (!response.ok || payload.error) {
                        throw new Error(payload.error || 'Failed to approve application.');
                    }
                })
                .then(() => { closeModal(); location.reload(); })
                .catch(err => alert('Error: ' + err.message));
        }

        function rejectApplication(appId) {
            if (!confirm('Reject this application?')) return;
            fetch('/api/applications/' + appId + '/reject', { method: 'POST' })
                .then(async response => {
                    const payload = await response.json();
                    if (!response.ok || payload.error) {
                        throw new Error(payload.error || 'Failed to reject application.');
                    }
                })
                .then(() => { closeModal(); location.reload(); })
                .catch(err => alert('Error: ' + err.message));
        }

        window.onclick = function(event) {
            const modal = document.getElementById('applicationModal');
            if (event.target === modal) modal.classList.remove('show');
        };

        var appFilterStatusPanel = document.getElementById('appFilterStatusPanel');
        if (appFilterStatusPanel) {
            appFilterStatusPanel.addEventListener('change', function (ev) {
                if (ev.target && ev.target.matches && ev.target.matches('input[type="checkbox"]')) filterApplications();
            });
        }

        fetch('/api/applications')
            .then(r => { if (!r.ok) throw new Error('Failed to load applications.'); return r.json(); })
            .then(payload => {
                allApplications = payload.data || payload || [];
                filterApplications();
            })
            .catch(() => {
                const msg = '<p class="list-status">Unable to load applications right now.</p>';
                document.getElementById('atcList').innerHTML = msg;
                document.getElementById('enforcerList').innerHTML = msg;
            });
    </script>
</body>
</html>
