<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="author" content="Caleb Thomas (TheRavenSeb)">
    <meta name="description" content="Applications - View and manage ATC and Enforcer applications.">
    <meta name="keywords" content="Applications, ATC, Enforcer, Aviation, Discord, Vtol VR">
    <title>Applications</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background-color: #1e1e1e;
            color: #e0e0e0;
            min-height: 100vh;
            display: flex;
            flex-direction: row;
            padding: 0;
            margin: 0;
            overflow-x: hidden;
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            overflow-y: auto;
            width: calc(100% - 280px);
            padding-top: 0;
        }

        .sidebar {
            width: 280px;
            background-color: #2a2a2a;
            border-right: 1px solid #444;
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 25px;
            overflow-y: auto;
            position: fixed;
            left: 0;
            top: 0;
            height: 100vh;
            z-index: 999;
            transition: transform 0.3s ease-in-out;
        }

        .sidebar.hidden {
            transform: translateX(-100%);
        }

        .hamburger-btn {
            display: none;
            background: none;
            border: none;
            color: #e0e0e0;
            font-size: 1.5em;
            cursor: pointer;
            padding: 10px 8px;
            margin-bottom: 0;
            transition: all 0.2s;
            margin-right: 10px;
            z-index: 1003;
        }

        .hamburger-btn:hover {
            color: #667eea;
        }

        .hamburger-btn.active {
            color: #667eea;
        }

        .close-sidebar-btn {
            display: none;
            position: absolute;
            top: 10px;
            right: 10px;
            background: none;
            border: none;
            color: #e0e0e0;
            font-size: 28px;
            cursor: pointer;
            padding: 5px 10px;
            width: auto;
            height: auto;
            z-index: 1002;
            transition: all 0.2s;
        }

        .close-sidebar-btn:hover {
            color: #667eea;
        }

        .header-content {
            display: flex;
            align-items: center;
            gap: 15px;
            width: 100%;
        }

        .sidebar-logo {
            width: 120px;
            height: 120px;
            background-color: #e0e0e0;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
            color: #2a2a2a;
        }

        .sidebar-title {
            text-align: center;
            color: #e0e0e0;
            font-size: 1.3em;
            font-weight: bold;
            line-height: 1.3;
        }

        .sidebar-title a {
            color: #e0e0e0;
            text-decoration: none;
        }

        .sidebar-title a:hover {
            color: #667eea;
        }

        .sidebar-menu {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .sidebar-menu-item {
            padding: 12px 16px;
            color: #b0b0b0;
            text-decoration: none;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
            text-align: left;
            font-size: 0.95em;
        }

        .sidebar-menu-item:hover {
            background-color: #3a3a3a;
            color: #e0e0e0;
        }

        .sidebar-menu-item.active {
            background-color: #667eea;
            color: #ffffff;
        }

        header {
            text-align: center;
            color: #e0e0e0;
            margin-bottom: 40px;
            padding-top: 20px;
        }

        header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
        }

        header p {
            font-size: 1.1em;
            opacity: 0.9;
        }

        .container {
            display: flex;
            gap: 30px;
            max-width: 1200px;
            width: 100%;
            flex-wrap: wrap;
            justify-content: center;
        }

        .applications-panel {
            background: #333;
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            display: flex;
            flex-direction: column;
            gap: 20px;
            flex: 1;
            min-width: 300px;
            max-width: 600px;
            width: 100%;
        }

        .applications-panel h2 {
            color: #e0e0e0;
            font-size: 1.5em;
            margin: 0;
            border-bottom: 2px solid #667eea;
            padding-bottom: 10px;
        }

        .application-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .application-item {
            background: #2a2a2a;
            border-left: 4px solid #667eea;
            padding: 15px;
            border-radius: 6px;
            transition: all 0.2s;
        }

        .application-item:hover {
            background: #3a3a3a;
        }

        .application-item.pending {
            border-left-color: #ffa500;
        }

        .application-item.approved {
            border-left-color: #4CAF50;
        }

        .application-item.rejected {
            border-left-color: #f44336;
        }

        .application-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }

        .applicant-name {
            color: #e0e0e0;
            font-weight: bold;
            font-size: 1.1em;
        }

        .application-status {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: bold;
        }

        .status-pending {
            background-color: #ffa500;
            color: #000;
        }

        .status-approved {
            background-color: #4CAF50;
            color: #fff;
        }

        .status-rejected {
            background-color: #f44336;
            color: #fff;
        }

        .application-position {
            color: #b0b0b0;
            font-size: 0.95em;
            margin-bottom: 5px;
        }

        .application-date {
            color: #888;
            font-size: 0.85em;
        }

        .application-actions {
            display: flex;
            gap: 8px;
            margin-top: 10px;
        }

        .action-btn {
            padding: 6px 12px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.85em;
            transition: all 0.2s;
        }

        .view-btn {
            background-color: #667eea;
            color: white;
        }

        .view-btn:hover {
            background-color: #5568d3;
        }

        .approve-btn {
            background-color: #4CAF50;
            color: white;
        }

        .approve-btn:hover {
            background-color: #45a049;
        }

        .reject-btn {
            background-color: #f44336;
            color: white;
        }

        .reject-btn:hover {
            background-color: #da190b;
        }

        .empty-state {
            text-align: center;
            color: #888;
            padding: 40px 20px;
        }

        .empty-state p {
            font-size: 1.1em;
        }

        footer {
            color: white;
            margin-top: 40px;
            text-align: center;
            opacity: 0.8;
        }

        @media (max-width: 1024px) {
            .main-content {
                width: calc(100% - 250px);
            }

            .sidebar {
                width: 250px;
            }
        }

        @media (max-width: 768px) {
            body {
                flex-direction: column;
            }

            .hamburger-btn {
                display: block;
            }

            .main-content {
                width: 100%;
                padding: 15px;
                padding-top: 50px;
            }

            .header-content {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                width: 100%;
                padding: 10px 15px;
                background-color: #2a2a2a;
                border-bottom: 1px solid #444;
                z-index: 1002;
                height: 50px;
            }

            .sidebar {
                width: 280px;
                height: auto;
                position: fixed;
                top: 50px;
                left: 0;
                transform: translateX(-100%);
                padding: 20px;
                z-index: 1001;
                max-height: calc(100vh - 50px);
                overflow-y: auto;
                border-right: 1px solid #444;
                transition: transform 0.3s ease-in-out;
                background-color: #2a2a2a;
            }

            .sidebar.active {
                transform: translateX(0);
                box-shadow: 2px 0 8px rgba(0, 0, 0, 0.3);
            }

            .close-sidebar-btn {
                display: block;
            }

            .container {
                flex-direction: column;
                align-items: 100%;
                gap: 20px;
            }

            header {
                margin-bottom: 30px;
                margin-top: 10px;
            }

            header h1 {
                font-size: 1.6em;
                margin-bottom: 5px;
            }

            header p {
                font-size: 0.85em;
            }

            .applications-panel {
                min-width: 100%;
                max-width: 100%;
                width: 100%;
            }

            .application-item {
                padding: 12px;
            }

            .application-header {
                flex-direction: column;
                gap: 8px;
            }

            .applicant-name {
                font-size: 1em;
            }

            .application-actions {
                width: 100%;
                flex-wrap: wrap;
                gap: 6px;
            }

            .action-btn {
                flex: 1;
                min-width: calc(50% - 3px);
                padding: 8px 10px;
                font-size: 0.8em;
            }
        }

        @media (max-width: 480px) {
            .main-content {
                padding: 12px;
                padding-top: 50px;
            }

            body {
                padding: 0;
            }

            .applications-panel {
                padding: 15px;
                gap: 12px;
                border-radius: 8px;
            }

            .applications-panel h2 {
                font-size: 1.2em;
                margin: 0;
            }

            header {
                margin-bottom: 25px;
                padding-top: 5px;
            }

            header h1 {
                font-size: 1.4em;
                margin-bottom: 3px;
            }

            header p {
                font-size: 0.8em;
            }

            .sidebar-logo {
                width: 70px;
                height: 70px;
                font-size: 35px;
                margin-bottom: 10px;
            }

            .sidebar-title {
                font-size: 0.95em;
                line-height: 1.2;
                margin-bottom: 15px;
            }

            .sidebar-menu {
                width: 100%;
            }

            .sidebar-menu-item {
                width: 100%;
                padding: 10px 12px;
                font-size: 0.9em;
            }

            .search-input {
                padding: 10px;
                font-size: 14px;
                border-radius: 4px;
            }

            .application-item {
                padding: 10px;
                gap: 8px;
            }

            .applicant-name {
                font-size: 0.95em;
            }

            .application-position {
                font-size: 0.85em;
            }

            .application-date {
                font-size: 0.75em;
            }

            .action-btn {
                padding: 6px 8px;
                font-size: 0.7em;
                flex: 1;
                min-width: calc(50% - 3px);
            }

            .modal-content {
                padding: 16px;
                margin: 10px;
                max-height: 85vh;
                width: calc(100% - 20px);
                border-radius: 8px;
            }

            .modal-header {
                flex-direction: column;
                align-items: flex-start;
                gap: 10px;
                margin-bottom: 16px;
            }

            .modal-close {
                align-self: flex-end;
                margin: -5px -5px 0 0;
            }

            .modal-header h2 {
                font-size: 1.15em;
                margin: 0;
            }

            .question-answer {
                margin-bottom: 16px;
            }

            .question {
                font-size: 0.9em;
            }

            .answer {
                font-size: 0.85em;
                padding: 8px;
            }

            .container {
                gap: 15px;
            }
        }

        @media (max-width: 360px) {
            .main-content {
                padding: 10px;
            }

            header h1 {
                font-size: 1.25em;
            }

            header p {
                font-size: 0.75em;
            }

            .modal-content {
                padding: 12px;
                width: calc(100% - 14px);
                margin: 7px;
            }

            .action-btn {
                padding: 5px 6px;
                font-size: 0.65em;
            }

            .application-item {
                padding: 8px;
            }

            .search-input {
                padding: 8px;
                font-size: 13px;
            }

            .hamburger-btn {
                padding: 8px 5px;
                font-size: 1.3em;
            }
        }

        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.7);
        }

        .modal.show {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background-color: #2a2a2a;
            padding: 30px;
            border-radius: 12px;
            max-width: 600px;
            max-height: 80vh;
            overflow-y: auto;
            color: #e0e0e0;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            border-bottom: 2px solid #667eea;
            padding-bottom: 15px;
        }

        .modal-header h2 {
            margin: 0;
            font-size: 1.5em;
        }

        .modal-close {
            background: none;
            border: none;
            color: #e0e0e0;
            font-size: 28px;
            cursor: pointer;
            padding: 0;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-close:hover {
            color: #667eea;
        }

        .question-answer {
            margin-bottom: 20px;
        }

        .question {
            color: #667eea;
            font-weight: bold;
            margin-bottom: 5px;
        }

        .answer {
            color: #b0b0b0;
            padding: 10px;
            background-color: #333;
            border-left: 3px solid #667eea;
            border-radius: 4px;
        }

        .search-container {
            width: 100%;
            margin-bottom: 20px;
        }

        .search-input {
            width: 100%;
            padding: 12px;
            background-color: #2a2a2a;
            border: 2px solid #667eea;
            border-radius: 6px;
            color: #e0e0e0;
            font-size: 1em;
        }

        .search-input::placeholder {
            color: #888;
        }

        .search-input:focus {
            outline: none;
            border-color: #7f9eff;
            box-shadow: 0 0 8px rgba(102, 126, 234, 0.3);
        }
    </style>
</head>
<body>
    <div class="sidebar" id="sidebar">
        <button type="button" class="close-sidebar-btn" id="closeSidebarBtn" onclick="closeSidebar()" aria-label="Close sidebar">✕</button>
        <div class="sidebar-logo"><img src="/assets/logo.png" alt="Logo"></div>
        <div class="sidebar-title"><a href="/">Aviation Realism<br>Network</a></div>
        <div class="sidebar-menu">
            <a class="sidebar-menu-item" href="/profile">Profile</a>
            <a class="sidebar-menu-item" href="/announcements">Announcements</a>
            <a class="sidebar-menu-item" href="/pilots">Pilots</a>
            <a class="sidebar-menu-item active" href="/applications">Applications</a>
            <a class="sidebar-menu-item" href="/information">Information</a>
        </div>
    </div>

    <div class="main-content">
        <div class="header-content">
            <button class="hamburger-btn" id="hamburgerBtn" onclick="toggleSidebar()" aria-label="Toggle navigation menu">☰</button>
        </div>
        <header>
            <h1>Applications</h1>
            <p>Manage ATC and Enforcer applications for the Aviation Realism Network Discord group.</p>
        </header>

        <div class="container">
            <div class="applications-panel">
                <h2>ATC Applications</h2>
                <div class="search-container">
                    <input type="text" class="search-input" id="searchInput" placeholder="Search by name, callsign, or Discord handle..." onkeyup="filterApplications()">
                </div>
                <div class="application-list" id="atcList">
                    <div class="empty-state">
                        <p>No ATC applications at this time.</p>
                    </div>
                </div>
            </div>

            <div class="applications-panel">
                <h2>Enforcer Applications</h2>
                <div class="application-list" id="enforcerList">
                    <div class="empty-state">
                        <p>No Enforcer applications at this time.</p>
                    </div>
                </div>
            </div>
        </div>

        <div id="applicationModal" class="modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 id="modalTitle">Application Details</h2>
                    <button class="modal-close" onclick="closeModal()">&times;</button>
                </div>
                <div id="modalBody"></div>
            </div>
        </div>

        <footer>
            <p>&copy; 2026 Aviation Realism Network. All rights reserved.</p>
        </footer>
    </div>

    <script>
        let allApplications = [];
        let filteredApplications = [];

        // Toggle sidebar on mobile
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const hamburgerBtn = document.getElementById('hamburgerBtn');
            sidebar.classList.toggle('active');
            hamburgerBtn.classList.toggle('active');
            // Show close button when sidebar is active
            const closeBtn = document.getElementById('closeSidebarBtn');
            if (sidebar.classList.contains('active')) {
                closeBtn.style.display = 'block';
            } else {
                closeBtn.style.display = 'none';
            }
        }

        // Close sidebar when menu item is clicked on mobile
        document.addEventListener('DOMContentLoaded', function() {
            const sidebarMenuItems = document.querySelectorAll('.sidebar-menu-item');
            sidebarMenuItems.forEach(item => {
                item.addEventListener('click', function() {
                    if (window.innerWidth <= 768) {
                        const sidebar = document.getElementById('sidebar');
                        const hamburgerBtn = document.getElementById('hamburgerBtn');
                        const closeBtn = document.getElementById('closeSidebarBtn');
                        sidebar.classList.remove('active');
                        hamburgerBtn.classList.remove('active');
                        closeBtn.style.display = 'none';
                    }
                });
            });
        });

        function closeSidebar() {
            const sidebar = document.getElementById('sidebar');
            const hamburgerBtn = document.getElementById('hamburgerBtn');
            const closeBtn = document.getElementById('closeSidebarBtn');
            sidebar.classList.remove('active');
            hamburgerBtn.classList.remove('active');
            closeBtn.style.display = 'none';
        }

        function filterApplications() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            
            if (searchTerm === '') {
                filteredApplications = allApplications;
            } else {
                filteredApplications = allApplications.filter(app => {
                    return app.name.toLowerCase().includes(searchTerm) ||
                           app.callsign.toLowerCase().includes(searchTerm) ||
                           app.discordHandle.toLowerCase().includes(searchTerm);
                });
            }
            
            const atcApplications = filteredApplications.filter(app => app.type === 'atc');
            const enforcerApplications = filteredApplications.filter(app => app.type === 'enforcer');
            
            renderApplications(atcApplications, 'atcList', 'ATC');
            renderApplications(enforcerApplications, 'enforcerList', 'Enforcer');
        }

        function renderApplications(applications, containerId, type) {
            const container = document.getElementById(containerId);
            
            if (applications.length === 0) {
                container.innerHTML = '<div class="empty-state"><p>No ' + type + ' applications at this time.</p></div>';
                return;
            }

            container.innerHTML = applications.map(app => `
                <div class="application-item ${app.status}">
                    <div class="application-header">
                        <span class="applicant-name">${app.name}</span>
                        <span class="application-status status-${app.status}">${app.status.toUpperCase()}</span>
                    </div>
                    <div class="application-position">${'Callsign: ' + app.callsign + ' | Discord: ' + app.discordHandle}</div>
                    <div class="application-date">Applied: ${new Date(app.date).toLocaleDateString()}</div>
                    <div class="application-actions">
                        <button class="action-btn view-btn" onclick="openApplicationModal('${app._id || app.id}')">View Full</button>
                        ${app.status === 'pending' ? `
                            <button class="action-btn approve-btn" onclick="approveApplication('${app._id || app.id}')">Approve</button>
                            <button class="action-btn reject-btn" onclick="rejectApplication('${app._id || app.id}')">Reject</button>
                        ` : ''}
                    </div>
                </div>
            `).join('');
        }

        function openApplicationModal(appId) {
            const application = allApplications.find(app => (app._id || app.id) === appId);
            if (!application) {
                alert('Application not found');
                return;
            }

            const modalTitle = document.getElementById('modalTitle');
            const modalBody = document.getElementById('modalBody');
            
            modalTitle.textContent = application.name + ' - Application Details';
            
            let questionsHtml = `
                <div class="question-answer">
                    <div class="question">Name:</div>
                    <div class="answer">${application.name}</div>
                </div>
                <div class="question-answer">
                    <div class="question">Callsign / Discord Handle:</div>
                    <div class="answer">${application.callsign} / ${application.discordHandle}</div>
                </div>
                <div class="question-answer">
                    <div class="question">Application Type:</div>
                    <div class="answer">${application.type.toUpperCase()}</div>
                </div>
                <div class="question-answer">
                    <div class="question">Status:</div>
                    <div class="answer">${application.status.toUpperCase()}</div>
                </div>
                <div class="question-answer">
                    <div class="question">Applied On:</div>
                    <div class="answer">${new Date(application.date).toLocaleString()}</div>
                </div>
                <div class="question-answer">
                    <div class="question">Experience:</div>
                    <div class="answer">${application.experience || 'N/A'}</div>
                </div>
                <div class="question-answer">
                    <div class="question">Why do you want to join?</div>
                    <div class="answer">${application.whyJoin || 'N/A'}</div>
                </div>
            `;

            if (application.responses && Array.isArray(application.responses)) {
                application.responses.forEach(resp => {
                    questionsHtml += `
                        <div class="question-answer">
                            <div class="question">${resp.question || 'Question'}:</div>
                            <div class="answer">${resp.answer || 'No answer provided'}</div>
                        </div>
                    `;
                });
            }

            modalBody.innerHTML = questionsHtml;
            document.getElementById('applicationModal').classList.add('show');
        }

        function closeModal() {
            document.getElementById('applicationModal').classList.remove('show');
        }

        function approveApplication(appId) {
            if (confirm('Are you sure you want to approve this application?')) {
                fetch('/api/applications/' + appId + '/approve', {
                    method: 'POST'
                })
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Failed to approve application');
                    }
                    return response.json();
                })
                .then(result => {
                    alert('Application approved successfully');
                    closeModal();
                    location.reload();
                })
                .catch(error => {
                    console.error('Error approving application:', error);
                    alert('Error approving application: ' + error.message);
                });
            }
        }

        function rejectApplication(appId) {
            if (confirm('Are you sure you want to reject this application?')) {
                fetch('/api/applications/' + appId + '/reject', {
                    method: 'POST'
                })
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Failed to reject application');
                    }
                    return response.json();
                })
                .then(result => {
                    alert('Application rejected successfully');
                    closeModal();
                    location.reload();
                })
                .catch(error => {
                    console.error('Error rejecting application:', error);
                    alert('Error rejecting application: ' + error.message);
                });
            }
        }

        window.onclick = function(event) {
            const modal = document.getElementById('applicationModal');
            if (event.target === modal) {
                modal.classList.remove('show');
            }
        }

        // Fetch applications from API
        fetch('/api/applications')
            .then(response => {
                if (!response.ok) {
                    throw new Error('API response was not ok: ' + response.status);
                }
                return response.json();
            })
            .then(result => {
                console.log('Applications fetched:', result);
                allApplications = result.data || result || [];
                filteredApplications = allApplications;
                const atcApplications = allApplications.filter(app => app.type === 'atc');
                const enforcerApplications = allApplications.filter(app => app.type === 'enforcer');
                
                renderApplications(atcApplications, 'atcList', 'ATC');
                renderApplications(enforcerApplications, 'enforcerList', 'Enforcer');
            })
            .catch(error => {
                console.error('Error fetching applications:', error);
                alert('Failed to load applications: ' + error.message);
            });
    </script>
</body>
</html>