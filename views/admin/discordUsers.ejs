<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="author" content="Caleb Thomas (TheRavenSeb)">
    <meta name="description" content="Discord Users Directory - Browse and search all Discord members.">
    <title>Discord Users Directory</title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        .main-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            min-height: 100vh;
        }

        .hero {
            text-align: center;
            color: #e0e0e0;
            margin-bottom: 30px;
            padding-top: 20px;
        }

        .hero h1 { font-size: 2.5em; margin-bottom: 10px; }
        .hero p   { font-size: 1.1em; opacity: 0.9; }

        .search-container {
            width: 100%;
            max-width: 800px;
            margin-bottom: 40px;
        }

        .search-box {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        .search-box input {
            flex: 1;
            padding: 12px 16px;
            background-color: #333;
            border: 1px solid #444;
            border-radius: 8px;
            color: #e0e0e0;
            font-size: 1em;
            transition: all 0.3s;
        }

        .search-box input:focus {
            outline: none;
            border-color: rgba(255,255,255,0.3);
            background-color: #3a3a3a;
        }

        .search-box button {
            padding: 12px 24px;
            background-color: rgba(255,255,255,0.1);
            color: #e0e0e0;
            border: 1px solid rgba(255,255,255,0.12);
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.2s;
        }

        .search-box button:hover {
            background-color: rgba(255,255,255,0.16);
        }

        .filter-options {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .filter-btn {
            padding: 8px 16px;
            background-color: #333;
            border: 1px solid rgba(255,255,255,0.1);
            color: #b0b0b0;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 0.9em;
            font-weight: 500;
        }

        .filter-btn:hover,
        .filter-btn.active {
            background-color: rgba(255,255,255,0.1);
            border-color: rgba(255,255,255,0.22);
            color: #f5f3ef;
        }

        .results-count {
            color: #888;
            font-size: 0.9em;
            margin-bottom: 20px;
            text-align: center;
        }

        .users-container {
            width: 100%;
            max-width: 900px;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        /* Card — mirrors pilot-card exactly */
        .user-card {
            background: #232323;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 10px;
            padding: 20px;
            transition: border-color 0.15s;
        }

        .user-card:hover { border-color: rgba(255,255,255,0.16); }

        .user-avatar {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            overflow: hidden;
            margin-bottom: 14px;
            background: #2e2e2e;
            border: 1px solid rgba(255,255,255,0.08);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .user-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .user-avatar-initials {
            font-size: 1.3rem;
            font-weight: 700;
            color: rgba(245,243,239,0.5);
            letter-spacing: -0.02em;
        }

        .user-name {
            font-size: 1rem;
            font-weight: 700;
            color: #f5f3ef;
            margin-bottom: 4px;
            letter-spacing: -0.01em;
            word-break: break-word;
        }

        .user-id {
            color: rgba(245,243,239,0.4);
            font-size: 0.78rem;
            font-weight: 500;
            font-family: 'Courier New', monospace;
            margin-bottom: 14px;
            word-break: break-all;
        }

        .user-info-label {
            font-size: 0.8rem;
            color: rgba(245,243,239,0.45);
            margin-bottom: 2px;
        }

        .user-roles {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px solid rgba(255,255,255,0.07);
        }

        .user-role-badge {
            display: inline-block;
            padding: 3px 10px;
            background: rgba(255,255,255,0.07);
            color: rgba(245,243,239,0.75);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 20px;
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        footer {
            color: white;
            margin-top: 40px;
            text-align: center;
            opacity: 0.8;
            font-size: 0.8rem;
        }

        @media (max-width: 768px) {
            .users-container { grid-template-columns: 1fr; }
            .search-box { flex-direction: column; }
            .search-box input, .search-box button { padding: 12px; font-size: 1em; }
            .search-container { max-width: 100%; }
            .hero h1 { font-size: 1.8em; }
        }

        @media (max-width: 480px) {
            .hero h1 { font-size: 1.6em; }
            .users-container { gap: 15px; max-width: 100%; }
            .user-card { padding: 15px; }
        }

        <%- include('../partials/fixed-sidebar-theme') %>
    </style>
</head>
<body>
    <%- include('../partials/sidebar', { page: 'discordUsers' }) %>

    <div class="main-content">

        <div class="hero">
            <h1>Discord Users</h1>
            <p>Browse and search all Discord members in our network</p>
        </div>

        <div class="search-container">
            <div class="search-box">
                <input
                    type="text"
                    id="searchInput"
                    placeholder="Search by username or Discord ID…"
                    onkeyup="searchUsers()"
                >
                <button onclick="searchUsers()">Search</button>
            </div>

            <div class="filter-options" id="filterOptions">
                <button class="filter-btn active" onclick="filterByRole('all', event)">All Members</button>
            </div>

            <div class="results-count">
                <span id="resultsCount"></span>
            </div>
        </div>

        <div class="users-container" id="usersContainer"></div>

        <footer>
            <%# <p>&copy; 2026 Aviation Realism Network. All rights reserved.</p> %>
            <p>Bringing realistic aviation simulation to VTOL VR</p>
        </footer>
    </div>

    <script>
        let allUsers = [];
        let currentFilter = 'all';

        document.addEventListener('DOMContentLoaded', function() {
            fetchUsers();
        });

        async function fetchUsers() {
            try {
                const response = await fetch('/api/users/discord');
                if (!response.ok) {
                    throw new Error('Unable to load Discord users right now.');
                }

                const data = await response.json();
                allUsers = data.data || [];
                buildRoleFilters(allUsers);
                displayUsers(allUsers);
            } catch (error) {
                document.getElementById('usersContainer').innerHTML = `
                    <div class="no-results">
                        <h3>Error loading Discord users</h3>
                        <p>Unable to load data. Please try again later.</p>
                    </div>
                `;
            }
        }

        function buildRoleFilters(users) {
            const roleSet = new Set();
            users.forEach(u => {
                if (u.roles) u.roles.filter(r => r !== '@everyone').forEach(r => roleSet.add(r));
            });

            const container = document.getElementById('filterOptions');
            const existing = container.querySelector('.filter-btn.active');
            roleSet.forEach(role => {
                const btn = document.createElement('button');
                btn.className = 'filter-btn';
                btn.textContent = role;
                btn.onclick = (e) => filterByRole(role, e);
                container.appendChild(btn);
            });
        }

        function displayUsers(users) {
            const container = document.getElementById('usersContainer');
            const resultsCount = document.getElementById('resultsCount');

            if (users.length === 0) {
                container.innerHTML = '';
                resultsCount.textContent = 'No results found';
                return;
            }

            resultsCount.textContent = `Showing ${users.length} member${users.length !== 1 ? 's' : ''}`;

            const initials = (name) => (name || '?').slice(0, 2).toUpperCase();

            container.innerHTML = users.map(user => {
                const visibleRoles = (user.roles || []).filter(r => r !== '@everyone');
                return `
                    <div class="user-card">
                        <div class="user-avatar">
                            ${user.avatar
                                ? `<img src="${user.avatar}" alt="${user.username || ''}" />`
                                : `<span class="user-avatar-initials">${initials(user.username)}</span>`
                            }
                        </div>
                        <div class="user-name">${user.username || 'Unknown'}</div>
                        <div class="user-id">${user.id || 'N/A'}</div>
                        ${visibleRoles.length > 0 ? `
                            <div class="user-roles">
                                ${visibleRoles.map(role => `<span class="user-role-badge">${role}</span>`).join('')}
                            </div>
                        ` : ''}
                    </div>
                `;
            }).join('');
        }

        function searchUsers() {
            const query = document.getElementById('searchInput').value.toLowerCase();
            const filtered = allUsers.filter(user => {
                const matchesSearch = !query ||
                    (user.username && user.username.toLowerCase().includes(query)) ||
                    (user.id && user.id.toLowerCase().includes(query));
                const matchesRole = currentFilter === 'all' ||
                    (user.roles && user.roles.includes(currentFilter));
                return matchesSearch && matchesRole;
            });
            displayUsers(filtered);
        }

        function filterByRole(role, event) {
            currentFilter = role;
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            if (event && event.target) event.target.classList.add('active');
            searchUsers();
        }
    </script>
</body>
</html>
