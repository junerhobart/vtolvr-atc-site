<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="IFR Flight Planning Sheet for IFR Flights in VTOL VR.">
    <meta name="keywords" content="IFR, Flight Planning, VTOL VR, Aviation, Navigation, Weather Briefing">
    <meta name="author" content="Caleb Thomas">
    <title>IFR Flight Planning Sheet</title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            if (window.OpenKneeboard) {
                document.body.classList.add("OpenKneeboard");
                await OpenKneeboard.EnableExperimentalFeature('GraphicsTabletInfo', 2025012901);
                const info = await OpenKneeboard.GetGraphicsTabletInfo();
                if (info && info.SuggestedPixelSize) {
                    await OpenKneeboard.SetPreferredPixelSize(info.SuggestedPixelSize.Width, info.SuggestedPixelSize.Height);
                } else {
                    await OpenKneeboard.SetPreferredPixelSize(600, 1300);
                }
            }
        });
    </script>
    <style>
        .main-content {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .page-wrap {
            flex: 1;
            max-width: 900px;
            margin: 0 auto;
            padding: 48px 24px;
            width: 100%;
        }

        .hero {
            margin-bottom: 32px;
            text-align: center;
            padding-top: 20px;
        }

        .hero h1 {
            font-size: 2.5em;
            font-weight: 700;
            color: #f5f3ef;
            margin-bottom: 10px;
        }

        .hero p {
            color: rgba(245,243,239,0.7);
            font-size: 1.1em;
            opacity: 0.9;
        }

        /* Sections */
        .sheet-section {
            padding: 24px 0;
            margin-bottom: 16px;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            padding-bottom: 14px;
            margin-bottom: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.07);
            flex-wrap: wrap;
            gap: 8px;
        }

        .section-title {
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: rgba(245,243,239,0.45);
        }

        .squawk-code {
            font-size: 0.8rem;
            font-weight: 600;
            color: rgba(245,243,239,0.5);
            font-family: "Inter", monospace;
        }

        /* Form layout */
        .form-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 14px;
            margin-bottom: 14px;
        }

        .form-row:last-child { margin-bottom: 0; }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .form-group.full { grid-column: 1 / -1; }

        label {
            font-size: 0.8rem;
            font-weight: 500;
            color: rgba(245,243,239,0.5);
        }

        input[type="text"],
        input[type="number"],
        input[type="date"],
        textarea,
        select {
            padding: 10px 12px;
            background: #1e1e1e;
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 8px;
            color: #f5f3ef;
            font-family: "Inter", sans-serif;
            font-size: 0.875rem;
            transition: border-color 0.15s;
            width: 100%;
        }

        input:focus,
        textarea:focus,
        select:focus {
            outline: none;
            border-color: rgba(255,255,255,0.25);
            background: #242424;
        }

        textarea { resize: vertical; }

        select option { background: #232323; }

        /* Navigation table */
        .nav-table-wrap {
            overflow-x: auto;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.08);
            margin-bottom: 12px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.875rem;
        }

        thead th {
            background: #1e1e1e;
            color: rgba(245,243,239,0.5);
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 10px 12px;
            text-align: left;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        tbody td {
            padding: 6px 8px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        tbody tr:last-child td { border-bottom: none; }

        tbody tr:hover td { background: rgba(255,255,255,0.02); }

        td input {
            padding: 7px 10px;
            background: transparent;
            border: 1px solid transparent;
            border-radius: 6px;
            color: #f5f3ef;
            font-family: "Inter", sans-serif;
            font-size: 0.875rem;
            width: 100%;
        }

        td input:focus {
            outline: none;
            background: #1e1e1e;
            border-color: rgba(255,255,255,0.15);
        }

        /* Buttons */
        .btn {
            padding: 10px 18px;
            border-radius: 8px;
            font-size: 0.875rem;
            font-weight: 600;
            font-family: "Inter", sans-serif;
            cursor: pointer;
            transition: all 0.15s;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .btn-ghost {
            background: transparent;
            color: rgba(245,243,239,0.5);
        }

        .btn-ghost:hover {
            background: rgba(255,255,255,0.04);
            color: #f5f3ef;
        }

        .btn-primary {
            background: #3a3a3a;
            color: #f5f3ef;
        }

        .btn-primary:hover {
            background: #444;
            border-color: rgba(255,255,255,0.16);
        }

        .btn-danger {
            background: transparent;
            color: rgba(255,176,176,0.7);
            border-color: rgba(220,50,50,0.2);
            padding: 5px 10px;
            font-size: 0.78rem;
        }

        .btn-danger:hover {
            background: rgba(220,50,50,0.1);
            color: #ffb0b0;
        }

        .row-actions {
            display: flex;
            gap: 8px;
            align-items: center;
            margin-top: 4px;
        }

        .submit-bar {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            padding-top: 8px;
        }

        /* Alert */
        .alert {
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 0.875rem;
            margin-bottom: 16px;
            display: none;
        }

        .alert-error {
            background: rgba(220,50,50,0.12);
            border: 1px solid rgba(220,50,50,0.25);
            color: #ffb0b0;
        }

        .alert-success {
            background: rgba(50,180,80,0.1);
            border: 1px solid rgba(50,180,80,0.25);
            color: #b6f3be;
        }

        footer {
            text-align: center;
            padding: 24px 20px;
            font-size: 0.8rem;
            color: rgba(245,243,239,0.3);
        }

        @media (max-width: 768px) {
            .page-wrap { padding: 32px 16px; }
            .hero h1 { font-size: 1.6rem; }
            .form-row { grid-template-columns: 1fr; }
            .section-header { flex-direction: column; gap: 4px; }
        }

        <%- include('partials/fixed-sidebar-theme') %>
    </style>
</head>
<body>
    <%- include('partials/sidebar', { page: 'ifr' }) %>

    <div class="main-content">
        <div class="page-wrap" id="capture-area">
            <div class="hero">
                <h1>IFR Flight Planning Sheet</h1>
                <p>Fill out each section and submit to log the flight plan to Discord.</p>
            </div>

            <div class="alert alert-error" id="alertError"></div>
            <div class="alert alert-success" id="alertSuccess"></div>

            <!-- General Information -->
            <div class="sheet-section">
                <div class="section-header">
                    <span class="section-title">General Information</span>
                    <span class="squawk-code" id="squawkCode">Aircraft ID (Squawk): 0000</span>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="date">Date</label>
                        <input type="date" id="date" name="date">
                    </div>
                    <div class="form-group">
                        <label for="sessionID">Session ID</label>
                        <input type="text" id="sessionID" name="sessionID" placeholder="ABC123">
                    </div>
                    <div class="form-group">
                        <label for="sessionMap">Session Map</label>
                        <input type="text" id="sessionMap" name="sessionMap" placeholder="ARN City">
                    </div>
                </div>
            </div>

            <!-- Flight Information -->
            <div class="sheet-section">
                <div class="section-header">
                    <span class="section-title">Flight Information</span>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="flightName">Flight Callsign</label>
                        <input type="text" id="flightName" name="flightName" placeholder="Crow 1-1">
                    </div>
                    <div class="form-group">
                        <label for="aircraftType">Aircraft Type</label>
                        <select id="aircraftType" name="aircraftType">
                            <option value="AV-42C">AV-42C</option>
                            <option value="F/A-26B">F/A-26B</option>
                            <option value="F-45A">F-45A</option>
                            <option value="AH-94">AH-94</option>
                            <option value="T-55">T-55</option>
                            <option value="EF-24G">EF-24G</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="altitude">Cruising Altitude</label>
                        <input type="text" id="altitude" name="altitude" placeholder="ft MSL">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="departure">Departure</label>
                        <input type="text" id="departure" name="departure">
                    </div>
                    <div class="form-group">
                        <label for="destination">Destination</label>
                        <input type="text" id="destination" name="destination">
                    </div>
                </div>
            </div>

            <!-- Fuel Planning -->
            <div class="sheet-section">
                <div class="section-header">
                    <span class="section-title">Fuel Planning</span>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="totalFuel">Total Fuel Onboard (lbs)</label>
                        <input type="number" id="totalFuel" name="totalFuel" placeholder="Pounds">
                    </div>
                    <div class="form-group">
                        <label for="bingoFuel">Bingo Fuel (lbs)</label>
                        <input type="number" id="bingoFuel" name="bingoFuel" placeholder="Pounds">
                    </div>
                </div>
            </div>

            <!-- Weather -->
            <div class="sheet-section">
                <div class="section-header">
                    <span class="section-title">Flight Weather</span>
                </div>
                <div class="form-group">
                    <label for="weatherBriefing">Weather Briefing</label>
                    <textarea id="weatherBriefing" name="weatherBriefing" rows="3" placeholder="Clear skies, visibility 10 miles..."></textarea>
                </div>
            </div>

            <!-- Navigation -->
            <div class="sheet-section">
                <div class="section-header">
                    <span class="section-title">Navigation & Route</span>
                </div>
                <div class="nav-table-wrap">
                    <table id="navigationLog">
                        <thead>
                            <tr>
                                <th>Waypoint</th>
                                <th>Distance (NM)</th>
                                <th>Heading</th>
                                <th>Ground Speed (KTS)</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><input type="text" name="waypoint" placeholder="Waypoint"></td>
                                <td><input type="number" name="distance" placeholder="NM"></td>
                                <td><input type="text" name="heading" placeholder="°"></td>
                                <td><input type="number" name="groundSpeed" placeholder="KTS"></td>
                                <td><button type="button" class="btn btn-danger" onclick="removeRow(this)">Remove</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <button type="button" class="btn btn-ghost" onclick="addRow()">+ Add Waypoint</button>
            </div>

            <!-- Crew Information -->
            <div class="sheet-section">
                <div class="section-header">
                    <span class="section-title">Pilot & Crew</span>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="pic">Pilot in Command</label>
                        <input type="text" id="pic" name="pic" placeholder="Callsign">
                    </div>
                    <div class="form-group">
                        <label for="role">Role</label>
                        <select id="role" name="role">
                            <option value="Pilot">Pilot</option>
                            <option value="Enforcer">Enforcer</option>
                            <option value="Intercepter">Intercepter</option>
                        </select>
                    </div>
                </div>
                <div class="form-row" id="copilotRow" style="display:none;">
                    <div class="form-group">
                        <label for="copilot">Co-Pilot</label>
                        <input type="text" id="copilot" name="copilot" placeholder="Callsign">
                    </div>
                    <div class="form-group">
                        <label for="co-role">Co-Pilot Role</label>
                        <select id="co-role" name="co-role">
                            <option value="Pilot">Pilot</option>
                            <option value="Enforcer">Enforcer</option>
                            <option value="Intercepter">Intercepter</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Radio Frequencies -->
            <div class="sheet-section">
                <div class="section-header">
                    <span class="section-title">Radio Frequencies</span>
                </div>
                <div class="form-group">
                    <label for="radioFrequencies">Frequencies</label>
                    <textarea id="radioFrequencies" name="radioFrequencies" rows="3" placeholder="Enter frequencies..."></textarea>
                </div>
            </div>

            <!-- Additional Notes -->
            <div class="sheet-section">
                <div class="section-header">
                    <span class="section-title">Additional Notes</span>
                </div>
                <div class="form-group">
                    <label for="additionalNotes">Notes</label>
                    <textarea id="additionalNotes" name="additionalNotes" rows="3" placeholder="Any additional notes..."></textarea>
                </div>
            </div>

            <div class="submit-bar">
                <button type="button" class="btn btn-primary" onclick="submitwebhook()">Submit Flight Plan</button>
            </div>
        </div>

        <footer>
            <%#  <p>&copy; 2026 Aviation Realism Network. All rights reserved.</p> %>
            <p>Bringing realistic aviation simulation to VTOL VR</p>
        </footer>
    </div>

    <script>
        const aircraftType = document.getElementById('aircraftType');
        aircraftType.addEventListener('change', function() {
            const copilotRow = document.getElementById('copilotRow');
            copilotRow.style.display = (this.value === 'T-55' || this.value === 'AH-94') ? 'grid' : 'none';
        });

        function addRow() {
            const tbody = document.getElementById('navigationLog').getElementsByTagName('tbody')[0];
            const row = tbody.insertRow();
            row.innerHTML = `
                <td><input type="text" name="waypoint" placeholder="Waypoint"></td>
                <td><input type="number" name="distance" placeholder="NM"></td>
                <td><input type="text" name="heading" placeholder="°"></td>
                <td><input type="number" name="groundSpeed" placeholder="KTS"></td>
                <td><button type="button" class="btn btn-danger" onclick="removeRow(this)">Remove</button></td>
            `;
        }

        function removeRow(button) {
            const row = button.closest('tr');
            row.parentElement.removeChild(row);
        }

        function showAlert(type, message) {
            const el = document.getElementById(type === 'error' ? 'alertError' : 'alertSuccess');
            el.textContent = message;
            el.style.display = 'block';
            setTimeout(() => el.style.display = 'none', 6000);
        }

        function takeScreenshot() {
            html2canvas(document.getElementById('capture-area')).then(canvas => {
                const link = document.createElement('a');
                link.href = canvas.toDataURL('image/png');
                link.download = 'ifr-flight-plan.png';
                link.click();
            });
        }

        function generateSquawk(aircraftType, flightName, flightType) {
            const type = aircraftType.toUpperCase();
            const callsign = flightName.toUpperCase();
            const codes = { 'AV-42C': ['1001','4004'], 'F/A-26B': ['2002','2003'], 'F-45A': ['3003','3004'], 'AH-94': ['1500','1500'], 'T-55': ['5005','5005'], 'EF-24G': ['6006','6006'] };
            const pair = codes[type];
            if (!pair) return '0000';
            return `${callsign} - ${flightType === 'IFR' ? pair[0] : pair[1]}`;
        }

        async function submitwebhook() {
            const wrap = document.getElementById('capture-area');
            const data = {};

            wrap.querySelectorAll('input:not(table input), select, textarea').forEach(el => {
                if (el.name) data[el.name] = el.value.trim() || null;
            });

            const rows = document.getElementById('navigationLog').querySelectorAll('tbody tr');
            const navLog = Array.from(rows).map(row => {
                const cells = row.querySelectorAll('input');
                if (!cells[0]?.value) return null;
                return { waypoint: cells[0].value, distance: cells[1].value, heading: cells[2].value, groundSpeed: cells[3].value };
            }).filter(Boolean);

            data.navigationLog = navLog.length
                ? navLog.map(n => `Waypoint: ${n.waypoint}, Distance: ${n.distance}, Heading: ${n.heading}, Ground Speed: ${n.groundSpeed}`).join('\n')
                : 'None';

            data.flightType = navLog.length ? 'IFR' : 'VFR';

            const squawk = generateSquawk(data.aircraftType || '', data.flightName || '', data.flightType);
            data.squawkCode = squawk;
            document.getElementById('squawkCode').textContent = `Aircraft ID (Squawk): ${squawk}`;

            if (!data.sessionID || !data.flightName) {
                showAlert('error', 'Please fill in Session ID and Flight Callsign.');
                return;
            }
            if (!data.flightName.includes('-')) {
                showAlert('error', 'Flight Callsign must include a hyphen (e.g. Crow 1-1).');
                return;
            }

            const endpoint = 'https://atc-vtolvr.site/api/ifr/submit';
            try {
                const res = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Access-Control-Allow-Origin': '*' },
                    body: JSON.stringify(data)
                });
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                showAlert('success', 'Flight plan submitted! Downloading screenshot...');
                takeScreenshot();
            } catch {
                try {
                    const fd = new FormData();
                    fd.append('payload', JSON.stringify(data));
                    const res2 = await fetch(endpoint, { method: 'POST', body: fd });
                    if (res2.type === 'opaque' || res2.ok) {
                        showAlert('success', 'Flight plan submitted.');
                    } else throw new Error();
                } catch {
                    showAlert('success', 'Flight plan submitted.');
                }
            }
        }
    </script>
</body>
</html>
