<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- add meta data for the page-->

  <meta name="description" content="IFR Flight Planning Sheet for IFR Flights in VTOL VR including sections for general information, flight details, fuel planning, weather, navigation, crew info, radio frequencies, and additional notes.">

  <meta name="keywords" content="IFR, Flight Planning, VTOL VR, Aviation, Flight Sheet, Navigation, Weather Briefing, Fuel Planning, Pilot Information">
  <meta name="author" content="Caleb Thomas">
  <!-- Include html2canvas library for screenshot functionality -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
   <script>
        document.addEventListener('DOMContentLoaded', async() => {
            if (window.OpenKneeboard) {
                document.body.classList.add("OpenKneeboard");
                await OpenKneeboard.EnableExperimentalFeature(
                    'GraphicsTabletInfo',
                    2025012901);
                var info = await OpenKneeboard.GetGraphicsTabletInfo();
                if (info && info.SuggestedPixelSize) {
                await OpenKneeboard.SetPreferredPixelSize(
                info.SuggestedPixelSize.Width,
                info.SuggestedPixelSize.Height)}
                else{
                    // set to 600x1300 if no suggested size is provided
                    await OpenKneeboard.SetPreferredPixelSize(600, 1300);
                }
            }
            


            
        });
    </script>

  <title>VFR Flight Planning Sheet</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
