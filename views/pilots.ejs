<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta name="author" content="Caleb Thomas (TheRavenSeb)">
    <meta name="description" content="Pilots Directory - Browse and search all pilots.">
    <meta name="keywords" content="Pilots, Directory, Aviation, VTOL VR">
    <title>Pilots Directory</title>
    <link rel="icon" type="image/png" href="/assets/logo.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        .main-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            min-height: 100vh;
        }

        .hamburger-btn {
            display: none;
            background: transparent;
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 10px;
            color: #e0e0e0;
            font-size: 1rem;
            cursor: pointer;
            padding: 10px;
            margin-right: 15px;
            transition: all 0.2s;
        }

        .hamburger-btn:hover,
        .hamburger-btn.active {
            color: #f5f3ef;
            background: #202020;
        }

        .hero {
            text-align: center;
            color: #e0e0e0;
            margin-bottom: 30px;
            padding-top: 20px;
        }

        .hero h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
        }

        .hero p {
            font-size: 1.1em;
            opacity: 0.9;
        }

        .search-container {
            width: 100%;
            max-width: 800px;
            margin-bottom: 40px;
        }

        .search-box {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        .search-box input {
            flex: 1;
            padding: 12px 16px;
            background-color: #333;
            border: 1px solid #444;
            border-radius: 8px;
            color: #e0e0e0;
            font-size: 1em;
            transition: all 0.3s;
        }

        .search-box input:focus {
            outline: none;
            border-color: #667eea;
            background-color: #3a3a3a;
        }

        .search-box button {
            padding: 12px 24px;
            background-color: #667eea;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }

        .search-box button:hover {
            background-color: #5569d8;
        }

        .filter-options {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .filter-btn {
            padding: 8px 16px;
            background-color: #333;
            border: 1px solid #444;
            color: #b0b0b0;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 0.9em;
        }

        .filter-btn:hover,
        .filter-btn.active {
            background-color: #667eea;
            border-color: #667eea;
            color: white;
        }

        .pilots-container {
            width: 100%;
            max-width: 900px;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .pilot-card {
            background: #232323;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 10px;
            padding: 20px;
            transition: border-color 0.15s;
        }

        .pilot-card:hover {
            border-color: rgba(255,255,255,0.16);
        }

        .pilot-avatar {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            overflow: hidden;
            margin-bottom: 14px;
            background: #2e2e2e;
            border: 1px solid rgba(255,255,255,0.08);
        }

        .pilot-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .pilot-name {
            font-size: 1rem;
            font-weight: 700;
            color: #f5f3ef;
            margin-bottom: 4px;
            letter-spacing: -0.01em;
        }

        .pilot-callsign {
            color: rgba(245,243,239,0.45);
            font-size: 0.825rem;
            font-weight: 500;
            margin-bottom: 14px;
        }

        .pilot-info {
            font-size: 0.8rem;
            color: rgba(245,243,239,0.45);
            margin-bottom: 2px;
        }

        .pilot-hours {
            font-size: 0.95rem;
            font-weight: 600;
            color: #f5f3ef;
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px solid rgba(255,255,255,0.07);
        }

        .pilot-roles {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px solid rgba(255,255,255,0.07);
        }

        .pilot-role-badge {
            display: inline-block;
            padding: 3px 10px;
            background: rgba(255,255,255,0.07);
            color: rgba(245,243,239,0.75);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 20px;
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .no-results {
            text-align: center;
            padding: 40px 20px;
            color: #999;
        }

        .no-results h3 {
            color: #e0e0e0;
            margin-bottom: 10px;
        }

        .results-count {
            color: #999;
            font-size: 0.95em;
            margin-bottom: 20px;
            text-align: center;
        }

        footer {
            color: white;
            margin-top: 40px;
            text-align: center;
            opacity: 0.8;
            font-size: 0.8rem;
        }

        @media (max-width: 768px) {
            .pilots-container {
                grid-template-columns: 1fr;
            }

            .hero h1 {
                font-size: 1.8em;
            }

            .hero p {
                font-size: 0.95em;
            }

            .search-box {
                flex-direction: column;
            }

            .search-box input {
                padding: 12px;
                font-size: 16px;
            }

            .search-box button {
                padding: 12px;
                font-size: 1em;
            }

            .filter-options {
                justify-content: center;
            }

            .filter-btn {
                padding: 8px 12px;
                font-size: 0.85em;
            }

            .search-container {
                max-width: 100%;
            }
        }

        @media (max-width: 480px) {
            .main-content {
                padding: 12px;
                padding-top: 0;
            }

            .hero {
                margin-bottom: 20px;
                padding-top: 10px;
            }

            .hero h1 {
                font-size: 1.6em;
                margin-bottom: 5px;
            }

            .hero p {
                font-size: 0.9em;
            }

            .search-box {
                flex-direction: column;
                gap: 8px;
            }

            .search-box input {
                padding: 12px;
                font-size: 16px;
                width: 100%;
            }

            .search-box button {
                padding: 12px;
                font-size: 0.95em;
                width: 100%;
            }

            .filter-options {
                flex-direction: column;
                gap: 8px;
            }

            .filter-btn {
                padding: 10px 12px;
                font-size: 0.8em;
                width: 100%;
            }

            .pilots-container {
                grid-template-columns: 1fr;
                gap: 15px;
                max-width: 100%;
            }

            .pilot-card {
                padding: 15px;
            }

            .pilot-avatar {
                width: 60px;
                height: 60px;
                font-size: 30px;
            }

            .pilot-name {
                font-size: 1.1em;
            }

            .pilot-callsign {
                font-size: 0.85em;
            }

            .pilot-info {
                font-size: 0.85em;
            }

            .pilot-hours {
                font-size: 1.1em;
            }

            .pilot-role-badge {
                padding: 3px 8px;
                font-size: 0.7em;
            }

            .results-count {
                font-size: 0.85em;
            }

            footer {
                font-size: 0.85em;
                margin-top: 30px;
            }
        }
        <%- include('partials/fixed-sidebar-theme') %>
    </style>
</head>
<body>
        <%- include('partials/sidebar', { page: 'pilots' }) %>

    <div class="main-content">
        <div class="hero">
            <h1>Pilots Directory</h1>
            <p>Browse and search all pilots in our network</p>
        </div>

        <div class="search-container">
            <div class="search-box">
                <input 
                    type="text" 
                    id="searchInput" 
                    placeholder="Search pilots by name or callsign..." 
                    onkeyup="searchPilots()"
                >
                <button onclick="searchPilots()">Search</button>
            </div>

            <div class="filter-options">
                <button class="filter-btn active" onclick="filterByRole('all')">All Pilots</button>
                <button class="filter-btn" onclick="filterByRole('atc')">ATC</button>
                <button class="filter-btn" onclick="filterByRole('enforcer')">Enforcer</button>
                <button class="filter-btn" onclick="filterByRole('user')">User</button>
            </div>

            <div class="results-count">
                <span id="resultsCount">Loading pilots...</span>
            </div>
        </div>

        <div class="pilots-container" id="pilotsContainer"></div>

        <footer>
            <%#  <p>&copy; 2026 Aviation Realism Network. All rights reserved.</p> %>
            <p>Bringing realistic aviation simulation to VTOL VR</p>
        </footer>
    </div>

    <script>
        let allPilots = [];
        let currentFilter = 'all';

        document.addEventListener('DOMContentLoaded', function() {
            fetchPilots();
        });

        async function fetchPilots() {
            try {
                const response = await fetch('/api/users');
                if (!response.ok) {
                    throw new Error('Unable to load pilots data right now.');
                }

                const data = await response.json();
                allPilots = data.data || [];
                displayPilots(allPilots);
            } catch (error) {
                document.getElementById('pilotsContainer').innerHTML = `
                    <div class="no-results">
                        <h3>Error loading pilots</h3>
                        <p>${error.message}</p>
                    </div>
                `;
            }
        }

        function displayPilots(pilots) {
            const container = document.getElementById('pilotsContainer');
            const resultsCount = document.getElementById('resultsCount');

            if (pilots.length === 0) {
                container.innerHTML = `
                    <div class="no-results">
                        <h3>No pilots found</h3>
                        <p>Try adjusting your search filters or criteria.</p>
                    </div>
                `;
                resultsCount.textContent = 'No results found';
            } else {
                resultsCount.textContent = `Showing ${pilots.length} pilot(s)`;
                container.innerHTML = pilots.map(pilot => `
                    <div class="pilot-card">
                        <div class="pilot-avatar"><img src="${pilot.avatar || '/assets/logo.png' }" alt="Avatar" width="60" height="60" style="border-radius: 50%;" /></div>
                        <div class="pilot-name">${pilot.Username || 'Unknown'}</div>
                        <div class="pilot-callsign">${pilot.Callsign || 'N/A'}</div>
                        <div class="pilot-info">
                            <strong>Flight Hours:</strong>
                        </div>
                        <div class="pilot-hours">${pilot.Flighthours || 0} hrs</div>
                        ${pilot.Role && pilot.Role.length > 0 ? `
                            <div class="pilot-roles">
                                ${pilot.Role.map(role => `
                                    <span class="pilot-role-badge">${role}</span>
                                `).join('')}
                            </div>
                        ` : ''}
                    </div>
                `).join('');
            }
        }

        function searchPilots() {
            const searchQuery = document.getElementById('searchInput').value.toLowerCase();
            
            let filtered = allPilots.filter(pilot => {
                const matchesSearch = !searchQuery || 
                    (pilot.Username && pilot.Username.toLowerCase().includes(searchQuery)) ||
                    (pilot.Callsign && pilot.Callsign.toLowerCase().includes(searchQuery));

                const matchesRole = currentFilter === 'all' || 
                    (pilot.Role && pilot.Role.includes(currentFilter));

                return matchesSearch && matchesRole;
            });

            displayPilots(filtered);
        }

        function filterByRole(role) {
            currentFilter = role;
            
            // Update active button
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');

            searchPilots();
        }
    </script>
</body>
</html>
